@inherits LayoutComponentBase
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="app-shell">
    <header class="app-header">
        <div class="brand">
            <span class="brand-icon">◈</span>
            <span class="brand-name">TaxRateCollector</span>
        </div>
        <div class="user-nav">
            <AuthorizeView>
                <Authorized>
                    <div class="user-dropdown @(dropdownOpen ? "user-dropdown-open" : "")">
                        <button class="user-nav-link" @onclick="ToggleDropdown" @onclick:stopPropagation="true">
                            👤 @context.User.Identity?.Name ▾
                        </button>
                        @if (dropdownOpen)
                        {
                            <div class="user-dropdown-menu" @onclick:stopPropagation="true">
                                <a href="/settings" class="user-dropdown-item" @onclick="CloseDropdown">⚙ Settings</a>
                                <form method="post" action="/logout" style="margin:0">
                            <AntiforgeryToken />
                            <button type="submit" class="user-dropdown-item user-dropdown-item-danger">⏻ Log Out</button>
                        </form>
                            </div>
                        }
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="user-nav-link">Log In</a>
                    <a href="/register" class="btn-subscribe-sm">Sign Up</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <nav class="tab-bar">
        <NavLink class="tab" href="" Match="NavLinkMatch.All">
            <span class="tab-icon">◈</span>
            <span class="tab-label">Jurisdictions</span>
        </NavLink>
        <NavLink class="tab" href="glossary">
            <span class="tab-icon">☰</span>
            <span class="tab-label">Glossary</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="tab" href="logs">
                    <span class="tab-icon">◎</span>
                    <span class="tab-label">Logs</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Administrator">
            <Authorized>
                <NavLink class="tab tab-admin" href="setup">
                    <span class="tab-icon">⚒</span>
                    <span class="tab-label">Setup</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </nav>

    <main class="tab-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool dropdownOpen;

    private void ToggleDropdown() => dropdownOpen = !dropdownOpen;
    private void CloseDropdown() => dropdownOpen = false;
}
