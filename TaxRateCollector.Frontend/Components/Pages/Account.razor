@page "/account"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>My Account — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">My Account</h1>
            <p class="page-sub">@email</p>
        </div>
        <div class="header-actions">
            <a href="/subscribe" class="btn-primary" style="text-decoration:none;padding:.42rem 1rem">
                @(subscriber is null ? "Subscribe" : "Change Plan")
            </a>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state">Loading…</div>
}
else
{
    <div class="settings-grid">

        <!-- ── Subscription status ── -->
        <section class="settings-section">
            <h2>Subscription</h2>
            @if (subscriber is null || !activeStates.Any())
            {
                <p class="muted">No active subscription. <a href="/subscribe">Subscribe by state</a> to unlock tax rates and evidence.</p>
            }
            else
            {
                <div class="setting-row">
                    <span class="setting-label">Status</span>
                    <span class="save-confirm">● Active</span>
                </div>
                <div class="setting-row">
                    <span class="setting-label">States subscribed</span>
                    <span>@activeStates.Count states</span>
                </div>
                <div class="setting-row">
                    <span class="setting-label">Monthly total</span>
                    <span>@((activeStates.Count * pricePerState).ToString("C"))/mo (excl. tax)</span>
                </div>
                <div style="margin-top:1rem">
                    <div class="subscribe-section-title" style="font-size:.8rem;margin-bottom:.5rem">Subscribed States</div>
                    <div class="states-grid" style="grid-template-columns:repeat(auto-fill,minmax(100px,1fr))">
                        @foreach (var s in activeStates)
                        {
                            <div class="state-tile state-tile-active" style="cursor:default">
                                <span class="state-tile-code">@s.StateCode</span>
                                <span class="state-tile-name">@s.StateName</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </section>

        <!-- ── Billing history ── -->
        <section class="settings-section">
            <h2>Billing History</h2>
            @if (billingRecords.Count == 0)
            {
                <p class="muted">No billing records yet.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>States</th>
                            <th>Subtotal</th>
                            <th>Tax</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Order ID</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in billingRecords)
                        {
                            <tr>
                                <td class="mono">@b.CreatedAt[..10]</td>
                                <td>@b.StateCount</td>
                                <td>@b.Subtotal.ToString("C")</td>
                                <td>@b.TaxAmount.ToString("C")</td>
                                <td><strong>@b.Total.ToString("C")</strong></td>
                                <td>
                                    @if (b.Status == BillingStatus.Completed)
                                    { <span class="save-confirm">✓ @b.Status</span> }
                                    else
                                    { <span class="muted">@b.Status</span> }
                                </td>
                                <td class="mono" style="font-size:.75rem">@b.PayPalOrderId</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

    </div>
}

@code {
    private bool loading = true;
    private string email = "";
    private Subscriber? subscriber;
    private List<SubscribedState> activeStates = [];
    private List<BillingRecord> billingRecords = [];
    private decimal pricePerState;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        email = auth.User.Identity?.Name ?? "";
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (userId is not null)
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            pricePerState = (await db.PricingConfigs.FirstOrDefaultAsync())?.PricePerState ?? 0.01m;

            subscriber = await db.Subscribers
                .FirstOrDefaultAsync(s => s.UserId == userId && s.IsActive);

            if (subscriber is not null)
            {
                activeStates = await db.SubscribedStates
                    .Where(ss => ss.SubscriberId == subscriber.Id && ss.IsActive)
                    .OrderBy(ss => ss.StateName)
                    .ToListAsync();

                billingRecords = await db.BillingRecords
                    .Where(b => b.SubscriberId == subscriber.Id)
                    .OrderByDescending(b => b.CreatedAt)
                    .ToListAsync();
            }
        }

        loading = false;
    }
}
