@page "/subscribe"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IPayPalService PayPal
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Subscribe — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Subscribe</h1>
    <p class="page-sub">Select the states and product categories your business needs. Pay only for what you use.</p>
</div>

@if (loading)
{
    <div class="loading-state">Loading…</div>
}
else if (step == 3)
{
    <!-- Success -->
    <div class="auth-card" style="max-width:520px">
        <div style="font-size:2.5rem;margin-bottom:.5rem">✓</div>
        <h2 class="auth-title" style="color:var(--green)">Payment Complete!</h2>
        <p>You now have access to tax rates for <strong>@selectedStates.Count state(s)</strong> across <strong>@selectedCategories.Count product category/categories</strong>.</p>
        @if (lastBillingRecord is not null)
        {
            <div class="billing-summary">
                <div class="billing-row"><span>States</span><span>@lastBillingRecord.StateCount</span></div>
                <div class="billing-row"><span>Subtotal</span><span>@lastBillingRecord.Subtotal.ToString("C")/mo</span></div>
                <div class="billing-row"><span>Tax (@(lastBillingRecord.BillingStateCode) @((lastBillingRecord.TaxRate * 100).ToString("F3"))%)</span><span>@lastBillingRecord.TaxAmount.ToString("C")/mo</span></div>
                <div class="billing-row billing-total"><span>Total</span><span>@lastBillingRecord.Total.ToString("C")/mo</span></div>
                <div class="billing-row muted small"><span>Order ID</span><span>@lastBillingRecord.PayPalOrderId</span></div>
            </div>
        }
        <a href="/" class="btn-primary auth-btn" style="display:block;text-align:center;margin-top:1rem;text-decoration:none">
            Browse Tax Rates →
        </a>
    </div>
}
else
{
    <div class="subscribe-layout">

        <!-- ── Left: State selector ── -->
        <div class="subscribe-states">
            <div class="subscribe-section-title">
                Select States
                <span class="muted small">@selectedStates.Count selected</span>
            </div>
            <div class="states-grid">
                @foreach (var state in availableStates)
                {
                    var sc = state.StateCode;
                    var active = selectedStates.Contains(sc);
                    <button class="state-tile @(active ? "state-tile-active" : "")" @onclick="() => ToggleState(sc)">
                        <span class="state-tile-code">@sc</span>
                        <span class="state-tile-name">@state.Name</span>
                        @if (active) { <span class="state-tile-check">✓</span> }
                    </button>
                }
            </div>
            <div class="states-actions">
                <button class="btn-tiny" @onclick="SelectAll">Select All</button>
                <button class="btn-tiny" @onclick="ClearAll">Clear</button>
            </div>
        </div>

        <!-- ── Middle: Category selector ── -->
        <div class="subscribe-categories">
            <div class="subscribe-section-title">
                Select Product Categories
                <span class="muted small">@selectedCategories.Count selected</span>
            </div>
            <div class="category-select-list">
                @foreach (var (groupName, leaves) in availableCategoryGroups)
                {
                    <div class="cat-select-group">
                        <div class="cat-select-group-label">@groupName</div>
                        @foreach (var cat in leaves)
                        {
                            var active = selectedCategories.Contains(cat.Id);
                            <button class="cat-select-chip @(active ? "cat-select-active" : "")"
                                    @onclick="() => ToggleCategory(cat.Id)">
                                @if (active) { <span>✓</span> }
                                @cat.Name
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="states-actions">
                <button class="btn-tiny" @onclick="SelectAllCategories">Select All</button>
                <button class="btn-tiny" @onclick="ClearCategories">Clear</button>
            </div>
        </div>

        <!-- ── Right: Billing address + order summary ── -->
        <div class="subscribe-checkout">
            <div class="subscribe-section-title">Billing Address</div>
            <p class="muted small" style="margin-bottom:.8rem">Used to calculate sales tax on your subscription using our own jurisdiction data.</p>

            <div class="auth-field">
                <label>Full Name</label>
                <input class="setting-input" placeholder="Jane Smith" @bind="fullName" @bind:event="oninput" />
            </div>
            <div class="auth-field">
                <label>Address</label>
                <input class="setting-input" placeholder="123 Main St" @bind="address" @bind:event="oninput" />
            </div>
            <div style="display:grid;grid-template-columns:1fr 80px;gap:.6rem">
                <div class="auth-field">
                    <label>City</label>
                    <input class="setting-input" placeholder="Springfield" @bind="city" @bind:event="oninput" />
                </div>
                <div class="auth-field">
                    <label>ZIP</label>
                    <input class="setting-input" placeholder="62701" @bind="zip" @bind:event="oninput" />
                </div>
            </div>
            <div class="auth-field">
                <label>State</label>
                <select class="setting-input" @bind="billingState" @bind:after="OnBillingStateChange">
                    <option value="">— Select state —</option>
                    @foreach (var s in availableStates)
                    {
                        <option value="@s.StateCode">@s.Name (@s.StateCode)</option>
                    }
                </select>
            </div>

            <!-- Order summary -->
            <div class="order-summary">
                <div class="subscribe-section-title" style="margin-bottom:.6rem">Order Summary</div>
                <div class="billing-row"><span>States × @pricing.PricePerState.ToString("C")/mo</span><span>@selectedStates.Count × @pricing.PricePerState.ToString("C") = @StateSubtotal.ToString("C")</span></div>
                <div class="billing-row"><span>Categories × @pricing.PricePerCategory.ToString("C")/mo</span><span>@selectedCategories.Count × @pricing.PricePerCategory.ToString("C") = @CatSubtotal.ToString("C")</span></div>
                <div class="billing-row"><span>Subtotal</span><span>@PricePerMonth.ToString("C") / month</span></div>
                @if (!string.IsNullOrEmpty(billingState) && billingTaxRate > 0)
                {
                    <div class="billing-row"><span>Sales tax (@billingState @((billingTaxRate * 100).ToString("F3"))%)</span><span>@TaxAmount.ToString("C") / month</span></div>
                }
                else if (!string.IsNullOrEmpty(billingState))
                {
                    <div class="billing-row muted"><span>Sales tax (@billingState)</span><span>No tax on SaaS</span></div>
                }
                <div class="billing-row billing-total"><span>Total</span><span>@Total.ToString("C") / month</span></div>
            </div>

            @if (error is not null)
            {
                <div class="auth-error">@error</div>
            }

            @if (!isMock)
            {
                <!-- Real PayPal: show the standard button text -->
                <button class="btn-paypal" @onclick="Checkout" disabled="@(!CanCheckout || processing)">
                    @(processing ? "Processing…" : "Pay with PayPal")
                </button>
            }
            else
            {
                <button class="btn-paypal btn-paypal-mock" @onclick="Checkout" disabled="@(!CanCheckout || processing)">
                    @(processing ? "Processing…" : "Mock Payment — No charge")
                </button>
                <p class="muted small" style="text-align:center;margin-top:.4rem">
                    Credentials not configured — enter PayPal API keys in Settings → Admin → PayPal to accept real payments.
                </p>
            }
        </div>
    </div>
}

@code {
    private bool loading = true;
    private int step = 1;
    private bool processing;
    private string? error;
    private bool isMock = true;

    private sealed record CategoryItem(int Id, string Name, string GroupName);

    private PricingConfig pricing = new();
    private List<(string StateCode, string Name)> availableStates = [];
    private HashSet<string> selectedStates = [];

    private List<(string GroupName, List<CategoryItem> Leaves)> availableCategoryGroups = [];
    private HashSet<int> selectedCategories = [];

    // Billing form
    private string fullName = "";
    private string address = "";
    private string city = "";
    private string zip = "";
    private string billingState = "";
    private decimal billingTaxRate;

    private BillingRecord? lastBillingRecord;

    private decimal StateSubtotal => selectedStates.Count * pricing.PricePerState;
    private decimal CatSubtotal => selectedCategories.Count * pricing.PricePerCategory;
    private decimal PricePerMonth => StateSubtotal + CatSubtotal;
    private decimal TaxAmount => PricePerMonth * billingTaxRate;
    private decimal Total => PricePerMonth + TaxAmount;

    private bool CanCheckout =>
        (selectedStates.Count > 0 || selectedCategories.Count > 0) &&
        !string.IsNullOrWhiteSpace(fullName) &&
        !string.IsNullOrWhiteSpace(address) &&
        !string.IsNullOrWhiteSpace(city) &&
        !string.IsNullOrWhiteSpace(zip) &&
        !string.IsNullOrWhiteSpace(billingState);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        pricing = await db.PricingConfigs.FirstOrDefaultAsync() ?? new PricingConfig();

        availableStates = await db.Jurisdictions
            .Where(j => j.JurisdictionType == JurisdictionType.State && j.IsActive)
            .OrderBy(j => j.JurisdictionName)
            .Select(j => new { j.StateCode, j.JurisdictionName })
            .ToListAsync()
            .ContinueWith(t => t.Result.Select(x => (x.StateCode, x.JurisdictionName)).ToList());

        // Load leaf categories grouped by parent
        var cats = await db.TaxCategories
            .Where(c => c.IsLeaf && c.ParentId != null)
            .OrderBy(c => c.SortOrder)
            .Select(c => new { c.Id, c.Name, ParentId = c.ParentId!.Value })
            .ToListAsync();

        var groups = await db.TaxCategories
            .Where(c => !c.IsLeaf && c.ParentId != null)
            .Select(c => new { c.Id, c.Name })
            .ToListAsync();

        var groupLookup = groups.ToDictionary(g => g.Id, g => g.Name);
        availableCategoryGroups = cats
            .GroupBy(c => c.ParentId)
            .Select(g => (
                GroupName: groupLookup.GetValueOrDefault(g.Key, "Other"),
                Leaves: g.Select(c => new CategoryItem(c.Id, c.Name, groupLookup.GetValueOrDefault(c.ParentId, "Other"))).ToList()
            ))
            .ToList();

        // Pre-populate selections from existing subscription
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId != null)
        {
            var existingStates = await db.SubscribedStates
                .Where(ss => ss.Subscriber.UserId == userId && ss.IsActive)
                .Select(ss => ss.StateCode)
                .ToListAsync();
            selectedStates = new HashSet<string>(existingStates, StringComparer.OrdinalIgnoreCase);

            var existingCats = await db.SubscribedCategories
                .Where(sc => sc.Subscriber.UserId == userId && sc.IsActive)
                .Select(sc => sc.CategoryId)
                .ToListAsync();
            selectedCategories = new HashSet<int>(existingCats);

            var sub = await db.Subscribers.FirstOrDefaultAsync(s => s.UserId == userId);
            if (sub != null)
            {
                fullName = sub.FullName;
                address = sub.AddressLine1;
                city = sub.City;
                zip = sub.ZipCode;
                billingState = sub.StateCode;
            }
        }

        isMock = !await PayPal.IsConfiguredAsync();
        loading = false;
    }

    private void ToggleState(string code)
    {
        if (!selectedStates.Remove(code)) selectedStates.Add(code);
    }
    private void SelectAll() => selectedStates = availableStates.Select(s => s.StateCode).ToHashSet();
    private void ClearAll() => selectedStates.Clear();

    private void ToggleCategory(int id)
    {
        if (!selectedCategories.Remove(id)) selectedCategories.Add(id);
    }
    private void SelectAllCategories() =>
        selectedCategories = availableCategoryGroups.SelectMany(g => g.Leaves).Select(c => c.Id).ToHashSet();
    private void ClearCategories() => selectedCategories.Clear();

    private async Task OnBillingStateChange()
    {
        billingTaxRate = 0;
        if (string.IsNullOrEmpty(billingState)) return;

        await using var db = await DbFactory.CreateDbContextAsync();
        var jurisdiction = await db.Jurisdictions
            .Where(j => j.StateCode == billingState && j.JurisdictionType == JurisdictionType.State)
            .FirstOrDefaultAsync();
        if (jurisdiction is null) return;

        var rate = await db.TaxRates
            .Where(r => r.JurisdictionId == jurisdiction.Id && r.IsCurrent)
            .Select(r => r.Rate)
            .FirstOrDefaultAsync();

        billingTaxRate = rate;
    }

    private async Task Checkout()
    {
        error = null;
        processing = true;
        StateHasChanged();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (userId is null) { error = "Session expired. Please log in again."; return; }

            await using var db = await DbFactory.CreateDbContextAsync();

            // Get or create subscriber profile
            var subscriber = await db.Subscribers.FirstOrDefaultAsync(s => s.UserId == userId)
                ?? new Subscriber
                {
                    UserId = userId,
                    CreatedAt = DateTime.UtcNow.ToString("o")
                };

            subscriber.FullName = fullName;
            subscriber.AddressLine1 = address;
            subscriber.City = city;
            subscriber.StateCode = billingState;
            subscriber.ZipCode = zip;
            subscriber.IsActive = true;

            if (subscriber.Id == 0) db.Subscribers.Add(subscriber);
            await db.SaveChangesAsync();

            // Create billing record
            var billing = new BillingRecord
            {
                SubscriberId = subscriber.Id,
                StateCount = selectedStates.Count,
                PricePerState = pricing.PricePerState,
                Subtotal = PricePerMonth,
                BillingStateCode = billingState,
                TaxRate = billingTaxRate,
                TaxAmount = TaxAmount,
                Total = Total,
                Currency = pricing.Currency,
                Status = BillingStatus.Pending,
                CreatedAt = DateTime.UtcNow.ToString("o")
            };
            db.BillingRecords.Add(billing);
            await db.SaveChangesAsync();

            // PayPal order
            var description = $"TaxRateCollector — {selectedStates.Count} state(s), {selectedCategories.Count} category/categories/month";
            var orderResult = await PayPal.CreateOrderAsync(Total, pricing.Currency, description);

            if (!orderResult.Success)
            {
                billing.Status = BillingStatus.Failed;
                await db.SaveChangesAsync();
                error = $"PayPal error: {orderResult.Error}";
                return;
            }

            billing.PayPalOrderId = orderResult.OrderId;
            await db.SaveChangesAsync();

            // Capture
            var captured = await PayPal.CaptureOrderAsync(orderResult.OrderId);
            billing.Status = captured ? BillingStatus.Completed : BillingStatus.Failed;
            await db.SaveChangesAsync();

            if (!captured) { error = "Payment capture failed. Please try again."; return; }

            // Activate subscribed states (soft-add — deactivate states no longer subscribed)
            var existing = await db.SubscribedStates
                .Where(ss => ss.SubscriberId == subscriber.Id)
                .ToListAsync();

            foreach (var ss in existing) ss.IsActive = false;

            foreach (var code in selectedStates)
            {
                var name = availableStates.FirstOrDefault(s => s.StateCode == code).Name ?? code;
                var existing2 = existing.FirstOrDefault(ss => ss.StateCode == code);
                if (existing2 is not null)
                    existing2.IsActive = true;
                else
                    db.SubscribedStates.Add(new SubscribedState
                    {
                        SubscriberId = subscriber.Id,
                        StateCode = code,
                        StateName = name,
                        IsActive = true,
                        StartDate = DateTime.UtcNow.ToString("o")
                    });
            }

            // Activate subscribed categories
            var existingCats = await db.SubscribedCategories
                .Where(sc => sc.SubscriberId == subscriber.Id)
                .ToListAsync();

            foreach (var sc in existingCats) sc.IsActive = false;

            var allLeaves = availableCategoryGroups.SelectMany(g => g.Leaves).ToList();
            foreach (var catId in selectedCategories)
            {
                var catName = allLeaves.FirstOrDefault(c => c.Id == catId)?.Name ?? "";
                var existing2 = existingCats.FirstOrDefault(sc => sc.CategoryId == catId);
                if (existing2 is not null)
                    existing2.IsActive = true;
                else
                    db.SubscribedCategories.Add(new SubscribedCategory
                    {
                        SubscriberId = subscriber.Id,
                        CategoryId = catId,
                        CategoryName = catName,
                        IsActive = true,
                        StartDate = DateTime.UtcNow.ToString("o")
                    });
            }
            await db.SaveChangesAsync();

            lastBillingRecord = billing;
            step = 3;
        }
        catch (Exception ex) { error = $"Unexpected error: {ex.Message}"; }
        finally { processing = false; StateHasChanged(); }
    }
}
