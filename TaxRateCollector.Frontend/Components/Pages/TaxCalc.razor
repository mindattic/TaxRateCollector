@page "/calc"
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ITaxCalculator Calculator
@rendermode InteractiveServer

<PageTitle>Tax Calculator — TaxRateCollector</PageTitle>

<h1>Tax Calculator</h1>

<div class="calc-form">
    <div class="form-group">
        <label>Jurisdiction</label>
        <input class="filter-input" placeholder="Type to search…" value="@searchText" @oninput="OnSearchInput" />
        @if (suggestions.Count > 0 && !jurisdictionSelected)
        {
            <div class="suggestions">
                @foreach (var j in suggestions)
                {
                    <div class="suggestion-item" @onclick="() => SelectJurisdiction(j)">
                        @j.Name (@j.StateCode) — @j.Type
                    </div>
                }
            </div>
        }
        @if (jurisdictionSelected)
        {
            <div class="selected-tag">
                @selectedName
                <button class="btn-tiny" @onclick="ClearJurisdiction">✕</button>
            </div>
        }
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Price ($)</label>
            <input class="filter-input" type="number" min="0" step="0.01" @bind="price" />
        </div>
        <div class="form-group">
            <label>Quantity</label>
            <input class="filter-input" type="number" min="1" @bind="quantity" />
        </div>
    </div>

    <details style="margin-top:8px">
        <summary style="cursor:pointer;color:var(--muted)">Advanced options</summary>
        <div class="form-row" style="margin-top:8px">
            <div class="form-group">
                <label>ABV % (for excise)</label>
                <input class="filter-input" type="number" min="0" max="100" step="0.1" @bind="abvPct" placeholder="e.g. 5" />
            </div>
            <div class="form-group">
                <label>Volume per unit (gal)</label>
                <input class="filter-input" type="number" min="0" step="0.001" @bind="volumeGal" placeholder="e.g. 0.5" />
            </div>
            <div class="form-group">
                <label>Weight per unit (oz)</label>
                <input class="filter-input" type="number" min="0" step="0.001" @bind="weightOz" placeholder="e.g. 12" />
            </div>
            <div class="form-group">
                <label>Wholesale price ($)</label>
                <input class="filter-input" type="number" min="0" step="0.01" @bind="wholesalePrice" placeholder="for OTP/cigar rates" />
            </div>
        </div>
    </details>

    <button class="btn-primary" @onclick="CalculateAsync" disabled="@(!CanCalculate)" style="margin-top:12px">Calculate</button>
</div>

@if (result is not null)
{
    <div class="calc-result">
        <div class="result-label">Tax to Collect (retailer-remitted)</div>
        <div class="result-value">@result.TotalTaxAmount.ToString("C")</div>
        <div class="result-detail">
            <span>Jurisdiction: <strong>@result.JurisdictionName</strong></span>
            <span>Combined Rate: <strong>@result.TotalPercentageRate.ToString("P4")</strong></span>
            <span>Subtotal: <strong>@((price * quantity).ToString("C"))</strong></span>
            <span>Invoice Total: <strong>@((price * quantity + result.TotalTaxAmount).ToString("C"))</strong></span>
        </div>
        @if (result.TotalIncludedInPriceAmount > 0)
        {
            <div class="setup-status-warn" style="margin-top:8px;padding:8px 12px;border-radius:4px">
                Upstream excise taxes already embedded in product price: <strong>@result.TotalIncludedInPriceAmount.ToString("C")</strong> — do not add to customer invoice.
            </div>
        }
        @if (result.RateLines.Count > 0)
        {
            <table class="data-table" style="margin-top:12px">
                <thead>
                    <tr>
                        <th>Rate Name</th><th>Rate</th><th>Basis</th><th>Compound</th>
                        <th>Sale Context</th><th>Remittance</th><th>Tax Amount</th><th>Effective</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in result.RateLines)
                    {
                        <tr class="@(line.IsIncludedInPrice ? "row-muted" : "")">
                            <td>
                                @line.RateName
                                @if (line.IsIncludedInPrice) { <span class="badge badge-muted" title="Already embedded in wholesale price">embedded</span> }
                            </td>
                            <td>@(line.Basis == TaxRateCollector.Core.Enums.RateBasis.Percentage || line.Basis == TaxRateCollector.Core.Enums.RateBasis.PercentageOfWholesale ? line.Rate.ToString("P4") : line.Rate.ToString("F4") + " " + line.Unit)</td>
                            <td>@line.Basis</td>
                            <td>@(line.IsCompound ? "✓" : "")</td>
                            <td>@line.SaleContext</td>
                            <td>@line.RemittancePoint</td>
                            <td>@line.TaxAmount.ToString("C")</td>
                            <td>@line.EffectiveDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
@if (noRate)
{
    <p class="muted">No current rate found for the selected jurisdiction.</p>
}

@code {
    private string searchText = string.Empty;
    private bool jurisdictionSelected;
    private int selectedId;
    private string selectedName = string.Empty;
    private decimal price = 100m;
    private int quantity = 1;
    private decimal? abvPct;
    private decimal? volumeGal;
    private decimal? weightOz;
    private decimal? wholesalePrice;
    private TaxCalcResult? result;
    private bool noRate;

    private record JurisdictionOption(int Id, string Name, string StateCode, string Type);
    private List<JurisdictionOption> allJurisdictions = [];
    private List<JurisdictionOption> suggestions = [];

    private bool CanCalculate => jurisdictionSelected && price > 0 && quantity > 0;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        allJurisdictions = await db.Jurisdictions
            .Where(j => j.IsActive || true) // show all for calc
            .Select(j => new JurisdictionOption(j.Id, j.JurisdictionName, j.StateCode, j.JurisdictionType.ToString()))
            .ToListAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        FilterJurisdictions();
    }

    private void FilterJurisdictions()
    {
        jurisdictionSelected = false;
        result = null;
        noRate = false;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            suggestions = [];
            return;
        }

        suggestions = allJurisdictions
            .Where(j => j.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                     || j.StateCode.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList();
    }

    private void SelectJurisdiction(JurisdictionOption j)
    {
        selectedId = j.Id;
        selectedName = $"{j.Name} ({j.StateCode})";
        searchText = selectedName;
        jurisdictionSelected = true;
        suggestions = [];
    }

    private void ClearJurisdiction()
    {
        selectedId = 0;
        selectedName = string.Empty;
        searchText = string.Empty;
        jurisdictionSelected = false;
        result = null;
        noRate = false;
        suggestions = [];
    }

    private async Task CalculateAsync()
    {
        result = null;
        noRate = false;
        var opts = new TaxCalcOptions(
            Abv:            abvPct.HasValue ? abvPct.Value / 100m : null,
            Volume:         volumeGal,
            Weight:         weightOz,
            WholesalePrice: wholesalePrice);
        var r = await Calculator.CalculateAsync(selectedId, price, quantity, opts);
        if (r is null) noRate = true;
        else result = r;
    }
}
