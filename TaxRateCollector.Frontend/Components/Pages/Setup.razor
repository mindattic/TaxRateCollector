</div>

<!-- ── Danger Zone ────────────────────────────────────────────────────────────── -->
<div class="setup-card settings-section-danger">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title" style="color:var(--color-error,#dc2626)">Danger Zone</h2>
            <p class="setup-card-desc">
                Permanently deletes all collected data. The schema (tables, indexes, migrations) is preserved.
                Login credentials and payment configuration are <strong>not</strong> cleared.
                You will need to re-run the Phase 2 import pipeline after truncating.
            </p>
        </div>
    </div>
    <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
        <button class="btn-danger" @onclick="TruncateAll" disabled="@truncateBusy">
            @(truncateBusy ? "Truncating…" : "Truncate All Data")
        </button>
        @if (!string.IsNullOrEmpty(truncateMsg))
        {
            <span class="@(truncateMsg.StartsWith("✗") ? "text-error" : "save-confirm")">@truncateMsg</span>
        }
    </div>
    <p class="section-note" style="margin-top:.5rem;color:var(--color-error,#dc2626)">
        Clears: Jurisdictions · TaxRates · ZipCodes · TaxCategories · TaxCategoryRules ·
        ExciseTaxRates · ScrapeRuns · ChangeLog · SourceDocuments · Subscribers · BillingRecords · LogEntries
    </p>
</div>

@code {
    // ── Counts ────────────────────────────────────────────────────────────────
    private int countyCount, cityCount, zipCount, taxCategoryCount, scrapeRunCount, jurisdictionsWithSources;

    private bool step1Ok => urlResults.Count > 0 && urlResults.Values.All(v => v);
    private bool step2Ok => taxCategoryCount > 0;
    private bool step3Ok => countyCount > 0 && cityCount > 0;
    private bool step4Ok => zipCount > 0;
    private bool step5Ok => jurisdictionsWithSources > 0;
    private bool step6Ok => scrapeRunCount > 0;

    // ── URL validation ────────────────────────────────────────────────────────
    private bool checkingUrls;
    private Dictionary<string, bool> urlResults = [];

    private Dictionary<string, (string Label, Func<string> Url)> UrlMap => new()
    {
        ["CensusCountyGaz"]     = ("Census County Gazetteer (ZIP)",       () => settings.Current.CensusCountyGazUrl),
        ["CensusPlaceGaz"]      = ("Census Place Gazetteer (ZIP)",         () => settings.Current.CensusPlaceGazUrl),
        ["CensusZctaCounty"]    = ("Census ZCTA→County crosswalk (TXT)",   () => settings.Current.CensusZctaCountyUrl),
        ["CensusZctaPlace"]     = ("Census ZCTA→Place crosswalk (TXT)",    () => settings.Current.CensusZctaPlaceUrl),
        ["SstAgreement"]        = ("SSUTA Agreement PDF (Appendix C)",      () => settings.Current.SstAgreementUrl),
        ["SstTaxabilityMatrix"] = ("SST Taxability Matrix (web)",           () => settings.Current.SstTaxabilityMatrixUrl),
        ["SstMemberStates"]     = ("SST Member States page (web)",          () => settings.Current.SstMemberStatesUrl),
    };

    // ── Import state ──────────────────────────────────────────────────────────
    private bool importBusy;
    private bool censusRunning, zipRunning, sstRunning;
    private string? importMsg;
    private string? sstMsg;
    private string? runAllMsg;

    // ── ZIP rich state ────────────────────────────────────────────────────────
    private CancellationTokenSource? zipCts;
    private ZipImportProgress zipProgress = new(0, 0, 0, 0, 0);
    private ZipImportResult? zipResult;
    private int zipLinkedCounty, zipLinkedCity;
    private record ZipStateRow(string StateCode, int Total, int CountyLinked, int CityLinked);
    private List<ZipStateRow> zipStateCounts = [];

    // ── Config / admin state ──────────────────────────────────────────────────
    private bool configBusy;
    private string? configMsg;
    private bool adminBusy;
    private string? adminStatus;
    private PricingConfig? pricing;
    private PayPalConfig? paypal;
    private bool backupBusy;
    private string? backupMsg;
    private string backupPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
        $"TaxRateCollector_{DateTime.Now:yyyyMMdd}.bacpac");
    private bool truncateBusy;
    private string? truncateMsg;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        await using var db = await DbFactory.CreateDbContextAsync();
        pricing = await db.PricingConfigs.OrderBy(x => x.Id).FirstOrDefaultAsync();
        paypal  = await db.PayPalConfigs.OrderBy(x => x.Id).FirstOrDefaultAsync();
        _ = PollScrapeProgressAsync(_pollCts.Token);
    }

    private async Task Refresh()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        countyCount              = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.County);
        cityCount                = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.City);
        zipCount                 = await db.ZipCodes.CountAsync();
        taxCategoryCount         = await db.TaxCategories.CountAsync();
        scrapeRunCount           = await db.ScrapeRuns.CountAsync();
        jurisdictionsWithSources = await db.Jurisdictions.CountAsync(
            j => j.SourceUrl != null && j.SourceUrl != "" && j.JurisdictionType != JurisdictionType.Country);

        if (zipCount > 0 && zipStateCounts.Count == 0)
            await LoadZipStateCountsAsync();
    }

    // ── URL check ────────────────────────────────────────────────────────────

    private async Task CheckSources()
    {
        checkingUrls = true;
        urlResults = [];
        StateHasChanged();

        using var http = HttpClientFactory.CreateClient();
        http.Timeout = TimeSpan.FromSeconds(10);

        var tasks = UrlMap.Select(async kv =>
        {
            var url = kv.Value.Url();
            if (string.IsNullOrWhiteSpace(url)) return (kv.Key, false);
            try
            {
                using var req = new HttpRequestMessage(HttpMethod.Head, url);
                using var resp = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);
                return (kv.Key, resp.IsSuccessStatusCode || (int)resp.StatusCode < 400);
            }
            catch { return (kv.Key, false); }
        });

        var results = await Task.WhenAll(tasks);
        urlResults = results.ToDictionary(r => r.Item1, r => r.Item2);
        checkingUrls = false;
        StateHasChanged();
    }

    // ── SST import ───────────────────────────────────────────────────────────

    private async Task RunSstImport()
    {
        importBusy = sstRunning = true;
        sstMsg = "Starting…";
        StateHasChanged();
        try
        {
            var p = new Progress<string>(msg => { sstMsg = msg; InvokeAsync(StateHasChanged); });
            var r = await sstSvc.ImportAsync(p);
            sstMsg = r.Success
                ? $"✓ {r.CategoriesCreated} categories imported in {r.Elapsed:m\\:ss}"
                : $"✗ {r.Error}";
            await Refresh();
        }
        catch (Exception ex) { sstMsg = $"✗ {ex.Message}"; }
        finally { importBusy = sstRunning = false; StateHasChanged(); }
    }

    // ── Census import ────────────────────────────────────────────────────────

    private async Task RunCensusImport()
    {
        importBusy = censusRunning = true;
        importMsg = "Importing counties & cities…";
        StateHasChanged();
        try
        {
            var p = new Progress<CensusImportProgress>(snap =>
            {
                importMsg = $"{snap.Stage}: {snap.Created:N0} created";
                InvokeAsync(StateHasChanged);
            });
            var r = await censusSvc.ImportAsync(p);
            importMsg = $"✓ {r.CountiesCreated:N0} counties · {r.CitiesCreated:N0} cities created in {r.Elapsed:m\\:ss}";
            await Refresh();
        }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { importBusy = censusRunning = false; StateHasChanged(); }
    }

    // ── ZIP import ───────────────────────────────────────────────────────────

    private async Task RunZipImport()
    {
        importBusy = zipRunning = true;
        zipResult = null;
        zipProgress = new(0, 0, 0, 0, 0);
        zipCts = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            var p = new Progress<ZipImportProgress>(snap =>
            {
                zipProgress = snap;
                InvokeAsync(StateHasChanged);
            });
            zipResult = await zipSvc.ImportAsync(p, zipCts.Token);
            await LoadZipLinkStatsAsync();
            await Refresh();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { importBusy = zipRunning = false; zipCts = null; StateHasChanged(); }
    }

    private void StopZipImport() => zipCts?.Cancel();

    private async Task LoadZipLinkStatsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        zipLinkedCounty = await db.ZipCodes.CountAsync(z => z.CountyJurisdictionId != null);
        zipLinkedCity   = await db.ZipCodes.CountAsync(z => z.CityJurisdictionId   != null);
    }

    private async Task LoadZipStateCountsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        zipStateCounts = await db.ZipCodes
            .GroupBy(z => z.StateCode)
            .Select(g => new ZipStateRow(
                g.Key,
                g.Count(),
                g.Count(z => z.CountyJurisdictionId != null),
                g.Count(z => z.CityJurisdictionId   != null)))
            .ToListAsync();
    }

    // ── Run All ──────────────────────────────────────────────────────────────

    private async Task RunAllSteps()
    {
        importBusy = true;
        runAllMsg = "Step 1/4 — Checking URLs…";
        StateHasChanged();

        try
        {
            await CheckSources();
            if (!step1Ok) { runAllMsg = "✗ URL check failed — fix URLs in Settings first."; return; }

            if (!step2Ok)
            {
                runAllMsg = "Step 2/4 — Importing SST taxonomy…";
                StateHasChanged();
                await RunSstImport();
                if (sstMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ SST step failed: {sstMsg}"; return; }
            }

            if (!step3Ok)
            {
                runAllMsg = "Step 3/4 — Importing Census jurisdictions…";
                StateHasChanged();
                await RunCensusImport();
                if (importMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ Census step failed: {importMsg}"; return; }
            }

            if (!step4Ok)
            {
                runAllMsg = "Step 4/4 — Importing ZIP codes…";
                StateHasChanged();
                await RunZipImport();
                if (importMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ ZIP step failed: {importMsg}"; return; }
            }

            runAllMsg = "✓ All steps complete.";
        }
        catch (Exception ex) { runAllMsg = $"✗ {ex.Message}"; }
        finally { importBusy = false; StateHasChanged(); }
    }

    private void ClearCensusCache() { censusSvc.ClearCache(); importMsg = "Census cache cleared."; StateHasChanged(); }
    private void ClearZipCache()    { zipSvc.ClearCache();    importMsg = "ZIP cache cleared.";    StateHasChanged(); }

    private static string TruncateUrl(string url) =>
        url.Length <= 55 ? url : url[..52] + "…";

    // ── Scrape state ──────────────────────────────────────────────────────────
    private string? scrapeStatus;
    private int? pausedScrapeRunId;
    private ScrapeRun? activeScrapeRun;
    private CancellationTokenSource _pollCts = new();

    private void StartScrape()
    {
        scrapeStatus = null;
        ScrapeCoordinator.TryEnqueueStart();
    }

    private void ResumeScrape()
    {
        if (pausedScrapeRunId is null) return;
        scrapeStatus = null;
        ScrapeCoordinator.TryEnqueueResume(pausedScrapeRunId.Value);
    }

    private async Task PollScrapeProgressAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await using var db = await DbFactory.CreateDbContextAsync(ct);

                activeScrapeRun = await db.ScrapeRuns
                    .Where(r => r.Status == ScrapeStatus.Running)
                    .OrderByDescending(r => r.Id)
                    .FirstOrDefaultAsync(ct);

                pausedScrapeRunId = activeScrapeRun is null
                    ? await db.ScrapeRuns
                        .Where(r => r.Status == ScrapeStatus.Paused)
                        .OrderByDescending(r => r.Id)
                        .Select(r => (int?)r.Id)
                        .FirstOrDefaultAsync(ct)
                    : null;

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        await _pollCts.CancelAsync();
        _pollCts.Dispose();
    }

    // ── Discovery state ───────────────────────────────────────────────────────
    private bool discoveryRunning;
    private CancellationTokenSource? discoveryCts;
    private int discoveryTotal, discoveryProcessed, discoveryFound, discoveryNotFound, discoverySkipped, discoveryErrors;
    private DateTime? discoveryCompletedAt;
    private string discoveryFilter = "All";
    private string discoverySearch = "";
    private readonly List<DiscoveryResult> discoveryResults = new();

    private IEnumerable<DiscoveryResult> DiscoveryFilteredResults =>
        discoveryResults
            .Where(r => discoveryFilter == "All" || r.Status == discoveryFilter)
            .Where(r => string.IsNullOrEmpty(discoverySearch) ||
                        r.JurisdictionName.Contains(discoverySearch, StringComparison.OrdinalIgnoreCase) ||
                        r.StateCode.Contains(discoverySearch, StringComparison.OrdinalIgnoreCase));

    private async Task StartDiscovery()
    {
        discoveryRunning     = true;
        discoveryCts         = new CancellationTokenSource();
        discoveryTotal       = 0; discoveryProcessed = 0;
        discoveryFound       = 0; discoveryNotFound  = 0;
        discoverySkipped     = 0; discoveryErrors    = 0;
        discoveryCompletedAt = null;
        discoveryResults.Clear();
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            discoveryTotal = await db.Jurisdictions
                .CountAsync(j => j.IsActive && j.JurisdictionType != JurisdictionType.Country, discoveryCts.Token);
            await InvokeAsync(StateHasChanged);

            var countries = await db.Jurisdictions
                .Where(j => j.JurisdictionType == JurisdictionType.Country && j.IsActive)
                .OrderBy(j => j.JurisdictionName)
                .ToListAsync(discoveryCts.Token);

            foreach (var country in countries)
                await DiscoverRecursiveAsync(country, db, discoveryCts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            discoveryResults.Insert(0, new DiscoveryResult
            { JurisdictionName = "Discovery run", Status = "Error", Notes = ex.Message, ProcessedAt = DateTime.UtcNow });
        }
        finally { discoveryRunning = false; discoveryCompletedAt = DateTime.UtcNow; await InvokeAsync(StateHasChanged); }
    }

    private async Task DiscoverRecursiveAsync(Jurisdiction jurisdiction, AppDbContext db, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();
        if (jurisdiction.JurisdictionType != JurisdictionType.Country)
        {
            DiscoveryResult result;
            try { result = await DiscoveryService.DiscoverAsync(jurisdiction, ct); }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex)
            {
                result = new DiscoveryResult
                {
                    JurisdictionId = jurisdiction.Id, JurisdictionName = jurisdiction.JurisdictionName,
                    StateCode = jurisdiction.StateCode, Tier = jurisdiction.JurisdictionType,
                    Status = "Error", Notes = ex.Message, ProcessedAt = DateTime.UtcNow,
                };
            }
            discoveryResults.Insert(0, result);
            discoveryProcessed++;
            switch (result.Status)
            {
                case "Found":    discoveryFound++;    break;
                case "NotFound": discoveryNotFound++; break;
                case "Skipped":  discoverySkipped++;  break;
                case "Error":    discoveryErrors++;   break;
            }
            if (discoveryProcessed % 10 == 0 || result.Status is "Error" or "Found")
                await InvokeAsync(StateHasChanged);
        }
        var children = await db.Jurisdictions
            .Where(j => j.ParentId == jurisdiction.Id && j.IsActive)
            .OrderBy(j => j.JurisdictionName)
            .ToListAsync(ct);
        foreach (var child in children)
            await DiscoverRecursiveAsync(child, db, ct);
    }

    private void StopDiscovery() => discoveryCts?.Cancel();

    private void ClearDiscovery()
    {
        discoveryResults.Clear();
        discoveryTotal = discoveryProcessed = discoveryFound = discoveryNotFound = discoverySkipped = discoveryErrors = 0;
        discoveryCompletedAt = null;
    }

    private static string TierClass(JurisdictionType tier) => tier switch
    {
        JurisdictionType.State  => "tier-state",
        JurisdictionType.County => "tier-county",
        JurisdictionType.City   => "tier-city",
        _                       => "tier-country"
    };

    private static string TruncateDiscoveryUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url == "—") return url;
        return url.Length <= 40 ? url : url[..37] + "…";
    }

