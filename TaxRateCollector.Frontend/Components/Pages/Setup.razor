@page "/setup"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ICensusJurisdictionImportService censusSvc
@inject IZipImportService zipSvc
@inject ISstTaxonomyImportService sstSvc
@inject IDiscoveryService DiscoveryService
@inject IScrapeOrchestrator Orchestrator
@inject SettingsService settings
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Setup — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Setup</h1>
    <p class="page-sub">
        One-time data population. Complete these steps in order to fill the database
        from authoritative external sources before running the scrape pipeline.
    </p>
</div>

<!-- ── Checklist ────────────────────────────────────────────────────────────── -->
<div class="setup-checklist">
    <div class="setup-checklist-header">
        <h2 class="setup-checklist-title">Progress</h2>
        <p class="setup-checklist-sub">Each step unlocks the next. All data is sourced from official external authorities.</p>
    </div>
    <ol class="setup-steps">
        <li class="setup-step @(step1Ok ? "step-ok" : "step-active")">
            <span class="step-icon">@(step1Ok ? "✓" : "1")</span>
            <div class="step-body">
                <strong>Validate data source URLs</strong>
                <span class="step-desc">
                    All Census and SST URLs must be reachable before importing.
                    Source URLs are configured in <a href="/settings">Settings</a>.
                    @if (!step1Ok) { <span class="step-action">→ Use the <em>Check Sources</em> button below</span> }
                </span>
            </div>
        </li>
        <li class="setup-step @(step2Ok ? "step-ok" : (step1Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step2Ok ? "✓" : "2")</span>
            <div class="step-body">
                <strong>Import SST product/service taxonomy</strong>
                <span class="step-desc">
                    Source: SSUTA Agreement PDF, Appendix C — SST Governing Board.
                    @taxCategoryCount.ToString("N0") categories in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step3Ok ? "step-ok" : (step2Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step3Ok ? "✓" : "3")</span>
            <div class="step-body">
                <strong>Import Census jurisdictions — counties &amp; cities</strong>
                <span class="step-desc">
                    Source: US Census Bureau Gazetteer files (ZIP archives).
                    @countyCount.ToString("N0") counties · @cityCount.ToString("N0") cities in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step4Ok ? "step-ok" : (step3Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step4Ok ? "✓" : "4")</span>
            <div class="step-body">
                <strong>Import ZIP code crosswalks</strong>
                <span class="step-desc">
                    Source: US Census Bureau ZCTA relationship files (TXT).
                    @zipCount.ToString("N0") ZIP codes in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step5Ok ? "step-ok" : (step4Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step5Ok ? "✓" : "5")</span>
            <div class="step-body">
                <strong>Assign source URLs to jurisdictions</strong>
                <span class="step-desc">
                    Each state/county needs its official tax rate page URL.
                    @jurisdictionsWithSources.ToString("N0") of @(countyCount + cityCount).ToString("N0") jurisdictions configured.
                    <span class="step-action muted">→ Edit via <a href="/">Jurisdictions</a></span>
                </span>
            </div>
        </li>
        <li class="setup-step @(step6Ok ? "step-ok" : (step5Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step6Ok ? "✓" : "6")</span>
            <div class="step-body">
                <strong>Run initial scrape</strong>
                <span class="step-desc">
                    Collect current tax rates from all configured sources.
                    @scrapeRunCount.ToString("N0") scrape run(s) on record.
                    <span class="step-action muted">→ Use <a href="/discovery">Discovery → ▶ Run Scrape</a></span>
                </span>
            </div>
        </li>
    </ol>
</div>

<!-- ── Run All ─────────────────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Run All Import Steps</h2>
            <p class="setup-card-desc">
                Runs steps 1→4 in sequence: validate URLs, import SST taxonomy, import Census jurisdictions,
                then import ZIP codes. Skips steps that have already completed.
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary" @onclick="RunAllSteps" disabled="@importBusy">
                @(importBusy ? "Running…" : "▶▶ Run All Steps")
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(runAllMsg))
    {
        <div class="setup-status @(runAllMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@runAllMsg</div>
    }
</div>

<!-- ── Step 1: Validate sources ─────────────────────────────────────────────── -->
<div class="setup-card @(step1Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step1Ok ? "num-done" : "num-active")">@(step1Ok ? "✓" : "1")</span>
                Validate Data Source URLs
            </h2>
            <p class="setup-card-desc">
                Confirms every Census and SST URL is reachable before attempting a download.
                Update any broken URLs in <a href="/settings">Settings → Admin</a> first.
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary" @onclick="CheckSources" disabled="@checkingUrls">
                @(checkingUrls ? "Checking…" : "Check Sources")
            </button>
        </div>
    </div>
    @if (urlResults.Count > 0)
    {
        <div class="setup-url-results">
            @foreach (var (label, ok) in urlResults)
            {
                <div class="setup-url-row">
                    <span class="@(ok ? "ds-url-ok" : "ds-url-fail")">@(ok ? "✓" : "✗")</span>
                    <span>@label</span>
                </div>
            }
        </div>
    }
</div>

<!-- ── Step 2: SST Taxonomy ──────────────────────────────────────────────────── -->
<div class="setup-card @(step2Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step2Ok ? "num-done" : (step1Ok ? "num-active" : "num-todo"))">@(step2Ok ? "✓" : "2")</span>
                SST Product/Service Taxonomy
            </h2>
            <p class="setup-card-desc">
                Downloads the SSUTA Agreement PDF, extracts Appendix C defined terms, and builds
                the product/service category tree used to scope tax rates per product type.
                Source: <span class="mono-sm">@TruncateUrl(settings.Current.SstAgreementUrl)</span>
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary" @onclick="RunSstImport" disabled="@(importBusy || !step1Ok)">
                @(sstRunning ? "Importing…" : (step2Ok ? "↺ Re-import" : "▶ Import Taxonomy"))
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(sstMsg))
    {
        <div class="setup-status @(sstMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@sstMsg</div>
    }
</div>

<!-- ── Step 3: Census jurisdictions ─────────────────────────────────────────── -->
<div class="setup-card @(step3Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step3Ok ? "num-done" : (step2Ok ? "num-active" : "num-todo"))">@(step3Ok ? "✓" : "3")</span>
                Census Jurisdictions — Counties &amp; Cities
            </h2>
            <p class="setup-card-desc">
                Downloads the Census Bureau Gazetteer ZIP archives and imports all US counties and
                incorporated cities/places (~3,200 counties · ~30,000 cities). Takes 20–40 minutes.
                Source: Census Bureau Gazetteer 2025.
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary" @onclick="RunCensusImport" disabled="@(importBusy || !step2Ok)">
                @(censusRunning ? "Running…" : (step3Ok ? "↺ Re-import" : "▶ Import Jurisdictions"))
            </button>
            <button class="btn-secondary" @onclick="ClearCensusCache" disabled="@importBusy" style="font-size:.82rem">
                Clear cache
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(importMsg))
    {
        <div class="setup-status @(importMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@importMsg</div>
    }
</div>

<!-- ── Step 4: ZIP codes ─────────────────────────────────────────────────────── -->
<div class="setup-card @(step4Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step4Ok ? "num-done" : (step3Ok ? "num-active" : "num-todo"))">@(step4Ok ? "✓" : "4")</span>
                ZIP Code Crosswalks
            </h2>
            <p class="setup-card-desc">
                Downloads Census ZCTA relationship files and maps ~33,000 ZIP codes to their
                State, County, and City jurisdictions. Requires Step 3. Takes 15–30 minutes.
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!zipRunning)
            {
                <button class="btn-primary" @onclick="RunZipImport" disabled="@(importBusy || !step3Ok)">
                    @(step4Ok ? "↺ Re-import" : "▶ Import ZIP Codes")
                </button>
                <button class="btn-secondary" @onclick="ClearZipCache" disabled="@importBusy" style="font-size:.82rem">Clear cache</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopZipImport">■ Stop</button>
            }
        </div>
    </div>
    @if (!step3Ok)
    {
        <div class="setup-status setup-status-warn">Complete Step 3 first.</div>
    }
    else if (!zipRunning && zipResult == null && !step4Ok)
    {
        <div class="zip-info-card">
            <h3>How ZIP-based tax resolution works</h3>
            <div class="zip-info-grid">
                <div class="zip-info-item">
                    <span class="zip-info-num">1</span>
                    <div><strong>ZIP → State</strong><br/>Every ZIP belongs to exactly one state. The state's general sales tax rate applies.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">2</span>
                    <div><strong>ZIP → County</strong><br/>Each ZIP is assigned its primary county by land-area intersection. County add-on rates apply.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">3</span>
                    <div><strong>ZIP → City</strong><br/>The Census primary place identifies municipal rates.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">4</span>
                    <div><strong>Product Category</strong><br/>Exemptions and reduced rates are applied per category × jurisdiction rule.</div>
                </div>
            </div>
        </div>
    }
    @if (zipRunning || zipResult != null)
    {
        <div class="discovery-progress-wrap" style="margin-top:.75rem">
            @if (zipRunning && zipProgress.Total > 0)
            {
                var pct = (int)Math.Round(zipProgress.Processed * 100.0 / zipProgress.Total);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (zipRunning)
            {
                <div class="progress-bar-indeterminate"></div>
            }
            else
            {
                <div class="discovery-progress-bar" style="width:100%"></div>
            }
        </div>
        <div class="discovery-stats" style="margin-top:.4rem">
            @if (zipRunning)
            {
                <span class="disc-stat disc-stat-total">
                    <strong>@zipProgress.Processed.ToString("N0")</strong> / @(zipProgress.Total > 0 ? zipProgress.Total.ToString("N0") : "…") processed
                </span>
            }
            <span class="disc-stat disc-stat-found"><strong>@zipProgress.Imported.ToString("N0")</strong> imported</span>
            <span class="disc-stat disc-stat-skipped"><strong>@zipProgress.Skipped.ToString("N0")</strong> skipped</span>
            @if (zipProgress.Errors > 0) { <span class="disc-stat disc-stat-error"><strong>@zipProgress.Errors</strong> errors</span> }
            @if (!string.IsNullOrEmpty(zipProgress.CurrentZip)) { <span class="disc-stat muted">@zipProgress.CurrentZip</span> }
            @if (zipResult != null && !zipRunning) { <span class="disc-stat muted">Done in @zipResult.Elapsed.ToString(@"m\:ss")</span> }
        </div>
    }
    @if (zipResult != null && !zipRunning)
    {
        <div class="zip-result-card" style="margin-top:.75rem">
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipResult.Imported.ToString("N0")</div>
                <div class="zip-result-label">imported</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipLinkedCounty.ToString("N0")</div>
                <div class="zip-result-label">linked county</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipLinkedCity.ToString("N0")</div>
                <div class="zip-result-label">linked city</div>
            </div>
        </div>
    }
</div>

@if (zipStateCounts.Count > 0)
{
    <div class="zip-table-wrap" style="margin-top:1rem">
        <table class="data-table">
            <thead>
                <tr>
                    <th>State</th>
                    <th style="text-align:right">ZIP Codes</th>
                    <th style="text-align:right">Linked County</th>
                    <th style="text-align:right">Linked City</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in zipStateCounts.OrderBy(r => r.StateCode))
                {
                    <tr>
                        <td class="mono">@row.StateCode</td>
                        <td class="mono" style="text-align:right">@row.Total.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CountyLinked.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CityLinked.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ── Step 6: Run Scrape ─────────────────────────────────────────────────────── -->
<div class="setup-card @(step6Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step6Ok ? "num-done" : (step5Ok ? "num-active" : "num-todo"))">@(step6Ok ? "✓" : "6")</span>
                Run Initial Scrape
            </h2>
            <p class="setup-card-desc">
                Iterates every active jurisdiction that has a source URL, fetches the current tax rate
                via its registered scrape strategy, and records any changes. Requires source URLs to be
                configured in the Jurisdictions tab (Step 5).
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!scrapeRunning)
            {
                <button class="btn-primary" @onclick="StartScrape" disabled="@(!step5Ok)">▶ Run Scrape</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopScrape">■ Stop</button>
            }
        </div>
    </div>
    @if (scrapeRunning)
    {
        <div class="setup-status setup-status-ok"><span class="pipeline-running-dot"></span> Running…</div>
    }
    @if (scrapeStatus is not null && !scrapeRunning)
    {
        <div class="setup-status @(scrapeStatus.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@scrapeStatus</div>
    }
</div>

<!-- ── Source Discovery (optional) ──────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                Source Discovery
                <span class="phase-badge phase-badge-stub">Stub</span>
            </h2>
            <p class="setup-card-desc">
                Probes every jurisdiction for a tax rate source URL — government API, web page, or PDF.
                Results are logged below but no rates are written. Use the findings to configure source
                URLs in the Jurisdictions tab. <em class="muted">Live probing is planned; currently returns stub results.</em>
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!discoveryRunning)
            {
                <button class="btn-primary" @onclick="StartDiscovery">▶ Run Discovery</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopDiscovery">■ Stop</button>
            }
            @if (discoveryResults.Count > 0 && !discoveryRunning)
            {
                <button class="btn-secondary" @onclick="ClearDiscovery">✕ Clear</button>
            }
        </div>
    </div>
    @if (discoveryRunning || discoveryProcessed > 0)
    {
        <div class="discovery-progress-wrap" style="margin-top:.75rem">
            @if (discoveryRunning && discoveryTotal > 0)
            {
                var pct = (int)Math.Round(discoveryProcessed * 100.0 / discoveryTotal);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (discoveryRunning)
            {
                <div class="progress-bar-indeterminate"></div>
            }
        </div>
        <div class="discovery-stats" style="margin-top:.4rem">
            <span class="disc-stat">
                <strong>@discoveryProcessed</strong> / @(discoveryTotal > 0 ? discoveryTotal.ToString() : "…") processed
            </span>
            <span class="disc-stat disc-stat-found"><strong>@discoveryFound</strong> found</span>
            <span class="disc-stat disc-stat-missing"><strong>@discoveryNotFound</strong> not found</span>
            <span class="disc-stat disc-stat-skipped"><strong>@discoverySkipped</strong> skipped</span>
            @if (discoveryErrors > 0) { <span class="disc-stat disc-stat-error"><strong>@discoveryErrors</strong> errors</span> }
            @if (!discoveryRunning && discoveryProcessed > 0)
            {
                <span class="disc-stat muted">Done @discoveryCompletedAt?.ToString("HH:mm:ss")</span>
            }
        </div>
    }
</div>

@if (discoveryResults.Count > 0)
{
    <div class="disc-filter-bar">
        <div class="log-level-pills">
            @foreach (var f in new[] { "All", "Found", "NotFound", "Skipped", "Error" })
            {
                <button class="log-level-pill disc-filter-pill @(f == "All" ? "disc-pill-all" : $"disc-pill-{f.ToLower()}") @(discoveryFilter == f ? "log-pill-active" : "")"
                        @onclick="() => discoveryFilter = f">@f</button>
            }
        </div>
        <input class="setting-input log-search" placeholder="Search name or state…"
               @bind="discoverySearch" @bind:event="oninput" />
    </div>
    <div class="disc-table-wrap">
        <table class="data-table disc-table">
            <thead>
                <tr>
                    <th>Tier</th><th>State</th><th>Name</th><th>Status</th><th>Source</th><th>Rate</th><th>Notes</th><th>Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in DiscoveryFilteredResults.Take(500))
                {
                    <tr class="disc-row disc-row-@r.Status.ToLower()">
                        <td><span class="tier-badge @TierClass(r.Tier)">@r.Tier</span></td>
                        <td class="mono">@r.StateCode</td>
                        <td>@r.JurisdictionName</td>
                        <td><span class="disc-status-badge disc-status-@r.Status.ToLower()">@r.Status</span></td>
                        <td class="disc-source-cell" title="@r.SourceUsed">@TruncateDiscoveryUrl(r.SourceUsed)</td>
                        <td class="mono">@(r.FoundRate.HasValue ? $"{r.FoundRate.Value * 100:F3}%" : "—")</td>
                        <td class="disc-notes-cell">@r.Notes</td>
                        <td class="mono muted">@r.ProcessedAt.ToString("HH:mm:ss")</td>
                    </tr>
                }
                @if (DiscoveryFilteredResults.Count() > 500)
                {
                    <tr><td colspan="8" class="muted" style="text-align:center;padding:.75rem">Showing first 500 of @DiscoveryFilteredResults.Count() results</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    // ── Counts ────────────────────────────────────────────────────────────────
    private int countyCount, cityCount, zipCount, taxCategoryCount, scrapeRunCount, jurisdictionsWithSources;

    private bool step1Ok => urlResults.Count > 0 && urlResults.All(r => r.Ok);
    private bool step2Ok => taxCategoryCount > 0;
    private bool step3Ok => countyCount > 0 && cityCount > 0;
    private bool step4Ok => zipCount > 0;
    private bool step5Ok => jurisdictionsWithSources > 0;
    private bool step6Ok => scrapeRunCount > 0;

    // ── URL validation ────────────────────────────────────────────────────────
    private bool checkingUrls;
    private List<(string Label, bool Ok)> urlResults = [];

    private Dictionary<string, (string Label, Func<string> Url)> UrlMap => new()
    {
        ["CensusCountyGaz"]     = ("Census County Gazetteer (ZIP)",       () => settings.Current.CensusCountyGazUrl),
        ["CensusPlaceGaz"]      = ("Census Place Gazetteer (ZIP)",         () => settings.Current.CensusPlaceGazUrl),
        ["CensusZctaCounty"]    = ("Census ZCTA→County crosswalk (TXT)",   () => settings.Current.CensusZctaCountyUrl),
        ["CensusZctaPlace"]     = ("Census ZCTA→Place crosswalk (TXT)",    () => settings.Current.CensusZctaPlaceUrl),
        ["SstAgreement"]        = ("SSUTA Agreement PDF (Appendix C)",      () => settings.Current.SstAgreementUrl),
        ["SstTaxabilityMatrix"] = ("SST Taxability Matrix (web)",           () => settings.Current.SstTaxabilityMatrixUrl),
        ["SstMemberStates"]     = ("SST Member States page (web)",          () => settings.Current.SstMemberStatesUrl),
    };

    // ── Import state ──────────────────────────────────────────────────────────
    private bool importBusy;
    private bool censusRunning, zipRunning, sstRunning;
    private string? importMsg;
    private string? sstMsg;
    private string? runAllMsg;

    // ── ZIP rich state ────────────────────────────────────────────────────────
    private CancellationTokenSource? zipCts;
    private ZipImportProgress zipProgress = new(0, 0, 0, 0, 0);
    private ZipImportResult? zipResult;
    private int zipLinkedCounty, zipLinkedCity;
    private record ZipStateRow(string StateCode, int Total, int CountyLinked, int CityLinked);
    private List<ZipStateRow> zipStateCounts = [];

    protected override async Task OnInitializedAsync() => await Refresh();

    private async Task Refresh()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        countyCount              = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.County);
        cityCount                = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.City);
        zipCount                 = await db.ZipCodes.CountAsync();
        taxCategoryCount         = await db.TaxCategories.CountAsync();
        scrapeRunCount           = await db.ScrapeRuns.CountAsync();
        jurisdictionsWithSources = await db.Jurisdictions.CountAsync(
            j => j.SourceUrl != null && j.SourceUrl != "" && j.JurisdictionType != JurisdictionType.Country);

        if (zipCount > 0 && zipStateCounts.Count == 0)
            await LoadZipStateCountsAsync();
    }

    // ── URL check ────────────────────────────────────────────────────────────

    private async Task CheckSources()
    {
        checkingUrls = true;
        urlResults = [];
        StateHasChanged();

        using var http = HttpClientFactory.CreateClient();
        http.Timeout = TimeSpan.FromSeconds(10);

        var tasks = UrlMap.Select(async kv =>
        {
            var (label, urlFn) = kv.Value;
            var url = urlFn();
            if (string.IsNullOrWhiteSpace(url)) return (label, false);
            try
            {
                using var req = new HttpRequestMessage(HttpMethod.Head, url);
                using var resp = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);
                return (label, resp.IsSuccessStatusCode || (int)resp.StatusCode < 400);
            }
            catch { return (label, false); }
        });

        var results = await Task.WhenAll(tasks);
        urlResults = results.Select(r => (r.Item1, r.Item2)).ToList();
        checkingUrls = false;
        StateHasChanged();
    }

    // ── SST import ───────────────────────────────────────────────────────────

    private async Task RunSstImport()
    {
        importBusy = sstRunning = true;
        sstMsg = "Starting…";
        StateHasChanged();
        try
        {
            var p = new Progress<string>(msg => { sstMsg = msg; InvokeAsync(StateHasChanged); });
            var r = await sstSvc.ImportAsync(p);
            sstMsg = r.Success
                ? $"✓ {r.CategoriesCreated} categories imported in {r.Elapsed:m\\:ss}"
                : $"✗ {r.Error}";
            await Refresh();
        }
        catch (Exception ex) { sstMsg = $"✗ {ex.Message}"; }
        finally { importBusy = sstRunning = false; StateHasChanged(); }
    }

    // ── Census import ────────────────────────────────────────────────────────

    private async Task RunCensusImport()
    {
        importBusy = censusRunning = true;
        importMsg = "Importing counties & cities…";
        StateHasChanged();
        try
        {
            var p = new Progress<CensusImportProgress>(snap =>
            {
                importMsg = $"{snap.Stage}: {snap.Created:N0} created";
                InvokeAsync(StateHasChanged);
            });
            var r = await censusSvc.ImportAsync(p);
            importMsg = $"✓ {r.CountiesCreated:N0} counties · {r.CitiesCreated:N0} cities created in {r.Elapsed:m\\:ss}";
            await Refresh();
        }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { importBusy = censusRunning = false; StateHasChanged(); }
    }

    // ── ZIP import ───────────────────────────────────────────────────────────

    private async Task RunZipImport()
    {
        importBusy = zipRunning = true;
        zipResult = null;
        zipProgress = new(0, 0, 0, 0, 0);
        zipCts = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            var p = new Progress<ZipImportProgress>(snap =>
            {
                zipProgress = snap;
                InvokeAsync(StateHasChanged);
            });
            zipResult = await zipSvc.ImportAsync(p, zipCts.Token);
            await LoadZipLinkStatsAsync();
            await Refresh();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { importBusy = zipRunning = false; zipCts = null; StateHasChanged(); }
    }

    private void StopZipImport() => zipCts?.Cancel();

    private async Task LoadZipLinkStatsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        zipLinkedCounty = await db.ZipCodes.CountAsync(z => z.CountyJurisdictionId != null);
        zipLinkedCity   = await db.ZipCodes.CountAsync(z => z.CityJurisdictionId   != null);
    }

    private async Task LoadZipStateCountsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        zipStateCounts = await db.ZipCodes
            .GroupBy(z => z.StateCode)
            .Select(g => new ZipStateRow(
                g.Key,
                g.Count(),
                g.Count(z => z.CountyJurisdictionId != null),
                g.Count(z => z.CityJurisdictionId   != null)))
            .ToListAsync();
    }

    // ── Run All ──────────────────────────────────────────────────────────────

    private async Task RunAllSteps()
    {
        importBusy = true;
        runAllMsg = "Step 1/4 — Checking URLs…";
        StateHasChanged();

        try
        {
            await CheckSources();
            if (!step1Ok) { runAllMsg = "✗ URL check failed — fix URLs in Settings first."; return; }

            if (!step2Ok)
            {
                runAllMsg = "Step 2/4 — Importing SST taxonomy…";
                StateHasChanged();
                await RunSstImport();
                if (sstMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ SST step failed: {sstMsg}"; return; }
            }

            if (!step3Ok)
            {
                runAllMsg = "Step 3/4 — Importing Census jurisdictions…";
                StateHasChanged();
                await RunCensusImport();
                if (importMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ Census step failed: {importMsg}"; return; }
            }

            if (!step4Ok)
            {
                runAllMsg = "Step 4/4 — Importing ZIP codes…";
                StateHasChanged();
                await RunZipImport();
                if (importMsg?.StartsWith("✗") == true) { runAllMsg = $"✗ ZIP step failed: {importMsg}"; return; }
            }

            runAllMsg = "✓ All steps complete.";
        }
        catch (Exception ex) { runAllMsg = $"✗ {ex.Message}"; }
        finally { importBusy = false; StateHasChanged(); }
    }

    private void ClearCensusCache() { censusSvc.ClearCache(); importMsg = "Census cache cleared."; StateHasChanged(); }
    private void ClearZipCache()    { zipSvc.ClearCache();    importMsg = "ZIP cache cleared.";    StateHasChanged(); }

    private static string TruncateUrl(string url) =>
        url.Length <= 55 ? url : url[..52] + "…";

    // ── Scrape state ──────────────────────────────────────────────────────────
    private bool scrapeRunning;
    private CancellationTokenSource? scrapeCts;
    private string? scrapeStatus;

    private async Task StartScrape()
    {
        scrapeRunning = true;
        scrapeStatus  = null;
        scrapeCts     = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            var changed = await Orchestrator.RunFullScrapeAsync(scrapeCts.Token);
            scrapeStatus = $"✓ Done — {changed} change(s) detected";
            await Refresh();
        }
        catch (OperationCanceledException) { scrapeStatus = "Stopped."; }
        catch (Exception ex) { scrapeStatus = $"✗ {ex.Message}"; }
        finally { scrapeRunning = false; StateHasChanged(); }
    }

    private void StopScrape() => scrapeCts?.Cancel();

    // ── Discovery state ───────────────────────────────────────────────────────
    private bool discoveryRunning;
    private CancellationTokenSource? discoveryCts;
    private int discoveryTotal, discoveryProcessed, discoveryFound, discoveryNotFound, discoverySkipped, discoveryErrors;
    private DateTime? discoveryCompletedAt;
    private string discoveryFilter = "All";
    private string discoverySearch = "";
    private readonly List<DiscoveryResult> discoveryResults = new();

    private IEnumerable<DiscoveryResult> DiscoveryFilteredResults =>
        discoveryResults
            .Where(r => discoveryFilter == "All" || r.Status == discoveryFilter)
            .Where(r => string.IsNullOrEmpty(discoverySearch) ||
                        r.JurisdictionName.Contains(discoverySearch, StringComparison.OrdinalIgnoreCase) ||
                        r.StateCode.Contains(discoverySearch, StringComparison.OrdinalIgnoreCase));

    private async Task StartDiscovery()
    {
        discoveryRunning     = true;
        discoveryCts         = new CancellationTokenSource();
        discoveryTotal       = 0; discoveryProcessed = 0;
        discoveryFound       = 0; discoveryNotFound  = 0;
        discoverySkipped     = 0; discoveryErrors    = 0;
        discoveryCompletedAt = null;
        discoveryResults.Clear();
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            discoveryTotal = await db.Jurisdictions
                .CountAsync(j => j.IsActive && j.JurisdictionType != JurisdictionType.Country, discoveryCts.Token);
            await InvokeAsync(StateHasChanged);

            var countries = await db.Jurisdictions
                .Where(j => j.JurisdictionType == JurisdictionType.Country && j.IsActive)
                .OrderBy(j => j.JurisdictionName)
                .ToListAsync(discoveryCts.Token);

            foreach (var country in countries)
                await DiscoverRecursiveAsync(country, db, discoveryCts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            discoveryResults.Insert(0, new DiscoveryResult
            { JurisdictionName = "Discovery run", Status = "Error", Notes = ex.Message, ProcessedAt = DateTime.UtcNow });
        }
        finally { discoveryRunning = false; discoveryCompletedAt = DateTime.UtcNow; await InvokeAsync(StateHasChanged); }
    }

    private async Task DiscoverRecursiveAsync(Jurisdiction jurisdiction, AppDbContext db, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();
        if (jurisdiction.JurisdictionType != JurisdictionType.Country)
        {
            DiscoveryResult result;
            try { result = await DiscoveryService.DiscoverAsync(jurisdiction, ct); }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex)
            {
                result = new DiscoveryResult
                {
                    JurisdictionId = jurisdiction.Id, JurisdictionName = jurisdiction.JurisdictionName,
                    StateCode = jurisdiction.StateCode, Tier = jurisdiction.JurisdictionType,
                    Status = "Error", Notes = ex.Message, ProcessedAt = DateTime.UtcNow,
                };
            }
            discoveryResults.Insert(0, result);
            discoveryProcessed++;
            switch (result.Status)
            {
                case "Found":    discoveryFound++;    break;
                case "NotFound": discoveryNotFound++; break;
                case "Skipped":  discoverySkipped++;  break;
                case "Error":    discoveryErrors++;   break;
            }
            if (discoveryProcessed % 10 == 0 || result.Status is "Error" or "Found")
                await InvokeAsync(StateHasChanged);
        }
        var children = await db.Jurisdictions
            .Where(j => j.ParentId == jurisdiction.Id && j.IsActive)
            .OrderBy(j => j.JurisdictionName)
            .ToListAsync(ct);
        foreach (var child in children)
            await DiscoverRecursiveAsync(child, db, ct);
    }

    private void StopDiscovery() => discoveryCts?.Cancel();

    private void ClearDiscovery()
    {
        discoveryResults.Clear();
        discoveryTotal = discoveryProcessed = discoveryFound = discoveryNotFound = discoverySkipped = discoveryErrors = 0;
        discoveryCompletedAt = null;
    }

    private static string TierClass(JurisdictionType tier) => tier switch
    {
        JurisdictionType.State  => "tier-state",
        JurisdictionType.County => "tier-county",
        JurisdictionType.City   => "tier-city",
        _                       => "tier-country"
    };

    private static string TruncateDiscoveryUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url == "—") return url;
        return url.Length <= 40 ? url : url[..37] + "…";
    }
