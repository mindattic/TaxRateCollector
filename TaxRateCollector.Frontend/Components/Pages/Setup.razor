@page "/setup"
@attribute [Authorize(Roles = "Administrator")]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ICensusJurisdictionImportService censusSvc
@inject IZipImportService zipSvc
@inject ISstTaxonomyImportService sstSvc
@inject IDiscoveryService DiscoveryService
@inject ScrapeJobCoordinator ScrapeCoordinator
@inject SettingsService settings
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject IConfiguration Configuration
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Setup — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Setup</h1>
    <p class="page-sub">
        One-time data population. Complete these steps in order to fill the database
        from authoritative external sources before running the scrape pipeline.
    </p>
</div>

<!-- ── Phase guide ──────────────────────────────────────────────────────────── -->
<div class="setup-card" style="border-style:dashed">
    <p style="margin:0;font-weight:600">Complete the three phases in order:</p>
    <ol style="margin:.5rem 0 0 1.1rem;padding:0;line-height:1.9">
        <li><strong>Phase 1 — Configure</strong> Set the source URLs and scraping preferences the import pipeline needs. Do this once before running any imports.</li>
        <li><strong>Phase 2 — Import Pipeline (Steps 1–6)</strong> Populate the database from authoritative external sources. Steps are sequential and each unlocks the next.</li>
        <li><strong>Phase 3 — Business Configuration</strong> Set subscription pricing and PayPal credentials. Do this before opening subscriptions to customers.</li>
    </ol>
</div>

<!-- ── Phase 1: Configure ────────────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 1 — Configure Source URLs &amp; Preferences</div>

@{ var failedUrlCount = urlResults.Values.Count(v => !v); }
@if (urlResults.Count > 0 && failedUrlCount > 0)
{
    <div class="ds-alert ds-alert-error">
        <strong>@failedUrlCount source(s) unreachable</strong> — update the broken URLs below and save before importing.
    </div>
}
else if (urlResults.Count > 0)
{
    <div class="ds-alert ds-alert-ok">All @urlResults.Count data sources reachable.</div>
}
else
{
    <div class="ds-alert ds-alert-warn">Data sources not yet validated — use the <em>Check Sources</em> button in the Data Source URLs card below.</div>
}

<!-- ── Data Source URLs card ─────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Data Source URLs</h2>
            <p class="setup-card-desc">
                These point to the files the import pipeline downloads. They default to the current 2025 Census Bureau
                files and the latest SSUTA Agreement PDF. Update them if the Census Bureau publishes a new year or
                the SST Governing Board publishes a new amendment. Clear the cache after updating to force a fresh download.
            </p>
        </div>
    </div>
    <div class="setup-url-config">
        <div class="setup-url-group-label">Census Bureau — free, no API key required</div>
        <div class="setup-url-field">
            <label class="setting-label">County Gazetteer (ZIP) — ~3,200 US counties with FIPS codes</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusCountyGazUrl" />
                @if (urlResults.TryGetValue("CensusCountyGaz", out var r1)) { <span class="@(r1 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r1 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">Place Gazetteer (ZIP) — ~30,000 incorporated cities and places</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusPlaceGazUrl" />
                @if (urlResults.TryGetValue("CensusPlaceGaz", out var r2)) { <span class="@(r2 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r2 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">ZCTA → County crosswalk (TXT) — maps ZIP codes to counties by land-area</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusZctaCountyUrl" />
                @if (urlResults.TryGetValue("CensusZctaCounty", out var r3)) { <span class="@(r3 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r3 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">ZCTA → Place crosswalk (TXT) — maps ZIP codes to cities by land-area</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusZctaPlaceUrl" />
                @if (urlResults.TryGetValue("CensusZctaPlace", out var r4)) { <span class="@(r4 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r4 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-group-label">Streamlined Sales Tax Governing Board</div>
        <div class="setup-url-field">
            <label class="setting-label">SSUTA Agreement PDF — Appendix C is the authoritative product/service taxonomy source</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstAgreementUrl" />
                @if (urlResults.TryGetValue("SstAgreement", out var r5)) { <span class="@(r5 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r5 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">SST Taxability Matrix (web)</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstTaxabilityMatrixUrl" />
                @if (urlResults.TryGetValue("SstTaxabilityMatrix", out var r6)) { <span class="@(r6 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r6 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">SST Member States &amp; News (web)</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstMemberStatesUrl" />
                @if (urlResults.TryGetValue("SstMemberStates", out var r7)) { <span class="@(r7 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r7 ? "✓" : "✗")</span> }
            </div>
        </div>
    </div>
    <div class="settings-actions" style="margin-top:1rem;gap:.6rem;justify-content:flex-end">
        <button class="btn-secondary" @onclick="CheckSources" disabled="@checkingUrls">
            @(checkingUrls ? "Checking…" : "Check Sources")
        </button>
        <button class="btn-primary" @onclick="SaveConfig" disabled="@(configBusy || !step1Ok)">Save URLs</button>
        @if (!string.IsNullOrEmpty(configMsg)) { <span class="save-confirm">@configMsg</span> }
    </div>
    @if (checkingUrls || urlResults.Count > 0)
    {
        <div class="url-check-results">
            @foreach (var kv in UrlMap)
            {
                @if (checkingUrls && !urlResults.ContainsKey(kv.Key))
                {
                    <div class="url-check-row url-check-pending">
                        <span class="url-check-spinner"></span>
                        <span class="url-check-label">@kv.Value.Label</span>
                    </div>
                }
                else if (urlResults.TryGetValue(kv.Key, out var ok))
                {
                    <div class="url-check-row @(ok ? "url-check-ok-row" : "url-check-fail-row")">
                        <span class="url-check-icon">@(ok ? "✓" : "✗")</span>
                        <span class="url-check-label">@kv.Value.Label</span>
                    </div>
                }
            }
        </div>
    }
</div>

<!-- ── Scraping Preferences card ──────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Scraping Preferences</h2>
            <p class="setup-card-desc">
                Controls how the scrape pipeline behaves. The USPS key is optional — it enriches ZIP code city names
                via the USPS CityStateLookup API. Without it, city names come directly from the Census Bureau.
            </p>
        </div>
    </div>
    <div class="setting-row">
        <label class="setting-label">USPS API Key <span class="muted">(optional)</span></label>
        <input class="setting-input" type="password" placeholder="USPS Web Tools API key" @bind="settings.Current.UspsApiKey" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Re-scrape interval (days)</label>
        <input class="setting-input setting-input-sm" type="number" min="1" max="365" @bind="settings.Current.DefaultUpdateFrequencyDays" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Auto-fetch evidence PDFs when scraping</label>
        <input type="checkbox" @bind="settings.Current.EvidenceAutoFetch" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Use Wayback Machine if source URL returns 404</label>
        <input type="checkbox" @bind="settings.Current.WaybackMachineFallback" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">
            Full-page capture for HTML evidence
            <span class="setting-hint">Off: HTML only (fast). On: bundles CSS/images/scripts into a zip.</span>
        </label>
        <input type="checkbox" @bind="settings.Current.FullPageCapture" />
    </div>
    <div class="settings-actions" style="margin-top:.75rem;gap:.6rem">
        <button class="btn-primary" @onclick="SaveConfig" disabled="@configBusy">Save Preferences</button>
        @if (!string.IsNullOrEmpty(configMsg)) { <span class="save-confirm">@configMsg</span> }
    </div>
</div>

<!-- ── Phase 2: Import Pipeline ──────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 2 — Import Pipeline</div>

<!-- ── Checklist ────────────────────────────────────────────────────────────── -->
<div class="setup-checklist">
    <div class="setup-checklist-header">
        <h2 class="setup-checklist-title">Progress</h2>
        <p class="setup-checklist-sub">Each step unlocks the next. All data is sourced from official external authorities.</p>
    </div>
    <ol class="setup-steps">
        <li class="setup-step @(step1Ok ? "step-ok" : "step-active")">
            <span class="step-icon">@(step1Ok ? "✓" : "1")</span>
            <div class="step-body">
                <strong>Validate data source URLs</strong>
                <span class="step-desc">
                    All Census and SST URLs must be reachable before importing.
                    Configure source URLs in the Phase 1 cards above.
                    @if (!step1Ok) { <span class="step-action">→ Use the <em>Check Sources</em> button in the Data Source URLs card above</span> }
                </span>
            </div>
        </li>
        <li class="setup-step @(step2Ok ? "step-ok" : (step1Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step2Ok ? "✓" : "2")</span>
            <div class="step-body">
                <strong>Import SST product/service taxonomy</strong>
                <span class="step-desc">
                    Source: SSUTA Agreement PDF, Appendix C — SST Governing Board.
                    @taxCategoryCount.ToString("N0") categories in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step3Ok ? "step-ok" : (step2Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step3Ok ? "✓" : "3")</span>
            <div class="step-body">
                <strong>Import Census jurisdictions — counties &amp; cities</strong>
                <span class="step-desc">
                    Source: US Census Bureau Gazetteer files (ZIP archives).
                    @countyCount.ToString("N0") counties · @cityCount.ToString("N0") cities in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step4Ok ? "step-ok" : (step3Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step4Ok ? "✓" : "4")</span>
            <div class="step-body">
                <strong>Import ZIP code crosswalks</strong>
                <span class="step-desc">
                    Source: US Census Bureau ZCTA relationship files (TXT).
                    @zipCount.ToString("N0") ZIP codes in DB.
                </span>
            </div>
        </li>
        <li class="setup-step @(step5Ok ? "step-ok" : (step4Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step5Ok ? "✓" : "5")</span>
            <div class="step-body">
                <strong>Assign source URLs to jurisdictions</strong>
                <span class="step-desc">
                    Each state/county needs its official tax rate page URL.
                    @jurisdictionsWithSources.ToString("N0") of @(countyCount + cityCount).ToString("N0") jurisdictions configured.
                    <span class="step-action muted">→ Edit via <a href="/">Jurisdictions</a></span>
                </span>
            </div>
        </li>
        <li class="setup-step @(step6Ok ? "step-ok" : (step5Ok ? "step-active" : "step-todo"))">
            <span class="step-icon">@(step6Ok ? "✓" : "6")</span>
            <div class="step-body">
                <strong>Run initial scrape</strong>
                <span class="step-desc">
                    Collect current tax rates from all configured sources.
                    @scrapeRunCount.ToString("N0") scrape run(s) on record.
                    <span class="step-action muted">→ Use <a href="/discovery">Discovery → ▶ Run Scrape</a></span>
                </span>
            </div>
        </li>
    </ol>
</div>

<!-- ── Run All ─────────────────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Run All Import Steps</h2>
            <p class="setup-card-desc">
                Runs steps 1→4 in sequence: validate URLs, import SST taxonomy, import Census jurisdictions,
                then import ZIP codes. Skips steps that have already completed.
            </p>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(runAllMsg))
    {
        <div class="setup-status @(runAllMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@runAllMsg</div>
    }
    <div class="settings-actions">
        <button class="btn-primary" @onclick="RunAllSteps" disabled="@importBusy">
            @(importBusy ? "Running…" : "▶▶ Run All Steps")
        </button>
    </div>
</div>

<!-- ── Step 2: SST Taxonomy ──────────────────────────────────────────────────── -->
<div class="setup-card @(step2Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step2Ok ? "num-done" : (step1Ok ? "num-active" : "num-todo"))">@(step2Ok ? "✓" : "2")</span>
                SST Product/Service Taxonomy
            </h2>
            <p class="setup-card-desc">
                Downloads the SSUTA Agreement PDF, extracts Appendix C defined terms, and builds
                the product/service category tree used to scope tax rates per product type.
                Source: <span class="mono-sm">@TruncateUrl(settings.Current.SstAgreementUrl)</span>
            </p>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(sstMsg))
    {
        <div class="setup-status @(sstMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@sstMsg</div>
    }
    <div class="settings-actions">
        <button class="btn-primary" @onclick="RunSstImport" disabled="@(importBusy || !step1Ok)">
            @(sstRunning ? "Importing…" : (step2Ok ? "↺ Re-import" : "▶ Import Taxonomy"))
        </button>
    </div>
</div>

<!-- ── Step 3: Census jurisdictions ─────────────────────────────────────────── -->
<div class="setup-card @(step3Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step3Ok ? "num-done" : (step2Ok ? "num-active" : "num-todo"))">@(step3Ok ? "✓" : "3")</span>
                Census Jurisdictions — Counties &amp; Cities
            </h2>
            <p class="setup-card-desc">
                Downloads the Census Bureau Gazetteer ZIP archives and imports all US counties and
                incorporated cities/places (~3,200 counties · ~30,000 cities). Takes 20–40 minutes.
                Source: Census Bureau Gazetteer 2025.
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary" @onclick="RunCensusImport" disabled="@(importBusy || !step2Ok)">
                @(censusRunning ? "Running…" : (step3Ok ? "↺ Re-import" : "▶ Import Jurisdictions"))
            </button>
            <button class="btn-secondary" @onclick="ClearCensusCache" disabled="@importBusy" style="font-size:.82rem">
                Clear cache
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(importMsg))
    {
        <div class="setup-status @(importMsg.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@importMsg</div>
    }
</div>

<!-- ── Step 4: ZIP codes ─────────────────────────────────────────────────────── -->
<div class="setup-card @(step4Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step4Ok ? "num-done" : (step3Ok ? "num-active" : "num-todo"))">@(step4Ok ? "✓" : "4")</span>
                ZIP Code Crosswalks
            </h2>
            <p class="setup-card-desc">
                Downloads Census ZCTA relationship files and maps ~33,000 ZIP codes to their
                State, County, and City jurisdictions. Requires Step 3. Takes 15–30 minutes.
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!zipRunning)
            {
                <button class="btn-primary" @onclick="RunZipImport" disabled="@(importBusy || !step3Ok)">
                    @(step4Ok ? "↺ Re-import" : "▶ Import ZIP Codes")
                </button>
                <button class="btn-secondary" @onclick="ClearZipCache" disabled="@importBusy" style="font-size:.82rem">Clear cache</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopZipImport">■ Stop</button>
            }
        </div>
    </div>
    @if (!step3Ok)
    {
        <div class="setup-status setup-status-warn">Complete Step 3 first.</div>
    }
    else if (!zipRunning && zipResult == null && !step4Ok)
    {
        <div class="zip-info-card">
            <h3>How ZIP-based tax resolution works</h3>
            <div class="zip-info-grid">
                <div class="zip-info-item">
                    <span class="zip-info-num">1</span>
                    <div><strong>ZIP → State</strong><br/>Every ZIP belongs to exactly one state. The state's general sales tax rate applies.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">2</span>
                    <div><strong>ZIP → County</strong><br/>Each ZIP is assigned its primary county by land-area intersection. County add-on rates apply.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">3</span>
                    <div><strong>ZIP → City</strong><br/>The Census primary place identifies municipal rates.</div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">4</span>
                    <div><strong>Product Category</strong><br/>Exemptions and reduced rates are applied per category × jurisdiction rule.</div>
                </div>
            </div>
        </div>
    }
    @if (zipRunning || zipResult != null)
    {
        <div class="discovery-progress-wrap" style="margin-top:.75rem">
            @if (zipRunning && zipProgress.Total > 0)
            {
                var pct = (int)Math.Round(zipProgress.Processed * 100.0 / zipProgress.Total);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (zipRunning)
            {
                <div class="progress-bar-indeterminate"></div>
            }
            else
            {
                <div class="discovery-progress-bar" style="width:100%"></div>
            }
        </div>
        <div class="discovery-stats" style="margin-top:.4rem">
            @if (zipRunning)
            {
                <span class="disc-stat disc-stat-total">
                    <strong>@zipProgress.Processed.ToString("N0")</strong> / @(zipProgress.Total > 0 ? zipProgress.Total.ToString("N0") : "…") processed
                </span>
            }
            <span class="disc-stat disc-stat-found"><strong>@zipProgress.Imported.ToString("N0")</strong> imported</span>
            <span class="disc-stat disc-stat-skipped"><strong>@zipProgress.Skipped.ToString("N0")</strong> skipped</span>
            @if (zipProgress.Errors > 0) { <span class="disc-stat disc-stat-error"><strong>@zipProgress.Errors</strong> errors</span> }
            @if (!string.IsNullOrEmpty(zipProgress.CurrentZip)) { <span class="disc-stat muted">@zipProgress.CurrentZip</span> }
            @if (zipResult != null && !zipRunning) { <span class="disc-stat muted">Done in @zipResult.Elapsed.ToString(@"m\:ss")</span> }
        </div>
    }
    @if (zipResult != null && !zipRunning)
    {
        <div class="zip-result-card" style="margin-top:.75rem">
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipResult.Imported.ToString("N0")</div>
                <div class="zip-result-label">imported</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipLinkedCounty.ToString("N0")</div>
                <div class="zip-result-label">linked county</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@zipLinkedCity.ToString("N0")</div>
                <div class="zip-result-label">linked city</div>
            </div>
        </div>
    }
</div>

@if (zipStateCounts.Count > 0)
{
    <div class="zip-table-wrap" style="margin-top:1rem">
        <table class="data-table">
            <thead>
                <tr>
                    <th>State</th>
                    <th style="text-align:right">ZIP Codes</th>
                    <th style="text-align:right">Linked County</th>
                    <th style="text-align:right">Linked City</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in zipStateCounts.OrderBy(r => r.StateCode))
                {
                    <tr>
                        <td class="mono">@row.StateCode</td>
                        <td class="mono" style="text-align:right">@row.Total.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CountyLinked.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CityLinked.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ── Step 6: Run Scrape ─────────────────────────────────────────────────────── -->
<div class="setup-card @(step6Ok ? "setup-card-done" : "")">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                <span class="setup-step-num @(step6Ok ? "num-done" : (step5Ok ? "num-active" : "num-todo"))">@(step6Ok ? "✓" : "6")</span>
                Run Initial Scrape
            </h2>
            <p class="setup-card-desc">
                Iterates every active jurisdiction that has a source URL, fetches the current tax rate
                via its registered scrape strategy, and records any changes. Requires source URLs to be
                configured in the Jurisdictions tab (Step 5).
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!ScrapeCoordinator.IsRunning)
            {
                <button class="btn-primary" @onclick="StartScrape" disabled="@(!step5Ok)">▶ Run Scrape</button>
                @if (pausedScrapeRunId.HasValue)
                {
                    <button class="btn-secondary" @onclick="ResumeScrape">↩ Resume</button>
                }
            }
            else
            {
                <button class="btn-secondary" @onclick="() => ScrapeCoordinator.RequestPause()">⏸ Pause</button>
            }
        </div>
    </div>
    @if (activeScrapeRun is not null)
    {
        var pct = activeScrapeRun.TotalCount > 0
            ? (int)(100.0 * activeScrapeRun.ProcessedCount / activeScrapeRun.TotalCount)
            : 0;
        <div class="scrape-progress-wrap">
            <div class="scrape-progress-bar" style="width:@(pct)%"></div>
        </div>
        <div class="setup-status setup-status-ok">
            <span class="pipeline-running-dot"></span>
            @activeScrapeRun.ProcessedCount.ToString("N0") / @activeScrapeRun.TotalCount.ToString("N0") jurisdictions (@pct%)
        </div>
    }
    @if (pausedScrapeRunId.HasValue && !ScrapeCoordinator.IsRunning)
    {
        <div class="setup-status setup-status-warn">⏸ Paused — run #@pausedScrapeRunId can be resumed.</div>
    }
    @if (scrapeStatus is not null && !ScrapeCoordinator.IsRunning)
    {
        <div class="setup-status @(scrapeStatus.StartsWith("✗") ? "setup-status-error" : "setup-status-ok")">@scrapeStatus</div>
    }
</div>

<!-- ── Source Discovery (optional) ──────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">
                Source Discovery
                <span class="phase-badge phase-badge-stub">Stub</span>
            </h2>
            <p class="setup-card-desc">
                Probes every jurisdiction for a tax rate source URL — government API, web page, or PDF.
                Results are logged below but no rates are written. Use the findings to configure source
                URLs in the Jurisdictions tab. <em class="muted">Live probing is planned; currently returns stub results.</em>
            </p>
        </div>
        <div class="setup-card-actions">
            @if (!discoveryRunning)
            {
                <button class="btn-primary" @onclick="StartDiscovery">▶ Run Discovery</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopDiscovery">■ Stop</button>
            }
            @if (discoveryResults.Count > 0 && !discoveryRunning)
            {
                <button class="btn-secondary" @onclick="ClearDiscovery">✕ Clear</button>
            }
        </div>
    </div>
    @if (discoveryRunning || discoveryProcessed > 0)
    {
        <div class="discovery-progress-wrap" style="margin-top:.75rem">
            @if (discoveryRunning && discoveryTotal > 0)
            {
                var pct = (int)Math.Round(discoveryProcessed * 100.0 / discoveryTotal);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (discoveryRunning)
            {
                <div class="progress-bar-indeterminate"></div>
            }
        </div>
        <div class="discovery-stats" style="margin-top:.4rem">
            <span class="disc-stat">
                <strong>@discoveryProcessed</strong> / @(discoveryTotal > 0 ? discoveryTotal.ToString() : "…") processed
            </span>
            <span class="disc-stat disc-stat-found"><strong>@discoveryFound</strong> found</span>
            <span class="disc-stat disc-stat-missing"><strong>@discoveryNotFound</strong> not found</span>
            <span class="disc-stat disc-stat-skipped"><strong>@discoverySkipped</strong> skipped</span>
            @if (discoveryErrors > 0) { <span class="disc-stat disc-stat-error"><strong>@discoveryErrors</strong> errors</span> }
            @if (!discoveryRunning && discoveryProcessed > 0)
            {
                <span class="disc-stat muted">Done @discoveryCompletedAt?.ToString("HH:mm:ss")</span>
            }
        </div>
    }
</div>

@if (discoveryResults.Count > 0)
{
    <div class="disc-filter-bar">
        <div class="log-level-pills">
            @foreach (var f in new[] { "All", "Found", "NotFound", "Skipped", "Error" })
            {
                <button class="@(discoveryFilter == f ? "btn-primary" : "btn-secondary")"
                        @onclick="() => discoveryFilter = f">@f</button>
            }
        </div>
        <input class="setting-input log-search" placeholder="Search name or state…"
               @bind="discoverySearch" @bind:event="oninput" />
    </div>
    <div class="disc-table-wrap">
        <table class="data-table disc-table">
            <thead>
                <tr>
                    <th>Tier</th><th>State</th><th>Name</th><th>Status</th><th>Source</th><th>Rate</th><th>Notes</th><th>Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in DiscoveryFilteredResults.Take(500))
                {
                    <tr class="disc-row disc-row-@r.Status.ToLower()">
                        <td><span class="tier-badge @TierClass(r.Tier)">@r.Tier</span></td>
                        <td class="mono">@r.StateCode</td>
                        <td>@r.JurisdictionName</td>
                        <td><span class="disc-status-badge disc-status-@r.Status.ToLower()">@r.Status</span></td>
                        <td class="disc-source-cell" title="@r.SourceUsed">@TruncateDiscoveryUrl(r.SourceUsed)</td>
                        <td class="mono">@(r.FoundRate.HasValue ? $"{r.FoundRate.Value * 100:F3}%" : "—")</td>
                        <td class="disc-notes-cell">@r.Notes</td>
                        <td class="mono muted">@r.ProcessedAt.ToString("HH:mm:ss")</td>
                    </tr>
                }
                @if (DiscoveryFilteredResults.Count() > 500)
                {
                    <tr><td colspan="8" class="muted" style="text-align:center;padding:.75rem">Showing first 500 of @DiscoveryFilteredResults.Count() results</td></tr>
                }
            </tbody>
        </table>
    </div>
}

