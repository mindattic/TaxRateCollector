@page "/setup"
@attribute [Authorize(Roles = "Administrator")]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@using TaxRateCollector.Infrastructure.Seeding
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ICensusJurisdictionImportService censusSvc
@inject IZipImportService zipSvc
@inject ISstTaxonomyImportService sstSvc
@inject SettingsService settings
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject IConfiguration Configuration
@rendermode InteractiveServer
<PageTitle>Setup — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Setup</h1>
    <p class="page-sub">
        One-time data population. Complete these steps in order to fill the database
        from authoritative external sources before running the scrape pipeline.
    </p>
</div>

<!-- ── Phase guide ──────────────────────────────────────────────────────────── -->
<div class="setup-card" style="border-style:dashed">
    <p style="margin:0;font-weight:600">Complete the four phases in order:</p>
    <ol style="margin:.5rem 0 0 1.1rem;padding:0;line-height:1.9">
        <li><strong>Phase 1 — Configuration</strong> Set the source URLs and scraping preferences the import pipeline needs. Do this once before running any imports.</li>
        <li><strong>Phase 2 — Schema</strong> Populate the database from authoritative external sources — SST taxonomy, Census jurisdictions, and ZIP crosswalks.</li>
        <li><strong>Phase 3 — Scraping</strong> <em class="muted">(Coming soon)</em> Automatically discover and scrape current tax rates for every jurisdiction.</li>
        <li><strong>Phase 4 — Business</strong> Set subscription pricing and PayPal credentials. Do this before opening subscriptions to customers.</li>
    </ol>
</div>

<!-- ── Phase 1: Configuration ─────────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 1 — Configuration</div>

@{ var failedUrlCount = urlResults.Values.Count(v => !v); }
@if (urlResults.Count > 0 && failedUrlCount > 0)
{
    <div class="ds-alert ds-alert-error">
        <strong>@failedUrlCount source(s) unreachable</strong> — update the broken URLs below and save before importing.
    </div>
}
else if (urlResults.Count > 0)
{
    <div class="ds-alert ds-alert-ok">All @urlResults.Count data sources reachable.</div>
}
else
{
    <div class="ds-alert ds-alert-warn">Data sources not yet validated — use the <em>Check Sources</em> button in the Data Source URLs card below.</div>
}

<!-- ── Data Source URLs card ─────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Data Source URLs</h2>
            <p class="setup-card-desc">
                These point to the files the import pipeline downloads. They default to the current 2025 Census Bureau
                files and the latest SSUTA Agreement PDF. Update them if the Census Bureau publishes a new year or
                the SST Governing Board publishes a new amendment. Clear the cache after updating to force a fresh download.
            </p>
        </div>
    </div>
    <div class="setup-url-config">
        <div class="setup-url-group-label">Census Bureau — free, no API key required</div>
        <div class="setup-url-field">
            <label class="setting-label">County Gazetteer (ZIP) — ~3,200 US counties with FIPS codes</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusCountyGazUrl" />
                @if (urlResults.TryGetValue("CensusCountyGaz", out var r1)) { <span class="@(r1 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r1 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">Place Gazetteer (ZIP) — ~30,000 incorporated cities and places</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusPlaceGazUrl" />
                @if (urlResults.TryGetValue("CensusPlaceGaz", out var r2)) { <span class="@(r2 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r2 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">ZCTA → County crosswalk (TXT) — maps ZIP codes to counties by land-area</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusZctaCountyUrl" />
                @if (urlResults.TryGetValue("CensusZctaCounty", out var r3)) { <span class="@(r3 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r3 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">ZCTA → Place crosswalk (TXT) — maps ZIP codes to cities by land-area</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.CensusZctaPlaceUrl" />
                @if (urlResults.TryGetValue("CensusZctaPlace", out var r4)) { <span class="@(r4 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r4 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-group-label">Streamlined Sales Tax Governing Board</div>
        <div class="setup-url-field">
            <label class="setting-label">SSUTA Agreement PDF — Appendix C is the authoritative product/service taxonomy source</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstAgreementUrl" />
                @if (urlResults.TryGetValue("SstAgreement", out var r5)) { <span class="@(r5 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r5 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">SST Taxability Matrix (web)</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstTaxabilityMatrixUrl" />
                @if (urlResults.TryGetValue("SstTaxabilityMatrix", out var r6)) { <span class="@(r6 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r6 ? "✓" : "✗")</span> }
            </div>
        </div>
        <div class="setup-url-field">
            <label class="setting-label">SST Member States &amp; News (web)</label>
            <div class="setup-url-input-row">
                <input class="setting-input setup-url-input" @bind="settings.Current.SstMemberStatesUrl" />
                @if (urlResults.TryGetValue("SstMemberStates", out var r7)) { <span class="@(r7 ? "ds-url-ok" : "ds-url-fail") url-check-badge">@(r7 ? "✓" : "✗")</span> }
            </div>
        </div>
    </div>
    <div class="settings-actions" style="margin-top:1rem;gap:.6rem;justify-content:flex-end">
        <button class="btn-secondary" @onclick="() => CheckSources()" disabled="@checkingUrls">
            @(checkingUrls ? "Checking…" : "Check Sources")
        </button>
        <button class="btn-primary" @onclick="SaveConfig" disabled="@(configBusy || !step1Ok)">Save URLs</button>
        @if (!string.IsNullOrEmpty(configMsg)) { <span class="save-confirm">@configMsg</span> }
    </div>
    @if (checkingUrls || urlResults.Count > 0)
    {
        <div class="url-check-results">
            @foreach (var kv in UrlMap)
            {
                @if (checkingUrls && !urlResults.ContainsKey(kv.Key))
                {
                    <div class="url-check-row url-check-pending">
                        <span class="url-check-spinner"></span>
                        <span class="url-check-label">@kv.Value.Label</span>
                    </div>
                }
                else if (urlResults.TryGetValue(kv.Key, out var ok))
                {
                    <div class="url-check-row @(ok ? "url-check-ok-row" : "url-check-fail-row")">
                        <span class="url-check-icon">@(ok ? "✓" : "✗")</span>
                        <span class="url-check-label">@kv.Value.Label</span>
                    </div>
                }
            }
        </div>
    }
</div>

<!-- ── Scraping Preferences card ──────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Scraping Preferences</h2>
            <p class="setup-card-desc">
                Controls how the scrape pipeline behaves. The USPS key is optional — it enriches ZIP code city names
                via the USPS CityStateLookup API. Without it, city names come directly from the Census Bureau.
            </p>
        </div>
    </div>
    <div class="setting-row">
        <label class="setting-label">USPS API Key <span class="muted">(optional)</span></label>
        <input class="setting-input" type="password" placeholder="USPS Web Tools API key" @bind="settings.Current.UspsApiKey" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Re-scrape interval (days)</label>
        <input class="setting-input setting-input-sm" type="number" min="1" max="365" @bind="settings.Current.DefaultUpdateFrequencyDays" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Auto-fetch evidence PDFs when scraping</label>
        <input type="checkbox" @bind="settings.Current.EvidenceAutoFetch" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">Use Wayback Machine if source URL returns 404</label>
        <input type="checkbox" @bind="settings.Current.WaybackMachineFallback" />
    </div>
    <div class="setting-row" style="margin-top:.6rem">
        <label class="setting-label">
            Full-page capture for HTML evidence
            <span class="setting-hint">Off: HTML only (fast). On: bundles CSS/images/scripts into a zip.</span>
        </label>
        <input type="checkbox" @bind="settings.Current.FullPageCapture" />
    </div>
    <div class="settings-actions" style="margin-top:.75rem;gap:.6rem">
        <button class="btn-primary" @onclick="SaveConfig" disabled="@configBusy">Save Preferences</button>
        @if (!string.IsNullOrEmpty(configMsg)) { <span class="save-confirm">@configMsg</span> }
    </div>
</div>

<!-- ── Phase 2: Schema ───────────────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 2 — Schema</div>

<div class="setup-card setup-card-primary">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Populate Database</h2>
            <p class="setup-card-desc">
                Wipes all jurisdictions, tax categories, and rate data, then rebuilds everything from
                authoritative sources in sequence. Steps run in order — each unlocks the next.
            </p>
        </div>
        <div class="setup-card-actions">
            @if (pipelineState == PipelineState.Running)
            {
                <button class="btn-secondary btn-lg" @onclick="PausePipeline">⏸ Pause</button>
            }
            else if (pipelineState == PipelineState.Paused)
            {
                <button class="btn-primary btn-lg" @onclick="ResumePipeline">↩ Resume</button>
                <button class="btn-secondary" @onclick="StartPipeline">↺ Restart</button>
            }
            else
            {
                <button class="btn-primary btn-lg" @onclick="StartPipeline">
                    @(pipelineState == PipelineState.Complete ? "↺ Re-run Pipeline" : "▶ Run Pipeline")
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(runAllMsg))
    {
        <div class="setup-status @(runAllMsg.StartsWith("✗") ? "setup-status-error" : (runAllMsg.StartsWith("⏸") ? "setup-status-warn" : "setup-status-ok"))">@runAllMsg</div>
    }

    <ol class="setup-steps setup-steps-inline">
        <!-- Step 1: Validate URLs -->
        <li class="setup-step @StepClass(PipelineStep.ValidateUrls)">
            <span class="step-icon">@StepIcon(PipelineStep.ValidateUrls, "1")</span>
            <div class="step-body">
                <strong>Validate source URLs</strong>
                <span class="step-desc">
                    @if (step1Ok) { <span class="step-count-ok">All @urlResults.Count URLs reachable</span> }
                    else if (currentStep == PipelineStep.ValidateUrls) { <span class="step-count-warn">Checking…</span> }
                    else { <span class="step-count-warn">Pending</span> }
                </span>
            </div>
        </li>
        <!-- Step 2: Wipe -->
        <li class="setup-step @StepClass(PipelineStep.Clear)">
            <span class="step-icon">@StepIcon(PipelineStep.Clear, "2")</span>
            <div class="step-body">
                <strong>Wipe all jurisdictions, categories &amp; rates</strong>
                <span class="step-desc">
                    @if (wipeCompleted) { <span class="step-count-ok">Wiped — clean slate ready</span> }
                    else if (currentStep == PipelineStep.Clear) { <span class="step-count-warn">Clearing…</span> }
                    else { <span class="step-count-warn">Pending — removes all existing jurisdiction, category, and rate data</span> }
                </span>
            </div>
        </li>
        <!-- Step 3: SST taxonomy -->
        <li class="setup-step @StepClass(PipelineStep.SstTaxonomy)">
            <span class="step-icon">@StepIcon(PipelineStep.SstTaxonomy, "3")</span>
            <div class="step-body">
                <strong>SST product/service taxonomy</strong>
                <span class="step-desc">
                    @if (step2Ok) { <span class="step-count-ok">@taxCategoryCount.ToString("N0") categories imported</span> }
                    else if (sstRunning) { <span class="step-count-warn">Importing… @sstMsg</span> }
                    else { <span class="step-count-warn">Pending — SSUTA Appendix C category tree</span> }
                </span>
            </div>
        </li>
        <!-- Step 4: Seed -->
        <li class="setup-step @StepClass(PipelineStep.Seed)">
            <span class="step-icon">@StepIcon(PipelineStep.Seed, "4")</span>
            <div class="step-body">
                <strong>Seed country, states &amp; tax profiles</strong>
                <span class="step-desc">
                    @if (seedCompleted) { <span class="step-count-ok">United States · 51 state jurisdictions &amp; tax profiles seeded</span> }
                    else if (currentStep == PipelineStep.Seed) { <span class="step-count-warn">Seeding…</span> }
                    else { <span class="step-count-warn">Pending — country, 50 states + DC, sourcing rules, local rate caps</span> }
                </span>
            </div>
        </li>
        <!-- Step 5: Census -->
        <li class="setup-step @StepClass(PipelineStep.Census)">
            <span class="step-icon">@StepIcon(PipelineStep.Census, "5")</span>
            <div class="step-body">
                <strong>Census jurisdictions — counties &amp; cities</strong>
                <span class="step-desc">
                    @if (step3Ok) { <span class="step-count-ok">@countyCount.ToString("N0") counties · @cityCount.ToString("N0") cities</span> }
                    else if (censusRunning) { <span class="step-count-warn">@importMsg</span> }
                    else { <span class="step-count-warn">Pending — ~3,200 counties and ~30,000 cities (20–40 min)</span> }
                </span>
            </div>
        </li>
        <!-- Step 6: ZIP -->
        <li class="setup-step @StepClass(PipelineStep.Zips)">
            <span class="step-icon">@StepIcon(PipelineStep.Zips, "6")</span>
            <div class="step-body">
                <strong>ZIP code crosswalks</strong>
                <span class="step-desc">
                    @if (step4Ok) { <span class="step-count-ok">@zipCount.ToString("N0") ZIP codes linked</span> }
                    else if (zipRunning) { <span class="step-count-warn">@zipProgress.Processed.ToString("N0") / @(zipProgress.Total > 0 ? zipProgress.Total.ToString("N0") : "…") processed</span> }
                    else { <span class="step-count-warn">Pending — ~33,000 ZIP codes (15–30 min)</span> }
                </span>
            </div>
        </li>
    </ol>

    @if (censusRunning || zipRunning)
    {
        <div class="discovery-progress-wrap" style="margin-top:.75rem">
            @if (zipRunning && zipProgress.Total > 0)
            {
                var pct = (int)Math.Round(zipProgress.Processed * 100.0 / zipProgress.Total);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else
            {
                <div class="progress-bar-indeterminate"></div>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- ── Phase 3: Scraping ─────────────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 3 — Scraping</div>

<div class="setup-card" style="opacity:.7;border-style:dashed">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title" style="display:flex;align-items:center;gap:.6rem">
                Run Scrape Pipeline
                <span class="phase-badge phase-badge-stub">Coming Soon</span>
            </h2>
            <p class="setup-card-desc">
                Once Phase 2 is complete, the scrape pipeline will automatically discover and collect
                current tax rates for every jurisdiction — government APIs, agency web pages, and official PDFs.
                Rates are validated, change-logged, and linked to source evidence.
                Complete Phase 2 first before this phase becomes active.
            </p>
        </div>
        <div class="setup-card-actions">
            <button class="btn-primary btn-lg" disabled>▶ Run Scrape</button>
        </div>
    </div>
    <ol class="setup-steps setup-steps-inline">
        <li class="setup-step step-todo">
            <span class="step-icon">1</span>
            <div class="step-body">
                <strong>Source discovery</strong>
                <span class="step-desc"><span class="step-count-warn">Probe every jurisdiction for a tax rate source URL — government API, web page, or PDF</span></span>
            </div>
        </li>
        <li class="setup-step step-todo">
            <span class="step-icon">2</span>
            <div class="step-body">
                <strong>Initial scrape</strong>
                <span class="step-desc"><span class="step-count-warn">Fetch current rates from all discovered sources and populate baseline tax rate records</span></span>
            </div>
        </li>
        <li class="setup-step step-todo">
            <span class="step-icon">3</span>
            <div class="step-body">
                <strong>Scheduled re-scrape</strong>
                <span class="step-desc"><span class="step-count-warn">Automatically re-check sources on a configurable interval and log any rate changes</span></span>
            </div>
        </li>
    </ol>
</div>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!-- ── Phase 4: Business ─────────────────────────────────────────────────────── -->
<div class="setup-phase-label">Phase 4 — Business</div>

<!-- ── Subscription Pricing ──────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Subscription Pricing</h2>
            <p class="setup-card-desc">
                The unit price charged per state per month. A subscriber who selects 10 states is billed
                <em>PricePerState × countyCount(selectedStates)</em> each billing cycle. Changes take effect
                immediately for new checkouts — existing subscriptions are not retroactively changed.
            </p>
        </div>
    </div>
    @if (pricing is not null)
    {
        <div class="setting-row">
            <label class="setting-label">Price per state / month</label>
            <div style="display:flex;align-items:center;gap:.5rem">
                <span class="muted">$</span>
                <input class="setting-input setting-input-sm" type="number" step="0.001" min="0.001"
                       @bind="pricing.PricePerState" />
                <span class="muted">USD · 50 states = @((pricing.PricePerState * 50).ToString("C"))/mo full access</span>
            </div>
        </div>
        <div class="setting-row" style="margin-top:.6rem">
            <label class="setting-label">Price per product category / month</label>
            <div style="display:flex;align-items:center;gap:.5rem">
                <span class="muted">$</span>
                <input class="setting-input setting-input-sm" type="number" step="0.001" min="0.001"
                       @bind="pricing.PricePerCategory" />
                <span class="muted">USD per category selected by subscriber</span>
            </div>
        </div>
        <div class="setting-row" style="margin-top:.6rem">
            <label class="setting-label">Currency</label>
            <input class="setting-input" style="max-width:80px" @bind="pricing.Currency" />
        </div>
        <div class="settings-actions" style="margin-top:.75rem">
            <button class="btn-primary" @onclick="SavePricing" disabled="@adminBusy">Save Pricing</button>
            @if (adminStatus is not null) { <span class="save-confirm">@adminStatus</span> }
        </div>
    }
    else { <div class="loading-state">Loading…</div> }
</div>

<!-- ── PayPal Integration ──────────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">PayPal Integration</h2>
            <p class="setup-card-desc">
                PayPal handles subscription checkout. Leave blank to run in <strong>mock mode</strong> —
                payments are simulated and no real charges occur. Get credentials at
                <a href="https://developer.paypal.com/dashboard/" target="_blank">developer.paypal.com</a> →
                Apps &amp; Credentials. Start in Sandbox until ready for live transactions.
            </p>
        </div>
    </div>
    @if (paypal is not null)
    {
        <div class="setting-row">
            <label class="setting-label">Mode</label>
            <div class="theme-toggle">
                <button class="@(paypal.Mode == "sandbox" ? "btn-primary" : "btn-secondary")"
                        @onclick='() => paypal.Mode = "sandbox"'>Sandbox</button>
                <button class="@(paypal.Mode == "live" ? "btn-primary" : "btn-secondary")"
                        @onclick='() => paypal.Mode = "live"'>Live</button>
            </div>
        </div>
        <div class="setting-row" style="margin-top:.6rem">
            <label class="setting-label">Client ID</label>
            <input class="setting-input" placeholder="AXxx… (from PayPal dashboard)" @bind="paypal.ClientId" />
        </div>
        <div class="setting-row" style="margin-top:.6rem">
            <label class="setting-label">Client Secret</label>
            <input class="setting-input" type="password" placeholder="EXxx… (keep secret)" @bind="paypal.ClientSecret" />
        </div>
        <div class="setting-row" style="margin-top:.6rem">
            <label class="setting-label">Webhook ID <span class="muted">(optional)</span></label>
            <input class="setting-input" placeholder="For payment signature verification" @bind="paypal.WebhookId" />
        </div>
        <div class="settings-actions" style="margin-top:.75rem">
            <button class="btn-primary" @onclick="SavePayPal" disabled="@adminBusy">Save PayPal Config</button>
            @if (adminStatus is not null) { <span class="save-confirm">@adminStatus</span> }
        </div>
    }
    else { <div class="loading-state">Loading…</div> }
</div>

<!-- ── Maintenance ────────────────────────────────────────────────────────────── -->
<div class="setup-phase-label">Maintenance</div>

<!-- ── Database Backup ───────────────────────────────────────────────────────── -->
<div class="setup-card">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title">Database Backup</h2>
            <p class="setup-card-desc">
                Exports the SQL Server database to a <code>.bacpac</code> file (a portable schema + data archive).
                Requires <code>sqlpackage</code>: <code>dotnet tool install -g microsoft.sqlpackage</code>
            </p>
        </div>
    </div>
    <div style="flex-direction:column;align-items:flex-start;gap:.4rem">
        <label class="setting-label">Output path</label>
        <input class="setting-input" style="font-size:.85rem;font-family:monospace;margin-top:.25rem"
               placeholder="C:\Users\…\TaxRateCollector.bacpac" @bind="backupPath" />
    </div>
    <div class="settings-actions" style="margin-top:.75rem;gap:.6rem">
        <button class="btn-primary" @onclick="CreateBackup" disabled="@backupBusy">
            @(backupBusy ? "Exporting…" : "Create Backup")
        </button>
        @if (!string.IsNullOrEmpty(backupMsg))
        {
            <span class="@(backupMsg.StartsWith("✗") ? "text-error" : "save-confirm")">@backupMsg</span>
        }
    </div>
</div>

<!-- ── Danger Zone ────────────────────────────────────────────────────────────── -->
<div class="setup-card settings-section-danger">
    <div class="setup-card-header">
        <div>
            <h2 class="setup-card-title" style="color:var(--color-error,#dc2626)">Danger Zone</h2>
            <p class="setup-card-desc">
                Permanently deletes all collected data. The schema (tables, indexes, migrations) is preserved.
                Login credentials and payment configuration are <strong>not</strong> cleared.
                You will need to re-run the Phase 2 import pipeline after truncating.
            </p>
        </div>
    </div>
    <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
        <button class="btn-danger" @onclick="TruncateAll" disabled="@truncateBusy">
            @(truncateBusy ? "Truncating…" : "Truncate All Data")
        </button>
        @if (!string.IsNullOrEmpty(truncateMsg))
        {
            <span class="@(truncateMsg.StartsWith("✗") ? "text-error" : "save-confirm")">@truncateMsg</span>
        }
    </div>
    <p class="section-note" style="margin-top:.5rem;color:var(--color-error,#dc2626)">
        Clears: Jurisdictions · TaxRates · ZipCodes · TaxCategories · TaxCategoryRules ·
        StateTaxProfiles · ScrapeRuns · ChangeLog · SourceDocuments · Subscribers · BillingRecords · LogEntries
    </p>
</div>

@code {
    // ── Pipeline state machine ────────────────────────────────────────────────
    private enum PipelineState { None, Running, Paused, Complete }
    private enum PipelineStep  { None, ValidateUrls, Clear, SstTaxonomy, Seed, Census, Zips }

    private PipelineState pipelineState = PipelineState.None;
    private PipelineStep  currentStep   = PipelineStep.None;
    private bool wipeCompleted;
    private bool seedCompleted;
    private CancellationTokenSource? pipelineCts;

    private string StepClass(PipelineStep step)
    {
        if (StepIsDone(step)) return "step-ok";
        if (currentStep == step && pipelineState == PipelineState.Running) return "step-active";
        return "step-todo";
    }

    private string StepIcon(PipelineStep step, string num) =>
        StepIsDone(step) ? "✓" : num;

    private bool StepIsDone(PipelineStep step) => step switch
    {
        PipelineStep.ValidateUrls => step1Ok,
        PipelineStep.Clear        => wipeCompleted,
        PipelineStep.SstTaxonomy  => step2Ok,
        PipelineStep.Seed         => seedCompleted,
        PipelineStep.Census       => step3Ok,
        PipelineStep.Zips         => step4Ok,
        _                         => false,
    };

    // ── Counts ────────────────────────────────────────────────────────────────
    private int countyCount, cityCount, zipCount, taxCategoryCount;

    private bool step1Ok => urlResults.Count > 0 && urlResults.Values.All(v => v);
    private bool step2Ok => taxCategoryCount > 0;
    private bool step3Ok => countyCount > 0 && cityCount > 0;
    private bool step4Ok => zipCount > 0;

    // ── URL validation ────────────────────────────────────────────────────────
    private bool checkingUrls;
    private Dictionary<string, bool> urlResults = [];

    private Dictionary<string, (string Label, Func<string> Url)> UrlMap => new()
    {
        ["CensusCountyGaz"]     = ("Census County Gazetteer (ZIP)",       () => settings.Current.CensusCountyGazUrl),
        ["CensusPlaceGaz"]      = ("Census Place Gazetteer (ZIP)",         () => settings.Current.CensusPlaceGazUrl),
        ["CensusZctaCounty"]    = ("Census ZCTA→County crosswalk (TXT)",   () => settings.Current.CensusZctaCountyUrl),
        ["CensusZctaPlace"]     = ("Census ZCTA→Place crosswalk (TXT)",    () => settings.Current.CensusZctaPlaceUrl),
        ["SstAgreement"]        = ("SSUTA Agreement PDF (Appendix C)",      () => settings.Current.SstAgreementUrl),
        ["SstTaxabilityMatrix"] = ("SST Taxability Matrix (web)",           () => settings.Current.SstTaxabilityMatrixUrl),
        ["SstMemberStates"]     = ("SST Member States page (web)",          () => settings.Current.SstMemberStatesUrl),
    };

    // ── Import running state ──────────────────────────────────────────────────
    private bool censusRunning, zipRunning, sstRunning;
    private string? importMsg;
    private string? sstMsg;
    private string? runAllMsg;
    private ZipImportProgress zipProgress = new(0, 0, 0, 0, 0);

    // ── Config / admin state ──────────────────────────────────────────────────
    private bool configBusy;
    private string? configMsg;
    private bool adminBusy;
    private string? adminStatus;
    private PricingConfig? pricing;
    private PayPalConfig? paypal;
    private bool backupBusy;
    private string? backupMsg;
    private string backupPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
        $"TaxRateCollector_{DateTime.Now:yyyyMMdd}.bacpac");
    private bool truncateBusy;
    private string? truncateMsg;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        await using var db = await DbFactory.CreateDbContextAsync();
        pricing = await db.PricingConfigs.OrderBy(x => x.Id).FirstOrDefaultAsync();
        paypal  = await db.PayPalConfigs.OrderBy(x => x.Id).FirstOrDefaultAsync();
    }

    private async Task Refresh()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        countyCount      = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.County);
        cityCount        = await db.Jurisdictions.CountAsync(j => j.JurisdictionType == JurisdictionType.City);
        zipCount         = await db.ZipCodes.CountAsync();
        taxCategoryCount = await db.TaxCategories.CountAsync();
    }

    // ── Pipeline entry points ─────────────────────────────────────────────────

    private async Task StartPipeline()
    {
        wipeCompleted = false;
        seedCompleted = false;
        runAllMsg     = null;
        await RunPipelineAsync(fresh: true);
    }

    private Task ResumePipeline() => RunPipelineAsync(fresh: false);

    private void PausePipeline() => pipelineCts?.Cancel();

    private async Task RunPipelineAsync(bool fresh)
    {
        pipelineState = PipelineState.Running;
        pipelineCts   = new CancellationTokenSource();
        var ct = pipelineCts.Token;
        StateHasChanged();

        try
        {
            // Step 1: Validate URLs
            currentStep = PipelineStep.ValidateUrls;
            runAllMsg   = "Step 1/6 — Checking source URLs…";
            StateHasChanged();
            await CheckSources(ct);
            if (!step1Ok)
            {
                runAllMsg     = "✗ URL check failed — fix broken URLs in Phase 1 first.";
                pipelineState = PipelineState.None;
                currentStep   = PipelineStep.None;
                return;
            }

            // Step 2: Wipe (fresh start only — resume skips if already wiped)
            if (fresh || !wipeCompleted)
            {
                currentStep = PipelineStep.Clear;
                runAllMsg   = "Step 2/6 — Wiping all jurisdictions, categories, and rate data…";
                StateHasChanged();
                await WipeAllDataAsync(ct);
                wipeCompleted = true;
                seedCompleted = false;
                await Refresh();
                StateHasChanged();
            }

            // Step 3: SST taxonomy
            if (!step2Ok)
            {
                currentStep = PipelineStep.SstTaxonomy;
                runAllMsg   = "Step 3/6 — Importing SST taxonomy…";
                StateHasChanged();
                await RunSstImportAsync(ct);
                if (sstMsg?.StartsWith("✗") == true)
                {
                    runAllMsg     = $"✗ SST import failed: {sstMsg}";
                    pipelineState = PipelineState.None;
                    currentStep   = PipelineStep.None;
                    return;
                }
            }

            // Step 4: Seed Country + States + Tax Profiles
            if (!seedCompleted)
            {
                currentStep = PipelineStep.Seed;
                runAllMsg   = "Step 4/6 — Seeding country, states, and tax profiles…";
                StateHasChanged();
                await SeedJurisdictionsAsync(ct);
                seedCompleted = true;
                await Refresh();
                StateHasChanged();
            }

            // Step 5: Census
            if (!step3Ok)
            {
                currentStep = PipelineStep.Census;
                runAllMsg   = "Step 5/6 — Importing Census jurisdictions…";
                StateHasChanged();
                await RunCensusImportAsync(ct);
                if (importMsg?.StartsWith("✗") == true)
                {
                    runAllMsg     = $"✗ Census import failed: {importMsg}";
                    pipelineState = PipelineState.None;
                    currentStep   = PipelineStep.None;
                    return;
                }
            }

            // Step 6: ZIPs
            if (!step4Ok)
            {
                currentStep = PipelineStep.Zips;
                runAllMsg   = "Step 6/6 — Importing ZIP crosswalks…";
                StateHasChanged();
                await RunZipImportAsync(ct);
                if (importMsg?.StartsWith("✗") == true)
                {
                    runAllMsg     = $"✗ ZIP import failed: {importMsg}";
                    pipelineState = PipelineState.None;
                    currentStep   = PipelineStep.None;
                    return;
                }
            }

            runAllMsg     = "✓ Pipeline complete.";
            pipelineState = PipelineState.Complete;
            currentStep   = PipelineStep.None;
        }
        catch (OperationCanceledException)
        {
            runAllMsg     = "⏸ Pipeline paused — click Resume to continue.";
            pipelineState = PipelineState.Paused;
        }
        catch (Exception ex)
        {
            runAllMsg     = $"✗ {ex.Message}";
            pipelineState = PipelineState.None;
            currentStep   = PipelineStep.None;
        }
        finally { StateHasChanged(); }
    }

    // ── URL check ────────────────────────────────────────────────────────────

    private async Task CheckSources(CancellationToken ct = default)
    {
        checkingUrls = true;
        urlResults = [];
        StateHasChanged();

        using var http = HttpClientFactory.CreateClient();
        http.Timeout = TimeSpan.FromSeconds(10);

        var tasks = UrlMap.Select(async kv =>
        {
            var url = kv.Value.Url();
            if (string.IsNullOrWhiteSpace(url)) return (kv.Key, false);
            try
            {
                using var req  = new HttpRequestMessage(HttpMethod.Head, url);
                using var resp = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead, ct);
                return (kv.Key, resp.IsSuccessStatusCode || (int)resp.StatusCode < 400);
            }
            catch { return (kv.Key, false); }
        });

        var results = await Task.WhenAll(tasks);
        urlResults   = results.ToDictionary(r => r.Item1, r => r.Item2);
        checkingUrls = false;
        StateHasChanged();
    }

    // ── Full wipe ─────────────────────────────────────────────────────────────

    private async Task WipeAllDataAsync(CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);

        // Null ZIP→jurisdiction links (no DB-level cascade for these nullable columns).
        await db.ZipCodes
            .Where(z => z.CountyJurisdictionId != null || z.CityJurisdictionId != null)
            .ExecuteUpdateAsync(s => s
                .SetProperty(z => z.CountyJurisdictionId, (int?)null)
                .SetProperty(z => z.CityJurisdictionId,   (int?)null), ct);

        // Delete jurisdictions bottom-up (ParentId FK is Restrict; TaxRates cascade).
        foreach (var type in new[] {
            JurisdictionType.City, JurisdictionType.County,
            JurisdictionType.State, JurisdictionType.Country })
        {
            var ids = await db.Jurisdictions
                .Where(j => j.JurisdictionType == type)
                .Select(j => j.Id).ToListAsync(ct);
            if (ids.Count > 0)
                await db.Jurisdictions.Where(j => ids.Contains(j.Id)).ExecuteDeleteAsync(ct);
        }

        // Wipe tax categories (self-referential FK — disable constraints to allow bulk delete).
        await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategoryRules", ct);
        await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories NOCHECK CONSTRAINT ALL", ct);
        await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategories", ct);
        await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories WITH CHECK CHECK CONSTRAINT ALL", ct);

        // Wipe scrape history and source evidence.
        await db.Database.ExecuteSqlRawAsync("DELETE FROM SourceDocuments", ct);
        await db.Database.ExecuteSqlRawAsync("DELETE FROM ScrapeRuns", ct);

        // Wipe state tax profiles (will be re-seeded in step 4).
        await db.Database.ExecuteSqlRawAsync("DELETE FROM StateTaxProfiles", ct);
    }

    // ── Seed Country + States + Tax Profiles ─────────────────────────────────

    private async Task SeedJurisdictionsAsync(CancellationToken ct)
    {
        await using var db = await DbFactory.CreateDbContextAsync(ct);
        await JurisdictionSeeder.SeedAsync(db);
        await StateTaxProfileSeeder.SeedAsync(db);
    }

    // ── SST import ───────────────────────────────────────────────────────────

    private async Task RunSstImportAsync(CancellationToken ct)
    {
        sstRunning = true;
        sstMsg     = null;
        StateHasChanged();
        try
        {
            var p = new Progress<string>(msg => { sstMsg = msg; InvokeAsync(StateHasChanged); });
            var r = await sstSvc.ImportAsync(p, ct);
            sstMsg = r.Success
                ? $"{r.CategoriesCreated:N0} categories in {r.Elapsed:m\\:ss}"
                : $"✗ {r.Error}";
            await Refresh();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex) { sstMsg = $"✗ {ex.Message}"; }
        finally { sstRunning = false; StateHasChanged(); }
    }

    // ── Census import ─────────────────────────────────────────────────────────

    private async Task RunCensusImportAsync(CancellationToken ct)
    {
        censusRunning = true;
        importMsg     = "Starting…";
        StateHasChanged();
        try
        {
            var p = new Progress<CensusImportProgress>(snap =>
            {
                importMsg = $"{snap.Stage}: {snap.Processed:N0}/{snap.Total:N0}";
                InvokeAsync(StateHasChanged);
            });
            var r = await censusSvc.ImportAsync(p, ct);
            importMsg = $"{r.CountiesCreated:N0} counties · {r.CitiesCreated:N0} cities in {r.Elapsed:m\\:ss}";
            await Refresh();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { censusRunning = false; StateHasChanged(); }
    }

    // ── ZIP import ────────────────────────────────────────────────────────────

    private async Task RunZipImportAsync(CancellationToken ct)
    {
        zipRunning    = true;
        zipProgress   = new(0, 0, 0, 0, 0);
        StateHasChanged();
        try
        {
            var p = new Progress<ZipImportProgress>(snap =>
            {
                zipProgress = snap;
                InvokeAsync(StateHasChanged);
            });
            await zipSvc.ImportAsync(p, ct);
            await Refresh();
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex) { importMsg = $"✗ {ex.Message}"; }
        finally { zipRunning = false; StateHasChanged(); }
    }

    // ── Config save ───────────────────────────────────────────────────────────
    private async Task SaveConfig()
    {
        configBusy = true;
        settings.Save();
        configMsg = "✓ Saved";
        StateHasChanged();
        await Task.Delay(2000);
        configMsg = null;
        configBusy = false;
        StateHasChanged();
    }

    // ── Pricing ───────────────────────────────────────────────────────────────
    private async Task SavePricing()
    {
        if (pricing is null) return;
        adminBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            pricing.UpdatedAt = DateTime.UtcNow.ToString("o");
            db.PricingConfigs.Update(pricing);
            await db.SaveChangesAsync();
            SetAdminStatus("✓ Pricing saved");
        }
        catch (Exception ex) { SetAdminStatus($"✗ {ex.Message}"); }
        finally { adminBusy = false; }
    }

    // ── PayPal ────────────────────────────────────────────────────────────────
    private async Task SavePayPal()
    {
        if (paypal is null) return;
        adminBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            paypal.UpdatedAt = DateTime.UtcNow.ToString("o");
            db.PayPalConfigs.Update(paypal);
            await db.SaveChangesAsync();
            SetAdminStatus("✓ PayPal config saved");
        }
        catch (Exception ex) { SetAdminStatus($"✗ {ex.Message}"); }
        finally { adminBusy = false; }
    }

    private void SetAdminStatus(string msg)
    {
        adminStatus = msg;
        StateHasChanged();
        _ = Task.Delay(3000).ContinueWith(_ => { adminStatus = null; InvokeAsync(StateHasChanged); });
    }

    // ── Backup ────────────────────────────────────────────────────────────────
    private async Task CreateBackup()
    {
        if (string.IsNullOrWhiteSpace(backupPath)) return;
        backupBusy = true; backupMsg = null;
        StateHasChanged();
        try
        {
            var connStr = Configuration.GetConnectionString("DefaultConnection") ?? "";
            var server = ""; var database = "";
            foreach (var part in connStr.Split(';', StringSplitOptions.RemoveEmptyEntries))
            {
                var kv = part.Split('=', 2);
                if (kv.Length < 2) continue;
                var key = kv[0].Trim(); var val = kv[1].Trim();
                if (key.Equals("Server", StringComparison.OrdinalIgnoreCase) ||
                    key.Equals("Data Source", StringComparison.OrdinalIgnoreCase))
                    server = val;
                else if (key.Equals("Database", StringComparison.OrdinalIgnoreCase) ||
                         key.Equals("Initial Catalog", StringComparison.OrdinalIgnoreCase))
                    database = val;
            }
            var dir = Path.GetDirectoryName(backupPath);
            if (!string.IsNullOrEmpty(dir)) Directory.CreateDirectory(dir);
            var sw = System.Diagnostics.Stopwatch.StartNew();
            using var proc = new System.Diagnostics.Process();
            proc.StartInfo = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "sqlpackage",
                Arguments = $"/Action:Export /SourceServerName:\"{server}\" /SourceDatabaseName:\"{database}\" /TargetFile:\"{backupPath}\"",
                RedirectStandardOutput = true, RedirectStandardError = true,
                UseShellExecute = false, CreateNoWindow = true
            };
            proc.Start();
            await proc.WaitForExitAsync();
            sw.Stop();
            backupMsg = proc.ExitCode == 0
                ? $"✓ Saved to {backupPath} ({sw.Elapsed.TotalSeconds:F1}s)"
                : $"✗ sqlpackage exited {proc.ExitCode}: {(await proc.StandardError.ReadToEndAsync()).Split('\n').FirstOrDefault()?.Trim()}";
        }
        catch (Exception ex) { backupMsg = $"✗ {ex.Message}"; }
        finally { backupBusy = false; StateHasChanged(); }
    }

    // ── Truncate ──────────────────────────────────────────────────────────────
    private async Task TruncateAll()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "TRUNCATE ALL DATA?\n\nThis permanently deletes:\n" +
            "  • All jurisdictions, tax rates, ZIP codes\n" +
            "  • All tax categories and rules\n" +
            "  • All scrape runs, source documents, change log\n" +
            "  • All subscribers, billing records, log entries\n\n" +
            "Login credentials and payment config are preserved.\n\nContinue?");
        if (!confirmed) return;
        truncateBusy = true; truncateMsg = null;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.ExecuteSqlRawAsync("DELETE FROM BillingRecords");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM SubscribedStates");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM Subscribers");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM LogEntries");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ChangeLog");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM SourceDocuments");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxRates");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ScrapeRuns");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ZipCodes");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategoryRules");
            await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories NOCHECK CONSTRAINT ALL");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategories");
            await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories WITH CHECK CHECK CONSTRAINT ALL");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM Jurisdictions");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM StateTaxProfiles");
            truncateMsg = "✓ All data cleared.";
        }
        catch (Exception ex) { truncateMsg = $"✗ {ex.Message}"; }
        finally { truncateBusy = false; StateHasChanged(); }
    }
}
