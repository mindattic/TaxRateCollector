    private static string ScraperLabel(string st) => st switch
    {
        "WI" => "Wisconsin — Alcohol excise",
        "IL" => "Illinois — Alcohol excise",
        "MN" => "Minnesota — Alcohol excise",
        _    => st,
    };

    private async Task RunScraper(string st)
    {
        scraperStates[st] = new ScraperRunState { Running = true };
        StateHasChanged();
        try
        {
            await Orchestrator.RunBulkForStateAsync(st, null, !settings.Current.AutoApprove);
            scraperStates[st] = new ScraperRunState { Running = false, Error = false };
        }
        catch
        {
            scraperStates[st] = new ScraperRunState { Running = false, Error = true };
        }
        StateHasChanged();
    }

