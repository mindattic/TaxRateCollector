    // ── Backup ────────────────────────────────────────────────────────────────
    private async Task CreateBackup()
    {
        if (string.IsNullOrWhiteSpace(backupPath)) return;
        backupBusy = true; backupMsg = null;
        StateHasChanged();
        try
        {
            var connStr = Configuration.GetConnectionString("DefaultConnection") ?? "";
            var server = ""; var database = "";
            foreach (var part in connStr.Split(';', StringSplitOptions.RemoveEmptyEntries))
            {
                var kv = part.Split('=', 2);
                if (kv.Length < 2) continue;
                var key = kv[0].Trim(); var val = kv[1].Trim();
                if (key.Equals("Server", StringComparison.OrdinalIgnoreCase) ||
                    key.Equals("Data Source", StringComparison.OrdinalIgnoreCase))
                    server = val;
                else if (key.Equals("Database", StringComparison.OrdinalIgnoreCase) ||
                         key.Equals("Initial Catalog", StringComparison.OrdinalIgnoreCase))
                    database = val;
            }
            var dir = Path.GetDirectoryName(backupPath);
            if (!string.IsNullOrEmpty(dir)) Directory.CreateDirectory(dir);
            var sw = System.Diagnostics.Stopwatch.StartNew();
            using var proc = new System.Diagnostics.Process();
            proc.StartInfo = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "sqlpackage",
                Arguments = $"/Action:Export /SourceServerName:\"{server}\" /SourceDatabaseName:\"{database}\" /TargetFile:\"{backupPath}\"",
                RedirectStandardOutput = true, RedirectStandardError = true,
                UseShellExecute = false, CreateNoWindow = true
            };
            proc.Start();
            await proc.WaitForExitAsync();
            sw.Stop();
            backupMsg = proc.ExitCode == 0
                ? $"✓ Saved to {backupPath} ({sw.Elapsed.TotalSeconds:F1}s)"
                : $"✗ sqlpackage exited {proc.ExitCode}: {(await proc.StandardError.ReadToEndAsync()).Split('\n').FirstOrDefault()?.Trim()}";
        }
        catch (Exception ex) { backupMsg = $"✗ {ex.Message}"; }
        finally { backupBusy = false; StateHasChanged(); }
    }

