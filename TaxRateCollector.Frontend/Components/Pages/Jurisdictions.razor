    private void OnRateChange(int id, string value) => editValues[id] = value;
    private void CancelEdit(int id) { editActive.Remove(id); editValues.Remove(id); }

    private async Task OnRateKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, int id)
    {
        if (e.Key is "Enter" or "Tab") await SaveRate(id);
        if (e.Key == "Escape") CancelEdit(id);
    }

    private async Task SaveRate(int jurisdictionId)
    {
        if (!isAdmin) { SetStatus("✗ Sign in to edit rates"); return; }
        if (selectedCategoryId is null) { SetStatus("✗ Select a category first"); return; }
        editActive.Remove(jurisdictionId);
        if (!editValues.TryGetValue(jurisdictionId, out var valStr)) return;
        editValues.Remove(jurisdictionId);
        if (!decimal.TryParse(valStr, out var pct)) return;
        var rate = pct / 100m;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (manualRunId is null)
            {
                var run = await db.ScrapeRuns.FirstOrDefaultAsync(r => r.Status == ScrapeStatus.Manual)
                    ?? new ScrapeRun { StartedAt = DateTime.UtcNow.ToString("o"), CompletedAt = DateTime.UtcNow.ToString("o"), Status = ScrapeStatus.Manual };
                if (run.Id == 0) { db.ScrapeRuns.Add(run); await db.SaveChangesAsync(); }
                manualRunId = run.Id;
            }

            var catId = selectedCategoryId;
            var old = await db.TaxRates.FirstOrDefaultAsync(
                r => r.JurisdictionId == jurisdictionId && r.IsCurrent && r.TaxCategoryId == catId);
            if (old is not null) old.IsCurrent = false;

            db.TaxRates.Add(new TaxRate
            {
                JurisdictionId = jurisdictionId,
                TaxCategoryId = catId,
                Rate = rate,
                RateType = "General",
                EffectiveDate = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd"),
                ScrapedAt = DateTime.UtcNow.ToString("o"),
                ScrapeRunId = manualRunId.Value,
                RawValue = $"{pct:F3}%",
                IsCurrent = true
            });
            await db.SaveChangesAsync();

            await RefreshNode(db, jurisdictionId);
            SetStatus($"✓ Saved {pct:F3}%");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        StateHasChanged();
    }

