    // ── Helpers ───────────────────────────────────────────────────────────────
    private void SetStatus(string? msg)
    {
        _status = msg;
        if (msg is not null)
            _ = Task.Delay(4000).ContinueWith(_ => { _status = null; InvokeAsync(StateHasChanged); });
    }

    // ── Export ────────────────────────────────────────────────────────────────
    private sealed record ExportRow(
        string Tier, string StateCode, string Name, string FipsCode,
        decimal? Rate, decimal? CombinedRate, string EffectiveDate,
        bool HasEvidence);

    private async Task<List<ExportRow>> BuildExportData()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var jurisdictions = await db.Jurisdictions
            .Where(j => j.IsActive)
            .Select(j => new
            {
                j.Id, j.ParentId, j.JurisdictionType, j.StateCode, j.JurisdictionName, j.FipsCode,
                Rate = (decimal?)db.TaxRates.Where(r => r.JurisdictionId == j.Id && r.IsCurrent).Select(r => r.Rate).FirstOrDefault(),
                EffectiveDate = db.TaxRates.Where(r => r.JurisdictionId == j.Id && r.IsCurrent).Select(r => r.EffectiveDate).FirstOrDefault() ?? "",
                RateId = (int?)db.TaxRates.Where(r => r.JurisdictionId == j.Id && r.IsCurrent).Select(r => r.Id).FirstOrDefault()
            })
            .ToListAsync();

        var allRateIds = jurisdictions.Where(j => j.RateId.HasValue).Select(j => j.RateId!.Value).ToList();
        var evidencedRateIds = await db.SourceDocuments
            .Where(d => allRateIds.Contains(d.TaxRateId) && d.IsActive)
            .Select(d => d.TaxRateId)
            .Distinct()
            .ToListAsync();
        var evidencedSet = evidencedRateIds.ToHashSet();

        var rateById = jurisdictions.ToDictionary(j => j.Id, j => j.Rate);
        var parentById = jurisdictions.ToDictionary(j => j.Id, j => j.ParentId);

        decimal? CombinedFor(int id)
        {
            var total = rateById.GetValueOrDefault(id) ?? 0;
            var cur = id;
            while (parentById.TryGetValue(cur, out var pid) && pid.HasValue)
            {
                total += rateById.GetValueOrDefault(pid.Value) ?? 0;
                cur = pid.Value;
            }
            return total;
        }

        return jurisdictions
            .Where(j => j.JurisdictionType != JurisdictionType.Country)
            .OrderBy(j => j.StateCode).ThenBy(j => j.JurisdictionType).ThenBy(j => j.JurisdictionName)
            .Select(j => new ExportRow(
                j.JurisdictionType.ToString(),
                j.StateCode,
                j.JurisdictionName,
                j.FipsCode,
                j.Rate,
                j.JurisdictionType == JurisdictionType.City ? CombinedFor(j.Id) : (decimal?)null,
                j.EffectiveDate,
                j.RateId.HasValue && evidencedSet.Contains(j.RateId.Value)
            ))
            .ToList();
    }

    private async Task OnExportChange(ChangeEventArgs e)
    {
        var fmt = e.Value?.ToString();
        _exportFormat = "";
        switch (fmt)
        {
            case "csv":  await ExportCsv();  break;
            case "xlsx": await ExportXlsx(); break;
            case "sql":  await ExportSql();  break;
            case "html": await ExportHtml(); break;
        }
    }

    private async Task ExportCsv()
    {
        _exporting = true; SetStatus("⟳ Building…"); StateHasChanged();
        try
        {
            var rows = await BuildExportData();
            var sb = new StringBuilder();
            sb.AppendLine("Tier,State,Name,FIPS,Rate(%),Combined(%),EffectiveDate,Validated");
            foreach (var r in rows)
                sb.AppendLine($"{r.Tier},{r.StateCode},\"{r.Name}\",{r.FipsCode}," +
                    $"{(r.Rate.HasValue ? (r.Rate.Value * 100).ToString("F3") : "")}," +
                    $"{(r.CombinedRate.HasValue ? (r.CombinedRate.Value * 100).ToString("F3") : "")}," +
                    $"{r.EffectiveDate},{r.HasEvidence}");
            await DownloadFile($"TaxRates_{DateTime.UtcNow:yyyyMMdd}.csv", "text/csv", Encoding.UTF8.GetBytes(sb.ToString()));
            SetStatus("✓ CSV downloaded");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { _exporting = false; StateHasChanged(); }
    }

    private async Task ExportXlsx()
    {
        _exporting = true; SetStatus("⟳ Building…"); StateHasChanged();
        try
        {
            var rows = await BuildExportData();
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Tax Rates");

            string[] headers = ["Tier", "State", "Name", "FIPS", "Rate (%)", "Combined (%)", "Effective Date", "Validated"];
            for (int i = 0; i < headers.Length; i++)
            {
                ws.Cell(1, i + 1).Value = headers[i];
                ws.Cell(1, i + 1).Style.Font.Bold = true;
                ws.Cell(1, i + 1).Style.Fill.BackgroundColor = XLColor.FromHtml("#1a2332");
                ws.Cell(1, i + 1).Style.Font.FontColor = XLColor.White;
            }

            int row = 2;
            foreach (var r in rows)
            {
                ws.Cell(row, 1).Value = r.Tier;
                ws.Cell(row, 2).Value = r.StateCode;
                ws.Cell(row, 3).Value = r.Name;
                ws.Cell(row, 4).Value = r.FipsCode;
                ws.Cell(row, 5).Value = r.Rate.HasValue ? (double)(r.Rate.Value * 100) : 0.0;
                ws.Cell(row, 6).Value = r.CombinedRate.HasValue ? (double)(r.CombinedRate.Value * 100) : 0.0;
                ws.Cell(row, 7).Value = r.EffectiveDate;
                ws.Cell(row, 8).Value = r.HasEvidence ? "Yes" : "No";
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            await DownloadFile($"TaxRates_{DateTime.UtcNow:yyyyMMdd}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", ms.ToArray());
            SetStatus("✓ XLSX downloaded");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { _exporting = false; StateHasChanged(); }
    }

    private async Task ExportSql()
    {
        _exporting = true; SetStatus("⟳ Building…"); StateHasChanged();
        try
        {
            var rows = await BuildExportData();
            var sb = new StringBuilder();
            sb.AppendLine("-- TaxRateCollector Export");
            sb.AppendLine($"-- Generated {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC");
            sb.AppendLine();
            sb.AppendLine("CREATE TABLE IF NOT EXISTS tax_rates_master (");
            sb.AppendLine("  tier TEXT, state_code TEXT, name TEXT, fips_code TEXT,");
            sb.AppendLine("  rate REAL, combined_rate REAL, effective_date TEXT, validated INTEGER");
            sb.AppendLine(");");
            sb.AppendLine();
            sb.AppendLine("INSERT INTO tax_rates_master VALUES");
            for (int i = 0; i < rows.Count; i++)
            {
                var r = rows[i];
                var rate = r.Rate.HasValue ? (r.Rate.Value * 100).ToString("F3") : "NULL";
                var combined = r.CombinedRate.HasValue ? (r.CombinedRate.Value * 100).ToString("F3") : "NULL";
                var comma = i < rows.Count - 1 ? "," : ";";
                sb.AppendLine($"  ('{r.Tier}','{r.StateCode}','{r.Name.Replace("'", "''")}','{r.FipsCode}'," +
                    $"{rate},{combined},'{r.EffectiveDate}',{(r.HasEvidence ? 1 : 0)}){comma}");
            }
            await DownloadFile($"TaxRates_{DateTime.UtcNow:yyyyMMdd}.sql", "text/plain", Encoding.UTF8.GetBytes(sb.ToString()));
            SetStatus("✓ SQL downloaded");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { _exporting = false; StateHasChanged(); }
    }

    private async Task ExportHtml()
    {
        _exporting = true; SetStatus("⟳ Building…"); StateHasChanged();
        try
        {
            var rows = await BuildExportData();
            var sb = new StringBuilder();
            sb.AppendLine("<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"utf-8\">");
            sb.AppendLine($"<title>Tax Rates — {DateTime.UtcNow:yyyy-MM-dd}</title>");
            sb.AppendLine("<style>");
            sb.AppendLine("body{font-family:system-ui,sans-serif;font-size:13px;margin:2rem;color:#1a2332}");
            sb.AppendLine("h2{margin-bottom:.25rem}p.meta{color:#666;font-size:12px;margin-bottom:1rem}");
            sb.AppendLine("table{border-collapse:collapse;width:100%}");
            sb.AppendLine("th{background:#1a2332;color:#fff;padding:7px 12px;text-align:left;font-size:12px;white-space:nowrap}");
            sb.AppendLine("td{border-bottom:1px solid #e8ecf0;padding:5px 12px;white-space:nowrap}");
            sb.AppendLine("tr:hover td{background:#f0f4f8}");
            sb.AppendLine(".state td{background:#e8f4fd;font-weight:600}.county td{background:#fff}.city td{background:#fafafa;font-size:12px}");
            sb.AppendLine(".badge{display:inline-block;padding:2px 7px;border-radius:3px;font-size:11px;font-weight:700;color:#fff}");
            sb.AppendLine(".badge-State{background:#2563eb}.badge-County{background:#7c3aed}.badge-City{background:#059669}");
            sb.AppendLine(".ok{color:#059669}.missing{color:#d97706}");
            sb.AppendLine("</style></head><body>");
            sb.AppendLine("<h2>Tax Rate Master Table</h2>");
            sb.AppendLine($"<p class=\"meta\">Generated {DateTime.UtcNow:yyyy-MM-dd HH:mm} UTC &nbsp;·&nbsp; {rows.Count:N0} jurisdictions</p>");
            sb.AppendLine("<table><thead><tr>");
            foreach (var h in new[] { "Tier", "State", "Name", "FIPS", "Rate (%)", "Combined (%)", "Effective Date", "Validated" })
                sb.Append($"<th>{h}</th>");
            sb.AppendLine("</tr></thead><tbody>");
            foreach (var r in rows)
            {
                var rate     = r.Rate.HasValue     ? $"{r.Rate.Value * 100:F3}%"         : "—";
                var combined = r.CombinedRate.HasValue ? $"{r.CombinedRate.Value * 100:F3}%" : "—";
                var validated = r.HasEvidence
                    ? "<span class=\"ok\">● Validated</span>"
                    : "<span class=\"missing\">○ Pending</span>";
                sb.AppendLine($"<tr class=\"{r.Tier.ToLower()}\">" +
                    $"<td><span class=\"badge badge-{r.Tier}\">{r.Tier}</span></td>" +
                    $"<td>{r.StateCode}</td>" +
                    $"<td>{System.Net.WebUtility.HtmlEncode(r.Name)}</td>" +
                    $"<td>{r.FipsCode}</td>" +
                    $"<td>{rate}</td>" +
                    $"<td>{combined}</td>" +
                    $"<td>{r.EffectiveDate}</td>" +
                    $"<td>{validated}</td></tr>");
            }
            sb.AppendLine("</tbody></table></body></html>");
            await DownloadFile($"TaxRates_{DateTime.UtcNow:yyyyMMdd}.html", "text/html", Encoding.UTF8.GetBytes(sb.ToString()));
            SetStatus("✓ HTML downloaded");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { _exporting = false; StateHasChanged(); }
    }

    private async Task DownloadFile(string fileName, string mimeType, byte[] data)
    {
        var base64 = Convert.ToBase64String(data);
        await JS.InvokeVoidAsync("downloadBase64File", fileName, mimeType, base64);
    }
