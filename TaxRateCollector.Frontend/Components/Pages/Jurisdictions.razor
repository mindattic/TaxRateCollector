@page "/"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Cryptography
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@using ClosedXML.Excel
@using System.Text
@using TaxRateCollector.Frontend.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IScrapeOrchestrator Orchestrator
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Jurisdictions — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Jurisdictions</h1>
            <p class="page-sub">Select a product category, then expand any tier to view or edit rates and attach evidence.</p>
        </div>
        <div class="header-actions">
            @if (isAdmin)
            {
                <button class="btn-secondary" @onclick="RunScrape" disabled="@scraping">
                    @(scraping ? "Scraping…" : "Run Scrape")
                </button>
            }
            <select class="btn-export-select" value="@exportFormat" @onchange="OnExportChange" disabled="@exporting">
                <option value="">@(exporting ? "Exporting…" : "Export ▾")</option>
                <option value="csv">CSV</option>
                <option value="xlsx">Excel (XLSX)</option>
                <option value="sql">SQL INSERTs</option>
                <option value="html">HTML Table</option>
            </select>
        </div>
    </div>
</div>

<!-- ── Product category picker ───────────────────────────────────────────────── -->
<div class="category-picker">
    @if (allCategories.Count == 0)
    {
        <div class="cat-page cat-empty-hint">
            No categories loaded — run <a href="/setup">Setup → SST Taxonomy</a> first.
        </div>
    }
    else
    {
        <div class="cat-type-row cat-type-@(selectedTopLevel.ToLower())">
            <button class="cat-type-btn @(selectedTopLevel == "Goods" ? "cat-type-active" : "")" @onclick='() => OnTopLevelClick("Goods")'>Goods</button>
            <button class="cat-type-btn @(selectedTopLevel == "Services" ? "cat-type-active" : "")" @onclick='() => OnTopLevelClick("Services")'>Services</button>
        </div>
        <div class="cat-page">
            @foreach (var (groupName, leaves) in categoryGroups)
            {
                <div class="cat-group">
                    <span class="cat-group-label">@groupName</span>
                    <div class="cat-chips">
                        @foreach (var leaf in leaves)
                        {
                            var catLocked = !isAdmin && !IsGuestMode && !subscribedCategoryIds.Contains(leaf.Id);
                            @if (catLocked)
                            {
                                <button class="cat-chip cat-chip-locked" title="Subscribe to this category to access rates"
                                        @onclick="() => ShowCategoryLockedHint()">
                                    🔒 @leaf.Name
                                </button>
                            }
                            else
                            {
                                <button class="cat-chip @(selectedCategoryId == leaf.Id ? "cat-chip-active" : "")"
                                        @onclick="() => SelectCategory(leaf.Id)">
                                    @leaf.Name
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (!isSubscribed)
{
    <div class="subscribe-banner">
        👁 <strong>You're viewing sample data.</strong>
        Subscribe by state and category to access verified real-time tax rates — from $0.01 / state / month.
        <a href="/subscribe" class="banner-cta" style="text-decoration:none">View Plans →</a>
    </div>
}
else if (!isAdmin && HasUnsubscribedContent)
{
    <div class="subscribe-banner subscribe-banner-remind">
        Some states or product categories are not included in your current subscription.
        <a href="/subscribe" class="banner-cta" style="text-decoration:none">Adjust subscription →</a>
    </div>
}

<div class="tree-container">
    @if (loading)
    {
        <div class="cat-loading-overlay">
            <div class="export-spinner-card">
                <div class="spinner"></div>
                <span>Loading rates…</span>
            </div>
        </div>
    }
    <div class="tree-root">
        @if (!loading && states.Count == 0)
        {
            <div class="loading-state muted">No jurisdictions found — run <a href="/setup">Setup → Import Jurisdictions</a> to populate.</div>
        }
        @foreach (var state in states)
        {
            @if (IsStateSubscribed(state.StateCode))
            {
            <!-- ── State row (subscribed) ── -->
            <div class="jnode state-node" @onclick="() => ToggleState(state.Id)">
                <span class="expand-icon">@(IsExpanded(state.Id) ? "▼" : "▶")</span>
                <span class="tier-badge tier-state">State</span>
                <span class="jname">@state.Name</span>
                <span class="fips mono">(FIPS: @state.FipsCode)</span>
                <span class="jnode-spacer"></span>
                @RangeDisplay(state)
            </div>

            @if (IsExpanded(state.Id))
            {
                <!-- State detail: rate editor + evidence -->
                <div class="jnode-detail state-detail">
                    @DetailPanel(state)
                </div>

                <!-- County children -->
                @if (!children.ContainsKey(state.Id))
                {
                    <div class="loading-child muted">Loading counties…</div>
                }
                else
                {
                    @foreach (var county in children[state.Id])
                    {
                        <!-- ── County row ── -->
                        <div class="jnode county-node" @onclick="() => ToggleCounty(county.Id)">
                            <span class="expand-icon">@(IsExpanded(county.Id) ? "▼" : "▶")</span>
                            <span class="tier-badge tier-county">County</span>
                            <span class="jname">@county.Name</span>
                            <span class="fips mono">(FIPS: @county.FipsCode)</span>
                            <span class="jnode-spacer"></span>
                            @RangeDisplay(county)
                        </div>

                        @if (IsExpanded(county.Id))
                        {
                            <!-- County detail: rate editor + evidence -->
                            <div class="jnode-detail county-detail">
                                @DetailPanel(county)
                            </div>

                            <!-- City children -->
                            @if (!children.ContainsKey(county.Id))
                            {
                                <div class="loading-child muted">Loading cities…</div>
                            }
                            else
                            {
                                @foreach (var city in children[county.Id])
                                {
                                    <!-- ── City row ── -->
                                    <div class="jnode city-node" @onclick="() => ToggleCity(city.Id)">
                                        <span class="expand-icon">@(IsExpanded(city.Id) ? "▼" : "▶")</span>
                                        <span class="tier-badge tier-city">City</span>
                                        <span class="jname">@city.Name</span>
                                        <span class="fips mono">(FIPS: @city.FipsCode)</span>
                                        <span class="jnode-spacer"></span>
                                        @RangeDisplay(city)
                                    </div>

                                    @if (IsExpanded(city.Id))
                                    {
                                        <!-- City detail: rate editor + combined + evidence -->
                                        <div class="jnode-detail city-detail">
                                            @DetailPanel(city, showCombined: true)
                                        </div>
                                    }
                                }
                            }
                        }
                    }
                }
            }
            }
            else
            {
            <!-- ── State row (locked / not subscribed) ── -->
            <div class="jnode state-node state-node-locked">
                <span class="expand-spacer"></span>
                <span class="tier-badge tier-state">State</span>
                <span class="jname">@state.Name</span>
                <span class="fips mono">(FIPS: @state.FipsCode)</span>
                <span class="jnode-spacer"></span>
                <a href="/subscribe" class="subscribe-state-link" @onclick:stopPropagation="true">Modify subscription →</a>
            </div>
            }
        }
    </div>
</div>

<!-- ── Toast notification ────────────────────────────────────────────────────── -->
@if (status is not null)
{
    <div class="toast @(status!.StartsWith("✗") ? "toast-err" : "toast-ok")">@status</div>
}

<!-- ── Export spinner overlay ────────────────────────────────────────────────── -->
@if (exporting)
{
    <div class="export-overlay">
        <div class="export-spinner-card">
            <div class="spinner"></div>
            <span>Building export…</span>
        </div>
    </div>
}

<!-- ── Evidence reader modal ─────────────────────────────────────────────────── -->
@if (evidenceReaderFile != null)
{
    <div class="evidence-reader-backdrop" id="evidence-reader-overlay">
        <div class="evidence-reader-modal">
            <div class="evidence-reader-header">
                <span class="ev-icon">@FileIcon(evidenceReaderFile.EvidenceType)</span>
                <span class="evidence-reader-breadcrumb">
                    <span class="evidence-reader-jurisdiction">@evidenceReaderJurisdiction</span>
                    <span class="evidence-reader-sep"> › </span>
                    <span class="evidence-reader-filename">@EvidenceDisplayName(evidenceReaderFile)</span>
                </span>
                <button class="evidence-reader-close" @onclick="CloseEvidenceReader" title="Close">✕</button>
            </div>
            <div class="evidence-reader-body" id="evidence-reader-body">
                @if (evidenceReaderLoading)
                {
                    <div class="evidence-reader-loading">
                        <div class="spinner"></div>
                        <span>Loading…</span>
                    </div>
                }
                else if (evidenceReaderContent != null)
                {
                    @if (IsUrl(evidenceReaderContent.Trim()))
                    {
                        <div class="evidence-url-view">
                            <p class="muted small">This evidence links to an external source:</p>
                            <p class="evidence-url-value">@evidenceReaderContent.Trim()</p>
                            <a href="@evidenceReaderContent.Trim()" target="_blank" rel="noopener noreferrer" class="btn-primary">
                                Open in Browser →
                            </a>
                        </div>
                    }
                    else
                    {
                        <pre class="evidence-reader-text">@evidenceReaderContent</pre>
                    }
                }
                else if (evidenceReaderFile.EvidenceType == "xlsx")
                {
                    <div class="evidence-reader-nopreview">
                        <span style="font-size:2rem">📊</span>
                        <p>Spreadsheet preview is not available.</p>
                    </div>
                }
                else
                {
                    <iframe src="/evidence/@evidenceReaderFile.FileName"
                            class="evidence-reader-frame"
                            id="evidence-reader-frame"
                            allow="fullscreen"
                            referrerpolicy="no-referrer">
                    </iframe>
                }
            </div>
        </div>
    </div>
}

<!-- ── Add Evidence modal ────────────────────────────────────────────────────── -->
@if (evidenceModalOpen && evidenceModalNode != null)
{
    <div class="evidence-modal-backdrop" @onclick="CloseEvidenceModal">
        <div class="evidence-modal-panel" @onclick:stopPropagation="true">
            <div class="evidence-modal-header">
                <span>Add Evidence — <strong>@evidenceModalNode.Name</strong> › @evidenceModalRateRowName</span>
                <button class="evidence-reader-close" @onclick="CloseEvidenceModal" title="Close">✕</button>
            </div>
            <div class="evidence-modal-body">
                <div class="ev-upload-tabs">
                    <button class='ev-upload-tab @(evidenceModalTab == "file" ? "ev-upload-tab-active" : "")' @onclick='() => evidenceModalTab = "file"'>📎 File</button>
                    <button class='ev-upload-tab @(evidenceModalTab == "url"  ? "ev-upload-tab-active" : "")' @onclick='() => evidenceModalTab = "url"'>🔗 URL</button>
                    <button class='ev-upload-tab @(evidenceModalTab == "raw"  ? "ev-upload-tab-active" : "")' @onclick='() => evidenceModalTab = "raw"'>📝 Raw Text</button>
                </div>
                @if (evidenceModalTab == "file")
                {
                    <div class="drop-zone @(ModalDropDragging ? "drop-zone-active" : "")"
                         @ondragenter="OnModalDragEnter"
                         @ondragleave="OnModalDragLeave"
                         @ondrop="OnModalDrop"
                         @ondragover:preventDefault="true">
                        <span class="dz-icon">⬆</span>
                        <span class="dz-text">Drop files here or click to browse</span>
                        <span class="dz-hint">.pdf · .txt · .csv · .html · .xlsx · .json</span>
                        <InputFile OnChange="OnModalFileChange"
                                   accept=".pdf,.txt,.csv,.html,.xlsx,.json"
                                   multiple class="dz-input" />
                    </div>
                }
                else if (evidenceModalTab == "url")
                {
                    <div class="ev-upload-url-row">
                        <input class="ev-url-input" type="text"
                               placeholder="https://tax.state.gov/…"
                               value="@evidenceModalUrl"
                               @oninput="e => evidenceModalUrl = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnUrlKeyDown" />
                        <button class="btn-primary" @onclick="AddUrlToQueue"
                                disabled="@string.IsNullOrWhiteSpace(evidenceModalUrl)">Add</button>
                    </div>
                }
                else
                {
                    <div class="ev-upload-raw">
                        <textarea class="ev-raw-textarea" rows="5"
                                  placeholder="Paste notes, excerpts, or any text…"
                                  value="@evidenceModalRaw"
                                  @oninput="e => evidenceModalRaw = e.Value?.ToString() ?? string.Empty"></textarea>
                        <button class="btn-primary" style="font-size:.82rem;align-self:flex-end"
                                @onclick="AddRawToQueue"
                                disabled="@string.IsNullOrWhiteSpace(evidenceModalRaw)">Add</button>
                    </div>
                }
                @if (stagedItems.Count > 0)
                {
                    <div class="ev-queue">
                        <div class="ev-queue-header">Queued (@stagedItems.Count)</div>
                        <ul class="ev-queue-list">
                            @foreach (var (item, idx) in stagedItems.Select((x, i) => (x, i)))
                            {
                                <li class="ev-queue-item">
                                    <span class="ev-icon">@QueueItemIcon(item)</span>
                                    <span class="ev-queue-name">@item.DisplayName</span>
                                    <button class="btn-danger-tiny" @onclick="() => stagedItems.RemoveAt(idx)" title="Remove">✕</button>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
            <div class="evidence-modal-footer">
                <button class="btn-secondary" @onclick="CloseEvidenceModal">Cancel</button>
                <button class="btn-primary" @onclick="SaveAllStaged"
                        disabled="@(stagedItems.Count == 0 || savingStaged)">
                    @(savingStaged ? "Saving…" : $"Add Evidence ({stagedItems.Count})")
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Data model ─────────────────────────────────────────────────────────────
    private sealed record EvidenceFile(int Id, string FileName, string OriginalFileName, string EvidenceType, string SourceUrl, string RawContent, string SourceType, string FetchedAt);

    private sealed record RateRow(
        int Id, string Name, decimal Rate, RateBasis Basis, string Unit,
        SaleContext SaleContext, RemittancePoint RemittancePoint,
        decimal? MinAbv, decimal? MaxAbv, string Conditions,
        string StatutoryReference, string EffectiveDate, string ExpirationDate,
        List<EvidenceFile> Evidence);

    private sealed class StagedItem
    {
        public string Kind { get; init; } = ""; // "file" | "url" | "raw"
        public IBrowserFile? File { get; init; }
        public string Text { get; init; } = "";
        public string DisplayName { get; init; } = "";
    }
    private sealed record JNode(int Id, string Name, string StateCode, string FipsCode,
        JurisdictionType Tier, List<RateRow> Rates,
        decimal ParentCumulative = 0,
        decimal? MinCumulative = null,
        decimal? MaxCumulative = null);
    private sealed record CategoryItem(int Id, string Name, string TopLevelType, int? ParentId, bool IsLeaf, int SortOrder);

    private static decimal NodePctSum(JNode node) =>
        node.Rates.Where(r => r.Basis == RateBasis.Percentage).Sum(r => r.Rate);

    // ── State ──────────────────────────────────────────────────────────────────
    private bool loading = true;
    private bool scraping;
    private bool exporting;
    private string exportFormat = "";
    private bool isAdmin;
    private HashSet<string> subscribedStateCodes = new(StringComparer.OrdinalIgnoreCase);

    private HashSet<int> subscribedCategoryIds = new();
    private int totalCategoryCount;

    private bool isSubscribed => isAdmin || subscribedStateCodes.Count > 0;
    private bool IsStateSubscribed(string stateCode) =>
        isAdmin || IsGuestMode || subscribedStateCodes.Contains(stateCode);
    private bool IsGuestMode => !isAdmin && subscribedStateCodes.Count == 0;
    private bool HasUnsubscribedContent =>
        (subscribedStateCodes.Count < states.Count && states.Count > 0) ||
        (subscribedCategoryIds.Count < totalCategoryCount && totalCategoryCount > 0);
    private string? status;
    private int? manualRunId;

    private List<JNode> states = [];
    private readonly Dictionary<int, List<JNode>> children = new();
    private readonly HashSet<int> expanded = new();

    // Rate row form
    private int? rateFormNodeId;
    private int? rateFormRowId;
    private string rateFormName = "";
    private string rateFormRate = "0.000";
    private RateBasis rateFormBasis = RateBasis.Percentage;
    private string rateFormUnit = "";
    private SaleContext rateFormSaleContext = SaleContext.Any;
    private RemittancePoint rateFormRemittance = RemittancePoint.Retailer;
    private string rateFormMinAbv = "";
    private string rateFormMaxAbv = "";
    private string rateFormStatutory = "";
    private string rateFormEffective = "";
    private string rateFormExpires = "";
    private string rateFormConditions = "";
    private bool savingRateForm;
    private readonly HashSet<int> rateEvidenceExpanded = new();

    // Add Evidence modal
    private bool evidenceModalOpen;
    private JNode? evidenceModalNode;
    private int? evidenceModalRateRowId;
    private string evidenceModalRateRowName = "";
    private string evidenceModalTab = "file";
    private string evidenceModalUrl = "";
    private string evidenceModalRaw = "";
    private readonly List<StagedItem> stagedItems = new();
    private bool savingStaged;
    private int modalDropDepth;
    private bool ModalDropDragging => modalDropDepth > 0;

    // Category picker
    private string selectedTopLevel = "Goods";
    private int? selectedCategoryId;
    private List<CategoryItem> allCategories = [];

    private List<(string GroupName, List<CategoryItem> Leaves)> categoryGroups =>
        allCategories
            .Where(c => c.TopLevelType == selectedTopLevel && !c.IsLeaf && c.ParentId != null)
            .OrderBy(c => c.SortOrder)
            .Select(g => (g.Name, allCategories.Where(c => c.ParentId == g.Id && c.IsLeaf).OrderBy(c => c.SortOrder).ToList()))
            .Where(g => g.Item2.Count > 0)
            .ToList();

    // ── Init ───────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = auth.User.IsInRole("Administrator");

        await using var db = await DbFactory.CreateDbContextAsync();

        if (!isAdmin && auth.User.Identity?.IsAuthenticated == true)
        {
            var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (userId != null)
            {
                var codes = await db.SubscribedStates
                    .Where(ss => ss.Subscriber.UserId == userId && ss.IsActive)
                    .Select(ss => ss.StateCode)
                    .ToListAsync();
                subscribedStateCodes = new HashSet<string>(codes, StringComparer.OrdinalIgnoreCase);

                var catIds = await db.SubscribedCategories
                    .Where(sc => sc.Subscriber.UserId == userId && sc.IsActive)
                    .Select(sc => sc.CategoryId)
                    .ToListAsync();
                subscribedCategoryIds = new HashSet<int>(catIds);
            }
        }

        allCategories = await db.TaxCategories
            .OrderBy(c => c.SortOrder)
            .Select(c => new CategoryItem(c.Id, c.Name, c.TopLevelType, c.ParentId, c.IsLeaf, c.SortOrder))
            .ToListAsync();

        totalCategoryCount = allCategories.Count(c => c.IsLeaf);

        var leafCategories = categoryGroups.SelectMany(g => g.Leaves).ToList();
        var firstAccessible = isAdmin || IsGuestMode
            ? leafCategories.FirstOrDefault()
            : leafCategories.FirstOrDefault(c => subscribedCategoryIds.Contains(c.Id))
              ?? leafCategories.FirstOrDefault();
        selectedCategoryId = firstAccessible?.Id;

        states = await BuildNodes(db, JurisdictionType.State, parentType: JurisdictionType.Country);
        loading = false;
    }

    private async Task OnTopLevelClick(string topLevel)
    {
        if (selectedTopLevel == topLevel) return;
        selectedTopLevel = topLevel;
        StateHasChanged();
        var first = categoryGroups.SelectMany(g => g.Leaves).FirstOrDefault();
        if (first != null)
            await SelectCategory(first.Id);
    }

    private async Task SelectCategory(int categoryId)
    {
        if (selectedCategoryId == categoryId) return;
        selectedCategoryId = categoryId;
        loading = true;
        children.Clear();
        expanded.Clear();
        rateFormNodeId = null;
        rateFormRowId = null;
        rateEvidenceExpanded.Clear();
        StateHasChanged();
        await using var db = await DbFactory.CreateDbContextAsync();
        states = await BuildNodes(db, JurisdictionType.State, parentType: JurisdictionType.Country);
        loading = false;
    }

    private async Task<List<JNode>> BuildNodes(AppDbContext db, JurisdictionType type,
        JurisdictionType parentType = default, int? parentId = null, decimal parentCumulative = 0)
    {
        IQueryable<Jurisdiction> q = db.Jurisdictions.Where(j => j.JurisdictionType == type && j.IsActive);

        if (parentId.HasValue)
            q = q.Where(j => j.ParentId == parentId);
        else
            q = q.Where(j => db.Jurisdictions.Any(p => p.JurisdictionType == parentType && p.Id == j.ParentId));

        var jurisdictions = await q.OrderBy(j => j.JurisdictionName).ToListAsync();

        if (!isSubscribed)
        {
            return jurisdictions.Select(j =>
            {
                var fakeRate = type switch
                {
                    JurisdictionType.State  => 0.03m  + (j.Id % 70) * 0.001m,
                    JurisdictionType.County => 0.010m + (j.Id % 30) * 0.0005m,
                    _                       => 0.003m + (j.Id % 25) * 0.0002m
                };
                var fakeCum = parentCumulative + fakeRate;
                var fakeEvidence = new List<EvidenceFile>
                {
                    new(-j.Id, "revenue-schedule.pdf", "Revenue Schedule 2024.pdf", "pdf", "", "", "GovernmentPublication", "2024-11-01T00:00:00Z")
                };
                var fakeRow = new RateRow(-(j.Id), "General Sales Tax", fakeRate, RateBasis.Percentage,
                    "", SaleContext.Any, RemittancePoint.Retailer, null, null, "", "", "2024-01-01", "", fakeEvidence);
                return new JNode(j.Id, j.JurisdictionName, j.StateCode, j.FipsCode, type,
                    [fakeRow], parentCumulative, fakeCum, fakeCum + (j.Id % 5) * 0.002m);
            }).ToList();
        }

        var ids = jurisdictions.Select(j => j.Id).ToList();

        var subscribedIds = (!isAdmin && subscribedStateCodes.Count > 0 && type == JurisdictionType.State)
            ? jurisdictions.Where(j => subscribedStateCodes.Contains(j.StateCode)).Select(j => j.Id).ToList()
            : ids;

        var catId = selectedCategoryId;
        var rates = await db.TaxRates
            .Where(r => subscribedIds.Contains(r.JurisdictionId) && r.IsCurrent && r.TaxCategoryId == catId)
            .Select(r => new { r.JurisdictionId, r.Rate, r.Id, r.Name, r.RateBasis, r.Unit,
                r.SaleContext, r.RemittancePoint, r.MinAbv, r.MaxAbv, r.Conditions,
                r.StatutoryReference,
                EffectiveDate = r.EffectiveDate != null ? r.EffectiveDate.Value.ToString() : "",
                ExpirationDate = r.ExpirationDate != null ? r.ExpirationDate.Value.ToString() : "" })
            .ToListAsync();

        var rateIds = rates.Select(r => r.Id).ToList();

        var docs = await db.SourceDocuments
            .Where(d => rateIds.Contains(d.TaxRateId) && d.IsActive)
            .Select(d => new { d.TaxRateId, d.Id, d.FileName, d.OriginalFileName, d.EvidenceType, d.SourceUrl, d.RawContent, d.SourceType, d.FetchedAt })
            .ToListAsync();

        var docMap = docs.GroupBy(d => d.TaxRateId).ToDictionary(g => g.Key, g => g.ToList());

        var ratesByJurisdiction = rates
            .GroupBy(r => r.JurisdictionId)
            .ToDictionary(g => g.Key, g => g
                .Select(r => new RateRow(r.Id, r.Name, r.Rate, r.RateBasis, r.Unit,
                    r.SaleContext, r.RemittancePoint, r.MinAbv, r.MaxAbv, r.Conditions,
                    r.StatutoryReference, r.EffectiveDate, r.ExpirationDate,
                    docMap.GetValueOrDefault(r.Id, [])
                        .Select(d => new EvidenceFile(d.Id, d.FileName, d.OriginalFileName,
                            d.EvidenceType, d.SourceUrl, d.RawContent, d.SourceType.ToString(), d.FetchedAt))
                        .ToList()))
                .ToList());

        // Compute child ranges
        Dictionary<int, (decimal Min, decimal Max)> subRangeMap = [];
        if (type == JurisdictionType.State && subscribedIds.Count > 0)
            subRangeMap = await ComputeStateSubRangesAsync(db, subscribedIds);
        else if (type == JurisdictionType.County && ids.Count > 0)
            subRangeMap = await ComputeCountySubRangesAsync(db, ids);

        return jurisdictions.Select(j =>
        {
            var nodeRates = ratesByJurisdiction.GetValueOrDefault(j.Id, []);
            var myRate = nodeRates.Where(r => r.Basis == RateBasis.Percentage).Sum(r => r.Rate);
            decimal? minCum = null, maxCum = null;

            if (type == JurisdictionType.State)
            {
                if (subRangeMap.TryGetValue(j.Id, out var sr))
                { minCum = myRate + sr.Min; maxCum = myRate + sr.Max; }
                else
                { minCum = maxCum = myRate; }
            }
            else if (type == JurisdictionType.County)
            {
                if (subRangeMap.TryGetValue(j.Id, out var cr))
                { minCum = parentCumulative + myRate + cr.Min; maxCum = parentCumulative + myRate + cr.Max; }
                else
                { minCum = maxCum = parentCumulative + myRate; }
            }
            else if (type == JurisdictionType.City)
            {
                minCum = maxCum = parentCumulative + myRate;
            }

            return new JNode(j.Id, j.JurisdictionName, j.StateCode, j.FipsCode, type,
                nodeRates, parentCumulative, minCum, maxCum);
        }).ToList();
    }

    // ── Range computation helpers ──────────────────────────────────────────────
    private async Task<Dictionary<int, (decimal Min, decimal Max)>> ComputeStateSubRangesAsync(
        AppDbContext db, List<int> stateIds)
    {
        var catId = selectedCategoryId;
        var counties = await db.Jurisdictions
            .Where(co => co.JurisdictionType == JurisdictionType.County && co.IsActive
                         && co.ParentId.HasValue && stateIds.Contains(co.ParentId.Value))
            .Select(co => new
            {
                CountyId = co.Id,
                StateId = co.ParentId!.Value,
                Rate = (decimal?)db.TaxRates
                    .Where(r => r.JurisdictionId == co.Id && r.IsCurrent && r.TaxCategoryId == catId && r.RateBasis == RateBasis.Percentage)
                    .Sum(r => (decimal?)r.Rate) ?? 0m
            })
            .ToListAsync();

        if (counties.Count == 0) return [];

        var countyIds = counties.Select(c => c.CountyId).ToList();

        var cities = await db.Jurisdictions
            .Where(ci => ci.JurisdictionType == JurisdictionType.City && ci.IsActive
                         && ci.ParentId.HasValue && countyIds.Contains(ci.ParentId.Value))
            .Select(ci => new
            {
                CountyId = ci.ParentId!.Value,
                Rate = (decimal?)db.TaxRates
                    .Where(r => r.JurisdictionId == ci.Id && r.IsCurrent && r.TaxCategoryId == catId && r.RateBasis == RateBasis.Percentage)
                    .Sum(r => (decimal?)r.Rate) ?? 0m
            })
            .ToListAsync();

        var cityByCounty = cities
            .GroupBy(c => c.CountyId)
            .ToDictionary(g => g.Key, g => (
                Min: g.Min(c => c.Rate),
                Max: g.Max(c => c.Rate)));

        return counties
            .GroupBy(c => c.StateId)
            .ToDictionary(g => g.Key, g =>
            {
                var all = g.SelectMany(co =>
                {
                    var cr = co.Rate;
                    return cityByCounty.TryGetValue(co.CountyId, out var city)
                        ? new[] { cr + city.Min, cr + city.Max }
                        : new[] { cr };
                }).ToList();
                return all.Count > 0
                    ? (Min: all.Min(), Max: all.Max())
                    : (Min: 0m, Max: 0m);
            });
    }

    private async Task<Dictionary<int, (decimal Min, decimal Max)>> ComputeCountySubRangesAsync(
        AppDbContext db, List<int> countyIds)
    {
        var catId = selectedCategoryId;
        var cities = await db.Jurisdictions
            .Where(ci => ci.JurisdictionType == JurisdictionType.City && ci.IsActive
                         && ci.ParentId.HasValue && countyIds.Contains(ci.ParentId.Value))
            .Select(ci => new
            {
                CountyId = ci.ParentId!.Value,
                Rate = (decimal?)db.TaxRates
                    .Where(r => r.JurisdictionId == ci.Id && r.IsCurrent && r.TaxCategoryId == catId && r.RateBasis == RateBasis.Percentage)
                    .Sum(r => (decimal?)r.Rate) ?? 0m
            })
            .ToListAsync();

        return cities
            .GroupBy(c => c.CountyId)
            .ToDictionary(g => g.Key, g => (
                Min: g.Min(c => c.Rate),
                Max: g.Max(c => c.Rate)));
    }

    // ── Expand / collapse ─────────────────────────────────────────────────────
    private bool IsExpanded(int id) => expanded.Contains(id);

    private async Task ToggleState(int stateId)
    {
        if (!expanded.Add(stateId)) { expanded.Remove(stateId); return; }
        if (!children.ContainsKey(stateId))
        {
            var stateNode = states.FirstOrDefault(s => s.Id == stateId);
            await using var db = await DbFactory.CreateDbContextAsync();
            children[stateId] = await BuildNodes(db, JurisdictionType.County, parentId: stateId,
                parentCumulative: stateNode is null ? 0m : NodePctSum(stateNode));
        }
    }

    private async Task ToggleCounty(int countyId)
    {
        if (!expanded.Add(countyId)) { expanded.Remove(countyId); return; }
        if (!children.ContainsKey(countyId))
        {
            var countyNode = children.Values.SelectMany(l => l).FirstOrDefault(n => n.Id == countyId);
            var parentCum = (countyNode?.ParentCumulative ?? 0m) + (countyNode is null ? 0m : NodePctSum(countyNode));
            await using var db = await DbFactory.CreateDbContextAsync();
            children[countyId] = await BuildNodes(db, JurisdictionType.City, parentId: countyId,
                parentCumulative: parentCum);
        }
    }

    private void ToggleCity(int cityId)
    {
        if (!expanded.Add(cityId)) expanded.Remove(cityId);
    }

    // ── Detail panel (1:M rate rows table) ───────────────────────────────────
    private RenderFragment DetailPanel(JNode node, bool showCombined = false) => __builder =>
    {
        <div @onclick:stopPropagation="true">
            <div class="detail-rates-header">
                <span class="detail-label">Rate Laws</span>
                @if (showCombined && (node.MinCumulative ?? 0) > 0)
                {
                    <span class="combined-pill" title="State + County + City combined">
                        ∑ @((node.MinCumulative!.Value * 100).ToString("F3"))%
                    </span>
                }
                @if (isAdmin && rateFormNodeId != node.Id)
                {
                    <button class="btn-primary" @onclick="() => StartAddRate(node.Id)">+ Add Rate Law</button>
                }
            </div>

            @* Inline add/edit form *@
            @if (rateFormNodeId == node.Id)
            {
                <div class="rate-row-form">
                    <div class="rate-form-grid">
                        <label class="rate-form-name">Name<input class="filter-input" @bind="rateFormName" placeholder="e.g. General Sales Tax" /></label>
                        <label>Basis
                            <select class="filter-select" @bind="rateFormBasis">
                                @foreach (var b in Enum.GetValues<RateBasis>())
                                { <option value="@b">@b</option> }
                            </select>
                        </label>
                        <label>Rate
                            <input class="filter-input rate-input" type="number" step="0.0001" min="0"
                                   @bind="rateFormRate"
                                   placeholder="@(rateFormBasis == RateBasis.Percentage ? "e.g. 6.25 (%)" : "e.g. 0.231")" />
                        </label>
                        <label>Unit<input class="filter-input" @bind="rateFormUnit" placeholder="per pack / per liter…" /></label>
                        <label>Sale Context
                            <select class="filter-select" @bind="rateFormSaleContext">
                                @foreach (var s in Enum.GetValues<SaleContext>())
                                { <option value="@s">@s</option> }
                            </select>
                        </label>
                        <label>Remittance
                            <select class="filter-select" @bind="rateFormRemittance">
                                @foreach (var r in Enum.GetValues<RemittancePoint>())
                                { <option value="@r">@r</option> }
                            </select>
                        </label>
                        <label>Statutory Ref<input class="filter-input" @bind="rateFormStatutory" placeholder="e.g. 235 ILCS 5/8-1" /></label>
                        <label>Effective<input class="filter-input" type="text" placeholder="yyyy-MM-dd" @bind="rateFormEffective" /></label>
                        <label>Expires<input class="filter-input" type="text" placeholder="yyyy-MM-dd (opt)" @bind="rateFormExpires" /></label>
                        <label>Min ABV<input class="filter-input" type="number" step="0.01" @bind="rateFormMinAbv" placeholder="%" /></label>
                        <label>Max ABV<input class="filter-input" type="number" step="0.01" @bind="rateFormMaxAbv" placeholder="%" /></label>
                        <label class="rate-form-full">Conditions<input class="filter-input" @bind="rateFormConditions" /></label>
                    </div>
                    <div class="rate-form-actions">
                        <button class="btn-primary" @onclick="SaveRateRow" disabled="@savingRateForm">
                            @(savingRateForm ? "Saving…" : (rateFormRowId.HasValue ? "Update" : "Add"))
                        </button>
                        <button class="btn-secondary" @onclick="CancelRateForm">Cancel</button>
                    </div>
                </div>
            }

            @* Rate rows table *@
            @if (node.Rates.Count == 0 && rateFormNodeId != node.Id)
            {
                <p class="muted small">No rate laws recorded. @(isAdmin ? "Click \"+ Add Rate Law\" to add one." : "")</p>
            }
            else
            {
                <div class="rate-rows-list">
                    @foreach (var row in node.Rates)
                    {
                        <div class="rate-row-item">
                            <div class="rate-row-main">
                                <span class="rate-row-name">@row.Name</span>
                                <span class="rate-row-value">@FormatRateRowValue(row)</span>
                                @if (!string.IsNullOrEmpty(row.SaleContext.ToString()) && row.SaleContext != SaleContext.Any)
                                { <span class="rate-row-badge">@row.SaleContext</span> }
                                @if (row.RemittancePoint != RemittancePoint.Retailer)
                                { <span class="rate-row-badge badge-remit">@row.RemittancePoint</span> }
                                @if (!string.IsNullOrEmpty(row.StatutoryReference))
                                { <span class="rate-row-cite muted small" title="Statutory reference">@row.StatutoryReference</span> }
                                <span class="rate-row-spacer"></span>
                                @{
                                    var evCount = row.Evidence.Count;
                                    var evExpanded = rateEvidenceExpanded.Contains(row.Id);
                                }
                                <button class="evidence-badge @(evExpanded ? "evidence-hide" : evCount > 0 ? "evidence-ok" : "evidence-missing")"
                                        @onclick="() => ToggleRateEvidence(row.Id)"
                                        title="@(evExpanded ? "Hide evidence" : evCount > 0 ? $"{evCount} evidence file(s)" : "Add evidence")">
                                    @(evExpanded ? "▲ Hide" : evCount > 0 ? $"📎 {evCount}" : isAdmin ? "＋ Evidence" : "—")
                                </button>
                                @if (isAdmin && row.Id > 0)
                                {
                                    <button class="btn-tiny" @onclick="() => StartEditRate(node, row)" title="Edit">✎</button>
                                    <button class="btn-danger-tiny" @onclick="() => DeleteRateRow(node.Id, row.Id)" title="Delete rate law">✕</button>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(row.Conditions))
                            { <div class="rate-row-conditions muted small">@row.Conditions</div> }
                            @if (row.MinAbv.HasValue || row.MaxAbv.HasValue)
                            { <div class="rate-row-abv muted small">ABV: @(row.MinAbv?.ToString("F1") ?? "0")% – @(row.MaxAbv?.ToString("F1") ?? "∞")%</div> }
                            @if (evExpanded)
                            {
                                <div class="rate-row-evidence-panel">
                                    @if (row.Evidence.Count == 0)
                                    { <p class="muted small">No evidence attached yet.</p> }
                                    else
                                    {
                                        <ul class="detail-evidence-list">
                                            @foreach (var f in row.Evidence)
                                            {
                                                <li class="evidence-item">
                                                    <span class="ev-icon">@FileIcon(f.EvidenceType)</span>
                                                    <button class="ev-name ev-name-btn" @onclick="() => OpenEvidenceReader(node, f)">@EvidenceDisplayName(f)</button>
                                                    <span class="ev-type muted small">@f.SourceType</span>
                                                    <span class="ev-date muted small">@(f.FetchedAt?.Length >= 10 ? f.FetchedAt[..10] : f.FetchedAt ?? "")</span>
                                                    @if (isAdmin && f.Id > 0)
                                                    {
                                                        <button class="btn-danger-tiny" @onclick="() => DisassociateEvidence(node, f.Id)" title="Disassociate">✕</button>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (isAdmin && row.Id > 0)
                                    {
                                        <button class="btn-primary" style="margin-top:.5rem"
                                                @onclick="() => OpenEvidenceModal(node, row.Id, row.Name)">+ Add Evidence</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    };

    private void ToggleRateEvidence(int rateRowId)
    {
        if (!rateEvidenceExpanded.Add(rateRowId)) rateEvidenceExpanded.Remove(rateRowId);
    }

    private static string FormatRateRowValue(RateRow row) => row.Basis switch
    {
        RateBasis.Percentage => $"{row.Rate * 100:F3}%",
        _ => $"${row.Rate:F4} {row.Unit}".Trim()
    };

    private void ShowCategoryLockedHint() =>
        SetStatus("✗ Subscribe to this product category to view rates — Adjust subscription →");

    // ── Rate row CRUD ─────────────────────────────────────────────────────────
    private void StartAddRate(int nodeId)
    {
        rateFormNodeId = nodeId;
        rateFormRowId = null;
        rateFormName = "General Sales Tax";
        rateFormRate = "0.000";
        rateFormBasis = RateBasis.Percentage;
        rateFormUnit = "";
        rateFormSaleContext = SaleContext.Any;
        rateFormRemittance = RemittancePoint.Retailer;
        rateFormMinAbv = rateFormMaxAbv = rateFormStatutory = rateFormConditions = rateFormExpires = "";
        rateFormEffective = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    }

    private void StartEditRate(JNode node, RateRow row)
    {
        rateFormNodeId = node.Id;
        rateFormRowId = row.Id;
        rateFormName = row.Name;
        rateFormRate = row.Basis == RateBasis.Percentage ? $"{row.Rate * 100:F4}" : row.Rate.ToString("F4");
        rateFormBasis = row.Basis;
        rateFormUnit = row.Unit;
        rateFormSaleContext = row.SaleContext;
        rateFormRemittance = row.RemittancePoint;
        rateFormMinAbv = row.MinAbv?.ToString() ?? "";
        rateFormMaxAbv = row.MaxAbv?.ToString() ?? "";
        rateFormStatutory = row.StatutoryReference;
        rateFormEffective = row.EffectiveDate;
        rateFormExpires = row.ExpirationDate;
        rateFormConditions = row.Conditions;
    }

    private void CancelRateForm()
    {
        rateFormNodeId = null;
        rateFormRowId = null;
    }

    private async Task SaveRateRow()
    {
        if (!isAdmin) { SetStatus("✗ Sign in to edit rates"); return; }
        if (rateFormNodeId is null) return;
        if (string.IsNullOrWhiteSpace(rateFormName)) { SetStatus("✗ Rate name is required"); return; }
        if (!decimal.TryParse(rateFormRate, out var rateVal)) { SetStatus("✗ Invalid rate value"); return; }
        if (rateFormBasis == RateBasis.Percentage) rateVal /= 100m;

        savingRateForm = true;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (manualRunId is null)
            {
                var run = await db.ScrapeRuns.FirstOrDefaultAsync(r => r.Status == ScrapeStatus.Manual)
                    ?? new ScrapeRun { StartedAt = DateTime.UtcNow.ToString("o"), CompletedAt = DateTime.UtcNow.ToString("o"), Status = ScrapeStatus.Manual };
                if (run.Id == 0) { db.ScrapeRuns.Add(run); await db.SaveChangesAsync(); }
                manualRunId = run.Id;
            }

            if (rateFormRowId.HasValue)
            {
                var existing = await db.TaxRates.FindAsync(rateFormRowId.Value);
                if (existing is not null)
                {
                    existing.Name = rateFormName.Trim();
                    existing.Rate = rateVal;
                    existing.RateBasis = rateFormBasis;
                    existing.Unit = rateFormUnit.Trim();
                    existing.SaleContext = rateFormSaleContext;
                    existing.RemittancePoint = rateFormRemittance;
                    existing.MinAbv = decimal.TryParse(rateFormMinAbv, out var minA) ? minA : null;
                    existing.MaxAbv = decimal.TryParse(rateFormMaxAbv, out var maxA) ? maxA : null;
                    existing.StatutoryReference = rateFormStatutory.Trim();
                    existing.EffectiveDate = string.IsNullOrWhiteSpace(rateFormEffective) ? null : DateOnly.Parse(rateFormEffective.Trim());
                    existing.ExpirationDate = string.IsNullOrWhiteSpace(rateFormExpires) ? null : DateOnly.Parse(rateFormExpires.Trim());
                    existing.Conditions = rateFormConditions.Trim();
                }
            }
            else
            {
                db.TaxRates.Add(new TaxRate
                {
                    JurisdictionId = rateFormNodeId.Value,
                    TaxCategoryId = selectedCategoryId,
                    Rate = rateVal,
                    Name = rateFormName.Trim(),
                    RateBasis = rateFormBasis,
                    Unit = rateFormUnit.Trim(),
                    SaleContext = rateFormSaleContext,
                    RemittancePoint = rateFormRemittance,
                    MinAbv = decimal.TryParse(rateFormMinAbv, out var minAbv) ? minAbv : null,
                    MaxAbv = decimal.TryParse(rateFormMaxAbv, out var maxAbv) ? maxAbv : null,
                    StatutoryReference = rateFormStatutory.Trim(),
                    EffectiveDate = string.IsNullOrWhiteSpace(rateFormEffective) ? null : DateOnly.Parse(rateFormEffective.Trim()),
                    ExpirationDate = string.IsNullOrWhiteSpace(rateFormExpires) ? null : DateOnly.Parse(rateFormExpires.Trim()),
                    Conditions = rateFormConditions.Trim(),
                    ScrapedAt = DateTime.UtcNow.ToString("o"),
                    ScrapeRunId = manualRunId.Value,
                    RawEvidence = rateFormBasis == RateBasis.Percentage ? $"{rateVal * 100:F3}%" : $"{rateVal:F4} {rateFormUnit}".Trim(),
                    IsCurrent = true
                });
            }

            await db.SaveChangesAsync();
            var nodeId = rateFormNodeId.Value;
            CancelRateForm();
            await RefreshNode(db, nodeId);
            SetStatus("✓ Rate law saved");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { savingRateForm = false; StateHasChanged(); }
    }

    private async Task DeleteRateRow(int nodeId, int rateRowId)
    {
        if (!isAdmin) { SetStatus("✗ Admin access required"); return; }
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var row = await db.TaxRates.FindAsync(rateRowId);
            if (row is not null) { row.IsCurrent = false; await db.SaveChangesAsync(); }
            await RefreshNode(db, nodeId);
            SetStatus("✓ Rate law removed");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        StateHasChanged();
    }

    // ── Range display ──────────────────────────────────────────────────────────
    private RenderFragment RangeDisplay(JNode node) => __builder =>
    {

        if (node.MinCumulative.HasValue)
        {
            var lo = node.MinCumulative.Value * 100m;
            var hi = (node.MaxCumulative ?? node.MinCumulative.Value) * 100m;

            <span class="rate-range">
                @if (Math.Abs(hi - lo) < 0.0005m)
                {
                    <span class="rate-range-single">@lo.ToString("F3")%</span>
                }
                else
                {
                    <span class="rate-range-low">@lo.ToString("F3")%</span>
                    <span class="rate-range-sep"> – </span>
                    <span class="rate-range-high">@hi.ToString("F3")%</span>
                }
            </span>
        }
        else
        {
            <span class="rate-range rate-range-empty">—</span>
        }
    };


    private static string EvidenceDisplayName(EvidenceFile f) =>
        string.IsNullOrEmpty(f.OriginalFileName) ? f.FileName : f.OriginalFileName;

    private static bool IsUrl(string s) =>
        s.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        s.StartsWith("https://", StringComparison.OrdinalIgnoreCase);

    private static string FileIcon(string evidenceType) => evidenceType.ToLowerInvariant() switch
    {
        "pdf"              => "📄",
        "txt" or "raw"     => "📝",
        "csv"              => "📊",
        "html" or "htm"    => "🌐",
        "xlsx" or "xls"    => "📊",
        "json"             => "{ }",
        "url"              => "🔗",
        _                  => "📎"
    };

    private string BuildJurisdictionPath(JNode node)
    {
        if (node.Tier == JurisdictionType.State)
            return node.Name;

        if (node.Tier == JurisdictionType.County)
        {
            var parent = states.FirstOrDefault(s =>
                children.TryGetValue(s.Id, out var counties) && counties.Any(c => c.Id == node.Id));
            return parent != null ? $"{parent.Name} › {node.Name}" : node.Name;
        }

        if (node.Tier == JurisdictionType.City)
        {
            foreach (var state in states)
            {
                if (!children.TryGetValue(state.Id, out var counties)) continue;
                foreach (var county in counties)
                {
                    if (!children.TryGetValue(county.Id, out var cities)) continue;
                    if (cities.Any(c => c.Id == node.Id))
                        return $"{state.Name} › {county.Name} › {node.Name}";
                }
            }
        }

        return node.Name;
    }

    private async Task DisassociateEvidence(JNode node, int docId)
    {
        if (!isAdmin) { SetStatus("✗ Admin access required to remove evidence"); return; }
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var doc = await db.SourceDocuments.FindAsync(docId);
            if (doc is null) return;

            doc.IsActive = false;
            await db.SaveChangesAsync();
            await RefreshNode(db, node.Id);
            SetStatus("✓ Evidence disassociated (record preserved)");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        StateHasChanged();
    }

    // ── Node refresh ──────────────────────────────────────────────────────────
    private async Task RefreshNode(AppDbContext db, int jurisdictionId)
    {
        var catId = selectedCategoryId;
        var rates = await db.TaxRates
            .Where(r => r.JurisdictionId == jurisdictionId && r.IsCurrent && r.TaxCategoryId == catId)
            .Select(r => new { r.Id, r.Name, r.Rate, r.RateBasis, r.Unit, r.SaleContext, r.RemittancePoint,
                r.MinAbv, r.MaxAbv, r.Conditions, r.StatutoryReference,
                EffectiveDate = r.EffectiveDate != null ? r.EffectiveDate.Value.ToString() : "",
                ExpirationDate = r.ExpirationDate != null ? r.ExpirationDate.Value.ToString() : "" })
            .ToListAsync();

        var rateIds = rates.Select(r => r.Id).ToList();
        var docs = await db.SourceDocuments
            .Where(d => rateIds.Contains(d.TaxRateId) && d.IsActive)
            .Select(d => new { d.TaxRateId, d.Id, d.FileName, d.OriginalFileName, d.EvidenceType, d.SourceUrl, d.RawContent, d.SourceType, d.FetchedAt })
            .ToListAsync();
        var docMap = docs.GroupBy(d => d.TaxRateId).ToDictionary(g => g.Key, g => g.ToList());

        var rateRows = rates.Select(r => new RateRow(r.Id, r.Name, r.Rate, r.RateBasis, r.Unit,
            r.SaleContext, r.RemittancePoint, r.MinAbv, r.MaxAbv, r.Conditions,
            r.StatutoryReference, r.EffectiveDate, r.ExpirationDate,
            docMap.GetValueOrDefault(r.Id, [])
                .Select(d => new EvidenceFile(d.Id, d.FileName, d.OriginalFileName, d.EvidenceType, d.SourceUrl, d.RawContent, d.SourceType.ToString(), d.FetchedAt))
                .ToList())).ToList();

        UpdateNodeInplace(jurisdictionId, rateRows);
    }

    private void UpdateNodeInplace(int id, List<RateRow> rates)
    {
        for (int i = 0; i < states.Count; i++)
        {
            if (states[i].Id == id) { states[i] = states[i] with { Rates = rates }; return; }
        }
        foreach (var list in children.Values)
            for (int i = 0; i < list.Count; i++)
                if (list[i].Id == id) { list[i] = list[i] with { Rates = rates }; return; }
    }

    // ── Scrape ────────────────────────────────────────────────────────────────
    private async Task RunScrape()
    {
        if (!isAdmin) { SetStatus("✗ Sign in to run scrape"); return; }
        scraping = true;
        SetStatus(null);
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ScrapeRuns.Add(new ScrapeRun
            {
                StartedAt = DateTime.UtcNow.ToString("o"),
                Status = ScrapeStatus.Pending,
            });
            await db.SaveChangesAsync();
            SetStatus("✓ Scrape queued — see /runs for progress");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { scraping = false; StateHasChanged(); }
    }


