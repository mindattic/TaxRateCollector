        stagedItems.Clear();
    }

    private void CloseEvidenceModal()
    {
        evidenceModalOpen = false;
        evidenceModalNode = null;
        evidenceModalRateRowId = null;
        evidenceModalRateRowName = "";
        stagedItems.Clear();
    }

    private void OnModalDragEnter() => modalDropDepth++;
    private void OnModalDragLeave() { var d = modalDropDepth - 1; modalDropDepth = d < 0 ? 0 : d; }
    private void OnModalDrop() => modalDropDepth = 0;

    private void OnModalFileChange(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(20))
            stagedItems.Add(new StagedItem { Kind = "file", File = file, DisplayName = file.Name });
    }

    private void OnUrlKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddUrlToQueue();
    }

    private void AddUrlToQueue()
    {
        var url = evidenceModalUrl.Trim();
        if (string.IsNullOrEmpty(url)) return;
        var displayName = Uri.TryCreate(url, UriKind.Absolute, out var uri)
            ? $"{uri.Host.Replace("www.", string.Empty)}.txt"
            : "link.txt";
        stagedItems.Add(new StagedItem { Kind = "url", Text = url, DisplayName = displayName });
        evidenceModalUrl = "";
    }

    private void AddRawToQueue()
    {
        var text = evidenceModalRaw.Trim();
        if (string.IsNullOrEmpty(text)) return;
        stagedItems.Add(new StagedItem { Kind = "raw", Text = text, DisplayName = $"Note {DateTime.UtcNow:yyyy-MM-dd HH-mm}.txt" });
        evidenceModalRaw = "";
    }

    private static string QueueItemIcon(StagedItem item) => item.Kind switch
    {
        "url" => "🔗",
        "raw" => "📝",
        _ => FileIcon(Path.GetExtension(item.DisplayName).TrimStart('.'))
    };

    private async Task SaveAllStaged()
    {
        if (evidenceModalNode is null || !evidenceModalRateRowId.HasValue || stagedItems.Count == 0) return;
        savingStaged = true;
        StateHasChanged();

        var node = evidenceModalNode;
        int saved = 0;

        try
        {
            Directory.CreateDirectory(SettingsService.EvidenceDirectory);

            foreach (var item in stagedItems.ToList())
            {
                try
                {
                    if (item.Kind == "file" && item.File != null)
                    {
                        var ext = Path.GetExtension(item.File.Name).ToLowerInvariant();
                        var fileName = $"{Guid.CreateVersion7():N}{ext}";
                        var fullPath = Path.Combine(SettingsService.EvidenceDirectory, fileName);

                        string contentHash;
                        await using (var fs = File.Create(fullPath))
                        await using (var stream = item.File.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024))
                        {
                            using var sha = SHA256.Create();
                            using var cs = new CryptoStream(fs, sha, CryptoStreamMode.Write);
                            await stream.CopyToAsync(cs);
                            cs.FlushFinalBlock();
                            contentHash = Convert.ToHexString(sha.Hash!).ToLowerInvariant();
                        }

                        var mime = ext switch
                        {
                            ".pdf"  => "application/pdf",
                            ".csv"  => "text/csv",
                            ".html" or ".htm" => "text/html",
                            ".json" => "application/json",
                            ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                            _       => "text/plain"
                        };
                        var sourceType = ext switch
                        {
                            ".pdf"  => SourceType.Pdf,
                            ".csv"  => SourceType.Csv,
                            ".html" or ".htm" => SourceType.Website,
                            _       => SourceType.Manual
                        };

                        await using var db = await DbFactory.CreateDbContextAsync();
                        db.SourceDocuments.Add(new SourceDocument
                        {
                            TaxRateId = evidenceModalRateRowId!.Value, SourceType = sourceType,
                            SourceUrl = string.Empty, MimeType = mime,
                            FetchedAt = DateTime.UtcNow.ToString("o"), ContentHash = contentHash,
                            FileName = fileName, OriginalFileName = item.File.Name,
                            EvidenceType = ext.TrimStart('.'), RawContent = string.Empty
                        });
                        await db.SaveChangesAsync();
                        saved++;
                    }
                    else
                    {
                        var bytes = System.Text.Encoding.UTF8.GetBytes(item.Text);
                        var fileName = $"{Guid.CreateVersion7():N}.txt";
                        await File.WriteAllBytesAsync(Path.Combine(SettingsService.EvidenceDirectory, fileName), bytes);

                        using var sha = SHA256.Create();
                        var contentHash = Convert.ToHexString(sha.ComputeHash(bytes)).ToLowerInvariant();

                        await using var db = await DbFactory.CreateDbContextAsync();
                        db.SourceDocuments.Add(new SourceDocument
                        {
                            TaxRateId = evidenceModalRateRowId!.Value, SourceType = SourceType.Manual,
                            SourceUrl = item.Kind == "url" ? item.Text : string.Empty,
                            MimeType = "text/plain", FetchedAt = DateTime.UtcNow.ToString("o"),
                            ContentHash = contentHash, FileName = fileName,
                            OriginalFileName = item.DisplayName, EvidenceType = "txt",
                            RawContent = string.Empty, IsActive = true
                        });
                        await db.SaveChangesAsync();
                        saved++;
                    }
                }
                catch (Exception ex) { SetStatus($"✗ {item.DisplayName}: {ex.Message}"); }
            }

            if (saved > 0)
            {
                await using var db2 = await DbFactory.CreateDbContextAsync();
                await RefreshNode(db2, node.Id);
                SetStatus($"✓ {saved} evidence item{(saved == 1 ? "" : "s")} added");
                CloseEvidenceModal();
            }
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { savingStaged = false; StateHasChanged(); }
    }

    // ── Evidence reader ────────────────────────────────────────────────────────
    private EvidenceFile? evidenceReaderFile;
    private string evidenceReaderJurisdiction = "";
    private string? evidenceReaderContent;
    private bool evidenceReaderLoading;
    private bool pendingReaderOpen;

    private async Task OpenEvidenceReader(JNode node, EvidenceFile file)
    {
        evidenceReaderFile = file;
        evidenceReaderJurisdiction = BuildJurisdictionPath(node);
        evidenceReaderContent = null;
        evidenceReaderLoading = true;
        pendingReaderOpen = false;
        StateHasChanged();

        switch (file.EvidenceType)
        {
            case "txt" or "csv" or "json" or "raw":
                if (file.Id < 0)
                    evidenceReaderContent = BuildFakeEvidenceText(EvidenceDisplayName(file));
                else if (!string.IsNullOrEmpty(file.RawContent))
                    evidenceReaderContent = file.RawContent;
                else
                    evidenceReaderContent = await JS.InvokeAsync<string?>("evidenceReader.fetchText", $"/evidence/{file.FileName}");
                break;
            // "pdf", "html" — shown in iframe below
        }

        evidenceReaderLoading = false;
        pendingReaderOpen = true;
        StateHasChanged();
    }

    private async Task CloseEvidenceReader()
    {
        await JS.InvokeVoidAsync("evidenceReader.close");
        evidenceReaderFile = null;
        evidenceReaderContent = null;
        evidenceReaderLoading = false;
    }

