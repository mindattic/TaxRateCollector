    private static bool IsUrl(string s) =>
        s.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        s.StartsWith("https://", StringComparison.OrdinalIgnoreCase);

    private static string FileIcon(string evidenceType) => evidenceType.ToLowerInvariant() switch
    {
        "pdf"              => "📄",
        "txt" or "raw"     => "📝",
        "csv"              => "📊",
        "html" or "htm"    => "🌐",
        "xlsx" or "xls"    => "📊",
        "json"             => "{ }",
        "url"              => "🔗",
        _                  => "📎"
    };

    private string BuildJurisdictionPath(JNode node)
    {
        if (node.Tier == JurisdictionType.State)
            return node.Name;

        if (node.Tier == JurisdictionType.County)
        {
            var parent = states.FirstOrDefault(s =>
                children.TryGetValue(s.Id, out var counties) && counties.Any(c => c.Id == node.Id));
            return parent != null ? $"{parent.Name} › {node.Name}" : node.Name;
        }

        if (node.Tier == JurisdictionType.City)
        {
            foreach (var state in states)
            {
                if (!children.TryGetValue(state.Id, out var counties)) continue;
                foreach (var county in counties)
                {
                    if (!children.TryGetValue(county.Id, out var cities)) continue;
                    if (cities.Any(c => c.Id == node.Id))
                        return $"{state.Name} › {county.Name} › {node.Name}";
                }
            }
        }

        return node.Name;
    }

    private async Task UploadEvidence(JNode node, InputFileChangeEventArgs e)
    {
        if (!isAdmin) { SetStatus("✗ Admin access required to upload evidence"); return; }
        if (!node.RateId.HasValue || e.FileCount == 0) return;
        uploading = true;
        StateHasChanged();

        try
        {
            Directory.CreateDirectory(SettingsService.EvidenceDirectory);

            foreach (var file in e.GetMultipleFiles(10))
            {
                var ext = Path.GetExtension(file.Name).ToLowerInvariant();
                var fileName = $"{Guid.CreateVersion7():N}{ext}";
                var fullPath = Path.Combine(SettingsService.EvidenceDirectory, fileName);

                string contentHash;
                await using (var fs = File.Create(fullPath))
                await using (var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024))
                {
                    using var sha = SHA256.Create();
                    using var cs = new CryptoStream(fs, sha, CryptoStreamMode.Write);
                    await stream.CopyToAsync(cs);
                    cs.FlushFinalBlock();
                    contentHash = Convert.ToHexString(sha.Hash!).ToLowerInvariant();
                }

                var mime = ext switch
                {
                    ".pdf" => "application/pdf",
                    ".csv" => "text/csv",
                    ".html" or ".htm" => "text/html",
                    ".json" => "application/json",
                    ".xlsx" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                    _ => "text/plain"
                };

                var sourceType = ext switch
                {
                    ".pdf" => SourceType.Pdf,
                    ".csv" => SourceType.Csv,
                    ".html" or ".htm" => SourceType.Website,
                    _ => SourceType.Manual
                };

                await using var db = await DbFactory.CreateDbContextAsync();
                db.SourceDocuments.Add(new SourceDocument
                {
                    TaxRateId = node.RateId.Value,
                    SourceType = sourceType,
                    SourceUrl = string.Empty,
                    MimeType = mime,
                    FetchedAt = DateTime.UtcNow.ToString("o"),
                    ContentHash = contentHash,
                    FileName = fileName,
                    OriginalFileName = file.Name,
                    EvidenceType = ext.TrimStart('.'),
                    RawContent = string.Empty
                });
                await db.SaveChangesAsync();
            }

            await using (var db2 = await DbFactory.CreateDbContextAsync())
                await RefreshNode(db2, node.Id);

            SetStatus("✓ Evidence attached");
        }
        catch (Exception ex) { SetStatus($"✗ Upload failed: {ex.Message}"); }
        finally { uploading = false; StateHasChanged(); }
    }

    private async Task DisassociateEvidence(JNode node, int docId)
    {
        if (!isAdmin) { SetStatus("✗ Admin access required to remove evidence"); return; }
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var doc = await db.SourceDocuments.FindAsync(docId);
            if (doc is null) return;

            doc.IsActive = false;
            await db.SaveChangesAsync();
            await RefreshNode(db, node.Id);
            SetStatus("✓ Evidence disassociated (record preserved)");
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        StateHasChanged();
    }

    // ── Node refresh ──────────────────────────────────────────────────────────
    private async Task RefreshNode(AppDbContext db, int jurisdictionId)
    {
        var catId = selectedCategoryId;
        var rate = await db.TaxRates
            .Where(r => r.JurisdictionId == jurisdictionId && r.IsCurrent && r.TaxCategoryId == catId)
            .Select(r => new { r.Rate, r.Id })
            .FirstOrDefaultAsync();

        var evidence = rate is null ? [] : await db.SourceDocuments
            .Where(d => d.TaxRateId == rate.Id && d.IsActive)
            .Select(d => new EvidenceFile(d.Id, d.FileName, d.OriginalFileName, d.EvidenceType, d.SourceUrl, d.RawContent, d.SourceType.ToString(), d.FetchedAt))
            .ToListAsync();

        UpdateNodeInplace(jurisdictionId, rate?.Rate, rate?.Id, evidence);
    }

    private void UpdateNodeInplace(int id, decimal? rate, int? rateId, List<EvidenceFile> evidence)
    {
        for (int i = 0; i < states.Count; i++)
        {
            if (states[i].Id == id) { states[i] = states[i] with { Rate = rate, RateId = rateId, Evidence = evidence }; return; }
        }
        foreach (var list in children.Values)
            for (int i = 0; i < list.Count; i++)
                if (list[i].Id == id) { list[i] = list[i] with { Rate = rate, RateId = rateId, Evidence = evidence }; return; }
    }

    // ── Scrape ────────────────────────────────────────────────────────────────
    private async Task RunScrape()
    {
        if (!isAdmin) { SetStatus("✗ Sign in to run scrape"); return; }
        scraping = true;
        SetStatus(null);
        StateHasChanged();
        try
        {
            var changed = await Orchestrator.RunFullScrapeAsync();
            SetStatus($"✓ Scrape done — {changed} change(s)");
            await using var db = await DbFactory.CreateDbContextAsync();
            states = await BuildNodes(db, JurisdictionType.State, parentType: JurisdictionType.Country);
            children.Clear();
            expanded.Clear();
        }
        catch (Exception ex) { SetStatus($"✗ {ex.Message}"); }
        finally { scraping = false; StateHasChanged(); }
    }


