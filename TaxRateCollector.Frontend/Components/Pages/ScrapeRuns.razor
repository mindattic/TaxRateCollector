@page "/runs"
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IScrapeOrchestrator Orchestrator
@rendermode InteractiveServer

<PageTitle>Scrape Runs — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Scrape Runs</h1>
            <p class="page-sub">Manually trigger a full scrape across all jurisdictions that have a registered strategy.</p>
        </div>
    </div>
</div>

@if (runs is null)
{
    <p class="muted">Loading…</p>
}
else if (runs.Count == 0)
{
    <p class="muted">No scrape runs yet.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Started</th>
                <th>Completed</th>
                <th>Status</th>
                <th>Scraped</th>
                <th>Changes</th>
                <th>Errors</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in runs)
            {
                <tr>
                    <td>#@r.Id</td>
                    <td>@r.StartedAt</td>
                    <td>@(r.CompletedAt ?? "—")</td>
                    <td><span class="badge badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                    <td>@r.TotalScraped</td>
                    <td>@r.ChangesDetected</td>
                    <td>@r.ErrorCount</td>
                    <td>
                        <button class="btn-tiny" @onclick="() => ToggleDetail(r.Id)">
                            @(expanded == r.Id ? "Hide" : "Details")
                        </button>
                    </td>
                </tr>
                @if (expanded == r.Id)
                {
                    <tr>
                        <td colspan="8">
                            <div class="run-detail">
                                <strong>Rates recorded in this run:</strong>
                                @if (runRates.Count == 0)
                                {
                                    <span class="muted"> None</span>
                                }
                                else
                                {
                                    <ul>
                                        @foreach (var tr in runRates)
                                        {
                                            <li>@tr.JurisdictionName — @tr.Rate.ToString("P4") (@tr.RateType)</li>
                                        }
                                    </ul>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<ScrapeRun>? runs;
    private int? expanded;
    private List<(string JurisdictionName, decimal Rate, string RateType)> runRates = [];
    private bool running;
    private string? lastResult;

    protected override async Task OnInitializedAsync() => await LoadRuns();

    private async Task LoadRuns()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        runs = await db.ScrapeRuns
            .OrderByDescending(r => r.StartedAt)
            .ToListAsync();
    }

    private async Task RunScrape()
    {
        running = true;
        lastResult = null;
        StateHasChanged();

        try
        {
            var changed = await Orchestrator.RunFullScrapeAsync();
            lastResult = $"✓ Done — {changed} change(s) detected";
        }
        catch (Exception ex)
        {
            lastResult = $"✗ {ex.Message}";
        }
        finally
        {
            running = false;
            await LoadRuns();
            StateHasChanged();
        }
    }

    private async Task ToggleDetail(int runId)
    {
        if (expanded == runId)
        {
            expanded = null;
            runRates = [];
            return;
        }

        expanded = runId;
        await using var db = await DbFactory.CreateDbContextAsync();
        runRates = await db.TaxRates
            .Include(t => t.Jurisdiction)
            .Where(t => t.ScrapeRunId == runId)
            .Select(t => ValueTuple.Create(t.Jurisdiction.JurisdictionName, t.Rate, t.RateType))
            .ToListAsync();
    }
}
