@page "/login"

<PageTitle>Log In — TaxRateCollector</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-logo">◈ TaxRateCollector</div>
        <h2 class="auth-title">Log in to your account</h2>

        @if (Error == "invalid")
        {
            <div class="auth-error">Invalid email or password.</div>
        }
        else if (Error == "locked")
        {
            <div class="auth-error">Account locked. Try again later.</div>
        }

        <form method="post" action="/login-submit">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="auth-field">
                <label>Email</label>
                <input type="email" name="email" class="setting-input" placeholder="you@example.com" autocomplete="username" />
            </div>
            <div class="auth-field">
                <label>Password</label>
                <input type="password" name="password" class="setting-input" placeholder="••••••••" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-primary auth-btn">Log In</button>
        </form>

        <div class="auth-links">
            <span class="muted">Don't have an account?</span>
            <a href="/register">Create one</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
}
