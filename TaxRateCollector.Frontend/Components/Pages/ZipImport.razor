@page "/zip-codes"
@attribute [Authorize]
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IZipImportService zipSvc
@inject ICensusJurisdictionImportService censusSvc
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>ZIP Codes — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">ZIP Codes</h1>
            <p class="page-sub">
                Maps every US ZIP code to its State, County, and City jurisdiction for destination-based sales tax calculation.
                Data sourced from the US Census Bureau ZCTA crosswalk files, optionally enriched via USPS CityStateLookup.
            </p>
        </div>
    </div>
</div>

<!-- ── Step 1: County & City Coverage ──────────────────────────────────────── -->
<div class="settings-section">
    <div class="step-header">
        <span class="step-badge">Step 1</span>
        <div>
            <h2 style="margin:0">Import Counties &amp; Cities</h2>
            <p class="section-note" style="margin:.25rem 0 0">
                Downloads all US counties (~3,143) and incorporated places (~30,000+) from the Census Bureau
                Gazetteer files and creates Jurisdiction rows at 0% rate. <strong>Run this before importing ZIP codes</strong>
                so that each ZIP immediately resolves to a real county and city.
            </p>
        </div>
    </div>

    <div class="discovery-stats" style="margin-bottom:1rem">
        <span class="disc-stat disc-stat-total"><strong>@seededCounties.ToString("N0")</strong> counties seeded</span>
        <span class="disc-stat disc-stat-found"><strong>@seededCities.ToString("N0")</strong> cities seeded</span>
        <span class="disc-stat disc-stat-skipped"><strong>@linkedZips.ToString("N0")</strong> ZIPs linked to county</span>
    </div>

    <div class="header-actions" style="margin-bottom:1rem">
        @if (!censusRunning)
        {
            @if (seededCounties == 0)
            {
                <button class="btn-primary" @onclick="StartCensusImport">▶ Import All Counties &amp; Cities</button>
            }
            else
            {
                <span class="step-complete-badge">✓ Complete</span>
                <button class="btn-secondary" @onclick="async () => { censusSvc.ClearCache(); await StartCensusImport(); }">↺ Re-download &amp; Import</button>
            }
        }
        else
        {
            <button class="btn-secondary" @onclick="StopCensusImport">■ Stop</button>
        }
    </div>

    @if (censusRunning || censusResult != null)
    {
        <div class="discovery-progress-wrap">
            @if (censusRunning && censusProgress.Total > 0)
            {
                var pct = (int)Math.Round(censusProgress.Processed * 100.0 / censusProgress.Total);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (censusRunning)
            {
                <div class="progress-bar-indeterminate"></div>
            }
            else
            {
                <div class="discovery-progress-bar" style="width:100%"></div>
            }
        </div>

        <div class="discovery-stats" style="margin-top:.5rem">
            <span class="disc-stat muted"><strong>@censusProgress.Stage</strong></span>
            <span class="disc-stat disc-stat-found"><strong>@censusProgress.Created.ToString("N0")</strong> created</span>
            <span class="disc-stat disc-stat-skipped"><strong>@censusProgress.Skipped.ToString("N0")</strong> skipped</span>
            @if (censusProgress.Errors > 0)
            {
                <span class="disc-stat disc-stat-error"><strong>@censusProgress.Errors</strong> errors</span>
            }
            @if (!string.IsNullOrEmpty(censusProgress.Current))
            {
                <span class="disc-stat muted">@censusProgress.Current</span>
            }
            @if (censusResult != null && !censusRunning)
            {
                <span class="disc-stat">Done in @censusResult.Elapsed.ToString(@"m\:ss")</span>
            }
        </div>
    }

    @if (censusResult != null && !censusRunning)
    {
        <div class="zip-result-card" style="margin-top:1rem">
            <div class="zip-result-stat">
                <div class="zip-result-num">@censusResult.CountiesCreated.ToString("N0")</div>
                <div class="zip-result-label">counties created</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@censusResult.CitiesCreated.ToString("N0")</div>
                <div class="zip-result-label">cities created</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@censusResult.ZipsRelinked.ToString("N0")</div>
                <div class="zip-result-label">ZIP codes re-linked</div>
            </div>
        </div>
    }
</div>

<!-- ── Step 2: ZIP Code Import ─────────────────────────────────────────────── -->
<div class="settings-section" style="margin-top:2rem">
    <div class="step-header">
        <span class="step-badge @(seededCounties == 0 ? "step-badge-blocked" : "")">Step 2</span>
        <div>
            <h2 style="margin:0">Import ZIP Codes</h2>
            <p class="section-note" style="margin:.25rem 0 0">
                Downloads the Census Bureau ZCTA crosswalk files and maps ~33,000 ZIP codes to their
                State, County, and City jurisdictions.
                @if (seededCounties == 0)
                {
                    <strong class="step-blocked-note"> Complete Step 1 first so ZIPs can link to real county and city rows.</strong>
                }
            </p>
        </div>
    </div>

    @if (importedCount > 0 && !running && result == null)
    {
        <div class="zip-status-banner">
            <span class="zip-status-icon">✓</span>
            <strong>@importedCount.ToString("N0")</strong> ZIP codes imported and linked to jurisdiction hierarchy.
        </div>
    }

    @if (!running && result == null && importedCount == 0 && seededCounties > 0)
    {
        <div class="zip-info-card">
            <h3>How ZIP-based tax resolution works</h3>
            <div class="zip-info-grid">
                <div class="zip-info-item">
                    <span class="zip-info-num">1</span>
                    <div>
                        <strong>ZIP → State</strong><br/>
                        Every ZIP belongs to exactly one state. The state's general sales tax rate applies.
                    </div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">2</span>
                    <div>
                        <strong>ZIP → County</strong><br/>
                        Each ZIP is assigned its primary county (by land-area intersection per Census data).
                        County add-on rates apply.
                    </div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">3</span>
                    <div>
                        <strong>ZIP → City</strong><br/>
                        The USPS preferred city name (or Census primary place) identifies municipal rates.
                    </div>
                </div>
                <div class="zip-info-item">
                    <span class="zip-info-num">4</span>
                    <div>
                        <strong>Product Category</strong><br/>
                        Exemptions and reduced rates (e.g., groceries, prescription drugs) are applied
                        per category × jurisdiction rule.
                    </div>
                </div>
            </div>
            <p class="zip-info-note">
                <strong>Data sources:</strong>
                Census Bureau 2020 ZCTA relationship files (free, no auth required) +
                optional USPS Web Tools CityStateLookup API (configure key in Settings).
                ~33,000 ZIP codes expected. Import takes 30–60 seconds (Census only) or
                10–20 minutes with USPS validation enabled.
            </p>
        </div>
    }

    <div class="header-actions" style="margin:1rem 0">
        @if (!running)
        {
            <button class="btn-primary" @onclick="StartImport"
                    disabled="@(alreadyComplete || seededCounties == 0 || censusRunning)">
                @if (alreadyComplete)
                {
                    <span>✓ Import Complete</span>
                }
                else if (seededCounties == 0)
                {
                    <span>▶ Import ZIP Codes (complete Step 1 first)</span>
                }
                else
                {
                    <span>▶ Import ZIP Codes</span>
                }
            </button>
            @if (importedCount > 0)
            {
                <button class="btn-secondary" @onclick="ReImport" disabled="@censusRunning">↺ Re-import</button>
            }
        }
        else
        {
            <button class="btn-secondary" @onclick="StopImport">■ Stop</button>
        }
    </div>

    @if (running || result != null)
    {
        <div class="discovery-progress-wrap">
            @if (running && progress.Total > 0)
            {
                var pct = (int)Math.Round(progress.Processed * 100.0 / progress.Total);
                <div class="discovery-progress-bar" style="width:@pct%"></div>
            }
            else if (running)
            {
                <div class="progress-bar-indeterminate"></div>
            }
            else
            {
                <div class="discovery-progress-bar" style="width:100%"></div>
            }
        </div>

        <div class="discovery-stats">
            @if (running)
            {
                <span class="disc-stat disc-stat-total">
                    <strong>@progress.Processed.ToString("N0")</strong> / @(progress.Total > 0 ? progress.Total.ToString("N0") : "…") processed
                </span>
            }
            <span class="disc-stat disc-stat-found"><strong>@progress.Imported.ToString("N0")</strong> imported</span>
            <span class="disc-stat disc-stat-skipped"><strong>@progress.Skipped.ToString("N0")</strong> skipped</span>
            @if (progress.Errors > 0)
            {
                <span class="disc-stat disc-stat-error"><strong>@progress.Errors</strong> errors</span>
            }
            @if (!string.IsNullOrEmpty(progress.CurrentZip))
            {
                <span class="disc-stat muted">processing @progress.CurrentZip</span>
            }
            @if (result != null)
            {
                <span class="disc-stat">Done in @result.Elapsed.ToString(@"m\:ss")</span>
            }
        </div>
    }

    @if (result != null)
    {
        <div class="zip-result-card" style="margin-top:1rem">
            <div class="zip-result-stat">
                <div class="zip-result-num">@result.Imported.ToString("N0")</div>
                <div class="zip-result-label">ZIP codes imported</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@linkedState.ToString("N0")</div>
                <div class="zip-result-label">linked to state</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@linkedCounty.ToString("N0")</div>
                <div class="zip-result-label">linked to county</div>
            </div>
            <div class="zip-result-stat">
                <div class="zip-result-num">@linkedCity.ToString("N0")</div>
                <div class="zip-result-label">linked to city</div>
            </div>
        </div>
    }
</div>

<!-- ── State breakdown table ───────────────────────────────────────────────── -->
@if (stateCounts.Count > 0)
{
    <div class="zip-table-wrap" style="margin-top:2rem">
        <table class="data-table">
            <thead>
                <tr>
                    <th>State</th>
                    <th style="text-align:right">ZIP Codes</th>
                    <th style="text-align:right">Linked County</th>
                    <th style="text-align:right">Linked City</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in stateCounts.OrderBy(r => r.StateCode))
                {
                    <tr>
                        <td class="mono">@row.StateCode</td>
                        <td class="mono" style="text-align:right">@row.Total.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CountyLinked.ToString("N0")</td>
                        <td class="mono" style="text-align:right">@row.CityLinked.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool running;
    private CancellationTokenSource? cts;
    private int importedCount;
    private bool alreadyComplete;
    private ZipImportProgress progress = new(0, 0, 0, 0, 0);
    private ZipImportResult? result;
    private int linkedState, linkedCounty, linkedCity;

    // ── Census import state ───────────────────────────────────────────────────
    private bool censusRunning;
    private CancellationTokenSource? censusCts;
    private CensusImportProgress censusProgress = new("", 0, 0, 0, 0, 0);
    private CensusImportResult? censusResult;
    private int seededCounties, seededCities, linkedZips;

    private record StateRow(string StateCode, int Total, int CountyLinked, int CityLinked);
    private List<StateRow> stateCounts = new();

    protected override async Task OnInitializedAsync()
    {
        importedCount = await zipSvc.GetImportedCountAsync();
        alreadyComplete = importedCount > 0;
        var coverage = await censusSvc.GetCoverageAsync();
        seededCounties = coverage.SeededCounties;
        seededCities   = coverage.SeededCities;
        linkedZips     = coverage.LinkedZips;
        if (importedCount > 0) await LoadStateCountsAsync();
    }

    private async Task StartImport()
    {
        running = true;
        result  = null;
        progress = new(0, 0, 0, 0, 0);
        cts = new CancellationTokenSource();
        StateHasChanged();

        var p = new Progress<ZipImportProgress>(snap =>
        {
            progress = snap;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            result = await zipSvc.ImportAsync(p, cts.Token);
            importedCount = await zipSvc.GetImportedCountAsync();
            alreadyComplete = importedCount > 0;
            await LoadLinkStatsAsync();
            await LoadStateCountsAsync();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            progress = progress with { CurrentZip = $"Error: {ex.Message}" };
        }
        finally
        {
            running = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReImport()
    {
        zipSvc.ClearCache();
        alreadyComplete = false;
        importedCount = 0;
        stateCounts.Clear();
        result = null;
        // Note: does not delete existing DB records — re-import only adds new ZIPs
        await StartImport();
    }

    private void StopImport() => cts?.Cancel();

    // ── Census import ─────────────────────────────────────────────────────────

    private async Task StartCensusImport()
    {
        censusRunning = true;
        censusResult  = null;
        censusProgress = new("Starting…", 0, 0, 0, 0, 0);
        censusCts = new CancellationTokenSource();
        StateHasChanged();

        var p = new Progress<CensusImportProgress>(snap =>
        {
            censusProgress = snap;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            censusResult = await censusSvc.ImportAsync(p, censusCts.Token);
            var coverage  = await censusSvc.GetCoverageAsync();
            seededCounties = coverage.SeededCounties;
            seededCities   = coverage.SeededCities;
            linkedZips     = coverage.LinkedZips;
            await LoadStateCountsAsync();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            censusProgress = censusProgress with { Current = $"Error: {ex.Message}" };
        }
        finally
        {
            censusRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StopCensusImport() => censusCts?.Cancel();

    private async Task LoadLinkStatsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        linkedState  = await db.ZipCodes.CountAsync(z => z.StateJurisdictionId  != null);
        linkedCounty = await db.ZipCodes.CountAsync(z => z.CountyJurisdictionId != null);
        linkedCity   = await db.ZipCodes.CountAsync(z => z.CityJurisdictionId   != null);
    }

    private async Task LoadStateCountsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        stateCounts = await db.ZipCodes
            .GroupBy(z => z.StateCode)
            .Select(g => new StateRow(
                g.Key,
                g.Count(),
                g.Count(z => z.CountyJurisdictionId != null),
                g.Count(z => z.CityJurisdictionId   != null)))
            .ToListAsync();

        if (linkedState == 0 && stateCounts.Count > 0)
        {
            linkedState  = await db.ZipCodes.CountAsync(z => z.StateJurisdictionId  != null);
            linkedCounty = await db.ZipCodes.CountAsync(z => z.CountyJurisdictionId != null);
            linkedCity   = await db.ZipCodes.CountAsync(z => z.CityJurisdictionId   != null);
        }
    }
}
