@page "/discovery"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IDiscoveryService DiscoveryService
@inject IScrapeOrchestrator Orchestrator
@rendermode InteractiveServer

<PageTitle>Data Collection — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Data Collection</h1>
    <p class="page-sub">
        Two-phase pipeline: <strong>Scrape</strong> fetches and stores current tax rates;
        <strong>Discovery</strong> maps every jurisdiction to its best available source.
    </p>
</div>

<!-- ── Phase panels ────────────────────────────────────────────────────────── -->
<div class="pipeline-grid">

    <!-- ── Scrape ───────────────────────────────────────────────────────────── -->
    <div class="pipeline-card">
        <div class="pipeline-card-header">
            <div class="pipeline-card-body">
                <h2 class="pipeline-card-title">
                    Scrape
                    <span class="phase-badge phase-badge-active">Phase 1 · Operational</span>
                </h2>
                <p class="pipeline-card-desc">
                    Iterates every active jurisdiction and routes it to a registered
                    <code>IScrapeStrategy</code>. Each strategy fetches the current tax rate
                    using the method best suited to that jurisdiction's tier — a direct URL fetch,
                    a structured API call, or PDF extraction. Successfully parsed rates are written
                    as new <code>TaxRate</code> records and the prior current rate for that
                    jurisdiction is retired. After all jurisdictions are processed, a diff engine
                    compares the new run to the previous one and records what changed. The full
                    run is logged in the <strong>Scrape Runs</strong> tab.
                </p>
            </div>
            <div class="pipeline-card-actions">
                @if (!scrapeRunning)
                {
                    <button class="btn-primary" @onclick="StartScrape">▶ Run Scrape</button>
                }
                else
                {
                    <button class="btn-secondary" @onclick="StopScrape">■ Stop</button>
                }
            </div>
        </div>
        @if (scrapeRunning || scrapeStatus is not null)
        {
            <div class="pipeline-status">
                @if (scrapeRunning)
                {
                    <span class="pipeline-running-dot"></span>
                    <span class="muted">Running…</span>
                }
                else
                {
                    <span class="@(scrapeStatus!.StartsWith("✗") ? "text-error" : "text-ok")">@scrapeStatus</span>
                }
            </div>
        }
    </div>

    <!-- ── Discovery ────────────────────────────────────────────────────────── -->
    <div class="pipeline-card">
        <div class="pipeline-card-header">
            <div class="pipeline-card-body">
                <h2 class="pipeline-card-title">
                    Discovery
                    <span class="phase-badge phase-badge-stub">Phase 2 · Stub</span>
                </h2>
                <p class="pipeline-card-desc">
                    Recursively traverses the full jurisdiction tree — State → County → City —
                    and attempts to locate a reliable tax rate source for each jurisdiction.
                    For every non-country node the discovery service probes in sequence:
                    a known government API endpoint, an official web page, a linked PDF, and
                    recent news articles. Results are logged below as
                    <strong>Found</strong>, <strong>Not Found</strong>, <strong>Skipped</strong>,
                    or <strong>Error</strong> — but no rates are written to the database.
                    Sources catalogued here are intended to inform and update the scrape
                    strategies used in Phase 1.
                    <em class="muted">Live probing is planned; currently returns stub results.</em>
                </p>
            </div>
            <div class="pipeline-card-actions">
                @if (!running)
                {
                    <button class="btn-primary" @onclick="StartDiscovery">▶ Run Discovery</button>
                }
                else
                {
                    <button class="btn-secondary" @onclick="StopDiscovery">■ Stop</button>
                }
                @if (results.Count > 0 && !running)
                {
                    <button class="btn-secondary" @onclick="ClearResults">✕ Clear</button>
                }
            </div>
        </div>

        @if (running || processed > 0)
        {
            <div class="discovery-progress-wrap" style="margin-top:.75rem">
                @if (running && total > 0)
                {
                    var pct = (int)Math.Round(processed * 100.0 / total);
                    <div class="discovery-progress-bar" style="width:@pct%"></div>
                }
                else if (running)
                {
                    <div class="progress-bar-indeterminate"></div>
                }
            </div>
            <div class="discovery-stats">
                <span class="disc-stat">
                    <strong>@processed</strong> / @(total > 0 ? total.ToString() : "…") processed
                </span>
                <span class="disc-stat disc-stat-found"><strong>@found</strong> found</span>
                <span class="disc-stat disc-stat-missing"><strong>@notFound</strong> not found</span>
                <span class="disc-stat disc-stat-skipped"><strong>@skipped</strong> skipped</span>
                @if (errors > 0)
                {
                    <span class="disc-stat disc-stat-error"><strong>@errors</strong> errors</span>
                }
                @if (!running && processed > 0)
                {
                    <span class="disc-stat muted">Done @completedAt?.ToString("HH:mm:ss")</span>
                }
            </div>
        }
    </div>

</div>

<!-- ── Discovery results log ───────────────────────────────────────────────── -->
@if (results.Count > 0)
{
    <div class="disc-filter-bar">
        <div class="log-level-pills">
            @foreach (var f in new[] { "All", "Found", "NotFound", "Skipped", "Error" })
            {
                <button class="log-level-pill disc-filter-pill @(f == "All" ? "disc-pill-all" : $"disc-pill-{f.ToLower()}") @(filter == f ? "log-pill-active" : "")"
                        @onclick="() => filter = f">@f</button>
            }
        </div>
        <input class="setting-input log-search" placeholder="Search name or state…"
               @bind="search" @bind:event="oninput" />
    </div>

    <div class="disc-table-wrap">
        <table class="data-table disc-table">
            <thead>
                <tr>
                    <th>Tier</th>
                    <th>State</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Source</th>
                    <th>Rate</th>
                    <th>Notes</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in FilteredResults.Take(500))
                {
                    <tr class="disc-row disc-row-@r.Status.ToLower()">
                        <td><span class="tier-badge @TierClass(r.Tier)">@r.Tier</span></td>
                        <td class="mono">@r.StateCode</td>
                        <td>@r.JurisdictionName</td>
                        <td><span class="disc-status-badge disc-status-@r.Status.ToLower()">@r.Status</span></td>
                        <td class="disc-source-cell" title="@r.SourceUsed">@TruncateUrl(r.SourceUsed)</td>
                        <td class="mono">@(r.FoundRate.HasValue ? $"{r.FoundRate.Value * 100:F3}%" : "—")</td>
                        <td class="disc-notes-cell">@r.Notes</td>
                        <td class="mono muted">@r.ProcessedAt.ToString("HH:mm:ss")</td>
                    </tr>
                }
                @if (FilteredResults.Count() > 500)
                {
                    <tr>
                        <td colspan="8" class="muted" style="text-align:center;padding:.75rem">
                            Showing first 500 of @FilteredResults.Count() results
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!running)
{
    <div class="empty-state">
        Press <strong>▶ Run Discovery</strong> to scan all jurisdictions for tax rate sources.
    </div>
}

@code {
    // ── Discovery state ───────────────────────────────────────────────────────
    private bool running;
    private CancellationTokenSource? cts;
    private int total, processed, found, notFound, skipped, errors;
    private DateTime? completedAt;
    private string filter = "All";
    private string search = "";
    private readonly List<DiscoveryResult> results = new();

    // ── Scrape state ──────────────────────────────────────────────────────────
    private bool scrapeRunning;
    private CancellationTokenSource? scrapeCts;
    private string? scrapeStatus;

    private IEnumerable<DiscoveryResult> FilteredResults =>
        results
            .Where(r => filter == "All" || r.Status == filter)
            .Where(r => string.IsNullOrEmpty(search) ||
                        r.JurisdictionName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                        r.StateCode.Contains(search, StringComparison.OrdinalIgnoreCase));

    // ── Scrape ────────────────────────────────────────────────────────────────
    private async Task StartScrape()
    {
        scrapeRunning = true;
        scrapeStatus = null;
        scrapeCts = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            var changed = await Orchestrator.RunFullScrapeAsync(scrapeCts.Token);
            scrapeStatus = $"✓ Done — {changed} change(s) detected";
        }
        catch (OperationCanceledException) { scrapeStatus = "Stopped."; }
        catch (Exception ex) { scrapeStatus = $"✗ {ex.Message}"; }
        finally { scrapeRunning = false; StateHasChanged(); }
    }

    private void StopScrape() => scrapeCts?.Cancel();

    // ── Discovery ─────────────────────────────────────────────────────────────
    private async Task StartDiscovery()
    {
        running   = true;
        cts       = new CancellationTokenSource();
        total     = 0;
        processed = 0;
        found     = 0;
        notFound  = 0;
        skipped   = 0;
        errors    = 0;
        completedAt = null;
        results.Clear();
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            total = await db.Jurisdictions
                .CountAsync(j => j.IsActive && j.JurisdictionType != JurisdictionType.Country, cts.Token);
            await InvokeAsync(StateHasChanged);

            var countries = await db.Jurisdictions
                .Where(j => j.JurisdictionType == JurisdictionType.Country && j.IsActive)
                .OrderBy(j => j.JurisdictionName)
                .ToListAsync(cts.Token);

            foreach (var country in countries)
                await ProcessRecursiveAsync(country, db, cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            results.Insert(0, new DiscoveryResult
            {
                JurisdictionName = "Discovery run",
                Status = "Error",
                Notes  = ex.Message,
                ProcessedAt = DateTime.UtcNow
            });
        }
        finally
        {
            running     = false;
            completedAt = DateTime.UtcNow;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ProcessRecursiveAsync(Jurisdiction jurisdiction, AppDbContext db, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        if (jurisdiction.JurisdictionType != JurisdictionType.Country)
        {
            DiscoveryResult result;
            try
            {
                result = await DiscoveryService.DiscoverAsync(jurisdiction, ct);
            }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex)
            {
                result = new DiscoveryResult
                {
                    JurisdictionId   = jurisdiction.Id,
                    JurisdictionName = jurisdiction.JurisdictionName,
                    StateCode        = jurisdiction.StateCode,
                    Tier             = jurisdiction.JurisdictionType,
                    Status           = "Error",
                    Notes            = ex.Message,
                    ProcessedAt      = DateTime.UtcNow,
                };
            }

            results.Insert(0, result);
            processed++;
            switch (result.Status)
            {
                case "Found":    found++;    break;
                case "NotFound": notFound++; break;
                case "Skipped":  skipped++;  break;
                case "Error":    errors++;   break;
            }

            if (processed % 10 == 0 || result.Status == "Error" || result.Status == "Found")
                await InvokeAsync(StateHasChanged);
        }

        var children = await db.Jurisdictions
            .Where(j => j.ParentId == jurisdiction.Id && j.IsActive)
            .OrderBy(j => j.JurisdictionName)
            .ToListAsync(ct);

        foreach (var child in children)
            await ProcessRecursiveAsync(child, db, ct);
    }

    private void StopDiscovery() => cts?.Cancel();

    private void ClearResults()
    {
        results.Clear();
        total = processed = found = notFound = skipped = errors = 0;
        completedAt = null;
    }

    private static string TierClass(JurisdictionType tier) => tier switch
    {
        JurisdictionType.State  => "tier-state",
        JurisdictionType.County => "tier-county",
        JurisdictionType.City   => "tier-city",
        _                       => "tier-country"
    };

    private static string TruncateUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url == "—") return url;
        if (url.Length <= 40) return url;
        return url[..37] + "…";
    }
}
