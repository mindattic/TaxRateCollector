@page "/discovery"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IDiscoveryService DiscoveryService
@rendermode InteractiveServer

<PageTitle>Discovery — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 class="page-title">Discovery</h1>
            <p class="page-sub">
                Recursively scans every jurisdiction for available tax rate sources.
                Phase 2 will scrape web pages, parse PDFs, call APIs, and read news articles.
            </p>
        </div>
        <div class="header-actions">
            @if (!_running)
            {
                <button class="btn-primary" @onclick="StartDiscovery">▶ Run Discovery</button>
            }
            else
            {
                <button class="btn-secondary" @onclick="StopDiscovery">■ Stop</button>
            }
            @if (_results.Count > 0 && !_running)
            {
                <button class="btn-secondary" @onclick="ClearResults">✕ Clear</button>
            }
        </div>
    </div>
</div>

<!-- ── Progress bar ────────────────────────────────────────────────────────── -->
@if (_running || _processed > 0)
{
    <div class="discovery-progress-wrap">
        @if (_running && _total > 0)
        {
            var pct = (int)Math.Round(_processed * 100.0 / _total);
            <div class="discovery-progress-bar" style="width:@pct%"></div>
        }
        else if (_running)
        {
            <div class="progress-bar-indeterminate"></div>
        }
    </div>

    <div class="discovery-stats">
        <span class="disc-stat disc-stat-total">
            <strong>@_processed</strong> / @(_total > 0 ? _total.ToString() : "…") processed
        </span>
        <span class="disc-stat disc-stat-found">
            <strong>@_found</strong> found
        </span>
        <span class="disc-stat disc-stat-missing">
            <strong>@_notFound</strong> not found
        </span>
        <span class="disc-stat disc-stat-skipped">
            <strong>@_skipped</strong> skipped
        </span>
        @if (_errors > 0)
        {
            <span class="disc-stat disc-stat-error"><strong>@_errors</strong> errors</span>
        }
        @if (!_running && _processed > 0)
        {
            <span class="disc-stat">Done @_completedAt?.ToString("HH:mm:ss")</span>
        }
    </div>
}

<!-- ── Results log ─────────────────────────────────────────────────────────── -->
@if (_results.Count > 0)
{
    <div class="disc-filter-bar">
        <div class="log-level-pills">
            @foreach (var f in new[] { "All", "Found", "NotFound", "Skipped", "Error" })
            {
                <button class="log-level-pill disc-filter-pill @(f == "All" ? "disc-pill-all" : $"disc-pill-{f.ToLower()}") @(_filter == f ? "log-pill-active" : "")"
                        @onclick="() => _filter = f">@f</button>
            }
        </div>
        <input class="setting-input log-search" placeholder="Search name or state…"
               @bind="_search" @bind:event="oninput" />
    </div>

    <div class="disc-table-wrap">
        <table class="data-table disc-table">
            <thead>
                <tr>
                    <th>Tier</th>
                    <th>State</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Source</th>
                    <th>Rate</th>
                    <th>Notes</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in FilteredResults.Take(500))
                {
                    <tr class="disc-row disc-row-@r.Status.ToLower()">
                        <td><span class="tier-badge @TierClass(r.Tier)">@r.Tier</span></td>
                        <td class="mono">@r.StateCode</td>
                        <td>@r.JurisdictionName</td>
                        <td><span class="disc-status-badge disc-status-@r.Status.ToLower()">@r.Status</span></td>
                        <td class="disc-source-cell" title="@r.SourceUsed">@TruncateUrl(r.SourceUsed)</td>
                        <td class="mono">@(r.FoundRate.HasValue ? $"{r.FoundRate.Value * 100:F3}%" : "—")</td>
                        <td class="disc-notes-cell">@r.Notes</td>
                        <td class="mono muted">@r.ProcessedAt.ToString("HH:mm:ss")</td>
                    </tr>
                }
                @if (FilteredResults.Count() > 500)
                {
                    <tr><td colspan="8" class="muted" style="text-align:center;padding:.75rem">
                        Showing first 500 of @FilteredResults.Count() results
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!_running)
{
    <div class="empty-state">
        Press <strong>▶ Run Discovery</strong> to scan all jurisdictions for tax rate sources.
    </div>
}

@code {
    private bool _running;
    private CancellationTokenSource? _cts;
    private int _total, _processed, _found, _notFound, _skipped, _errors;
    private DateTime? _completedAt;
    private string _filter = "All";
    private string _search = "";

    private readonly List<DiscoveryResult> _results = new();

    private IEnumerable<DiscoveryResult> FilteredResults =>
        _results
            .Where(r => _filter == "All" || r.Status == _filter)
            .Where(r => string.IsNullOrEmpty(_search) ||
                        r.JurisdictionName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                        r.StateCode.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private async Task StartDiscovery()
    {
        _running   = true;
        _cts       = new CancellationTokenSource();
        _total     = 0;
        _processed = 0;
        _found     = 0;
        _notFound  = 0;
        _skipped   = 0;
        _errors    = 0;
        _completedAt = null;
        _results.Clear();
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            // Pre-count non-Country active jurisdictions for progress display
            _total = await db.Jurisdictions
                .CountAsync(j => j.IsActive && j.JurisdictionType != JurisdictionType.Country, _cts.Token);
            await InvokeAsync(StateHasChanged);

            // Traverse the full tree starting from Countries
            var countries = await db.Jurisdictions
                .Where(j => j.JurisdictionType == JurisdictionType.Country && j.IsActive)
                .OrderBy(j => j.JurisdictionName)
                .ToListAsync(_cts.Token);

            foreach (var country in countries)
                await ProcessRecursiveAsync(country, db, _cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _results.Insert(0, new DiscoveryResult
            {
                JurisdictionName = "Discovery run",
                Status = "Error",
                Notes  = ex.Message,
                ProcessedAt = DateTime.UtcNow
            });
        }
        finally
        {
            _running     = false;
            _completedAt = DateTime.UtcNow;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ProcessRecursiveAsync(Jurisdiction jurisdiction, AppDbContext db, CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();

        // Discover for every tier except Country (which is just a grouping node)
        if (jurisdiction.JurisdictionType != JurisdictionType.Country)
        {
            DiscoveryResult result;
            try
            {
                result = await DiscoveryService.DiscoverAsync(jurisdiction, ct);
            }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex)
            {
                result = new DiscoveryResult
                {
                    JurisdictionId   = jurisdiction.Id,
                    JurisdictionName = jurisdiction.JurisdictionName,
                    StateCode        = jurisdiction.StateCode,
                    Tier             = jurisdiction.JurisdictionType,
                    Status           = "Error",
                    Notes            = ex.Message,
                    ProcessedAt      = DateTime.UtcNow,
                };
            }

            _results.Insert(0, result);
            _processed++;
            switch (result.Status)
            {
                case "Found":    _found++;    break;
                case "NotFound": _notFound++; break;
                case "Skipped":  _skipped++;  break;
                case "Error":    _errors++;   break;
            }

            // Throttle UI updates — every 10 results or on error
            if (_processed % 10 == 0 || result.Status == "Error" || result.Status == "Found")
                await InvokeAsync(StateHasChanged);
        }

        // Load and process children
        var children = await db.Jurisdictions
            .Where(j => j.ParentId == jurisdiction.Id && j.IsActive)
            .OrderBy(j => j.JurisdictionName)
            .ToListAsync(ct);

        foreach (var child in children)
            await ProcessRecursiveAsync(child, db, ct);
    }

    private void StopDiscovery()
    {
        _cts?.Cancel();
    }

    private void ClearResults()
    {
        _results.Clear();
        _total = _processed = _found = _notFound = _skipped = _errors = 0;
        _completedAt = null;
    }

    private static string TierClass(JurisdictionType tier) => tier switch
    {
        JurisdictionType.State  => "tier-state",
        JurisdictionType.County => "tier-county",
        JurisdictionType.City   => "tier-city",
        _                       => "tier-country"
    };

    private static string TruncateUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url == "—") return url;
        if (url.Length <= 40) return url;
        return url[..37] + "…";
    }
}
