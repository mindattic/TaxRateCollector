@page "/settings"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@using TaxRateCollector.Frontend.Services
@inject SettingsService settings
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ViewAsService ViewAs
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>Settings — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Settings</h1>
</div>

<div class="settings-grid">

    <!-- ── Appearance — visible to all ──────────────────────────────────────── -->
    <section class="settings-section">
        <h2>Appearance</h2>
        <div class="setting-row">
            <label class="setting-label">Theme</label>
            <select class="setting-input" style="max-width:220px"
                    value="@settings.Current.Theme"
                    @onchange="e => SetTheme(e.Value?.ToString() ?? settings.Current.Theme)">
                <option value="light">☀ Light</option>
                <option value="dark">☾ Dark</option>
                <option value="spring">🌸 Spring</option>
                <option value="summer">☀ Summer</option>
                <option value="autumn">🍂 Autumn</option>
                <option value="winter">❄ Winter</option>
                <option value="tutor">📘 Tutor</option>
                <option value="llm">🤖 LLM</option>
                <option value="samurai">⚔ Samurai</option>
            </select>
        </div>
        <div class="setting-row">
            <label class="setting-label">Font</label>
            <select class="setting-input" style="max-width:220px"
                    value="@settings.Current.Font"
                    @onchange="e => SetFont(e.Value?.ToString() ?? settings.Current.Font)">
                <option value="outfit">Outfit</option>
                <option value="roboto">Roboto</option>
                <option value="lato">Lato</option>
                <option value="calibri">Calibri</option>
                <option value="arial">Arial</option>
                <option value="times">Times New Roman</option>
            </select>
        </div>
    </section>

    @if (effectiveIsAdmin)
    {

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="admin-divider">
            <span>Admin Configuration</span>
        </div>
        <!-- ═══════════════════════════════════════════════════════════════════ -->

        <!-- ── Data Source Alert Banner ──────────────────────────────────────── -->
        @if (FailedSources.Count > 0)
        {
            <div class="ds-alert ds-alert-error">
                <strong>@FailedSources.Count data source(s) unreachable</strong> —
                URLs marked ✗ below could not be reached. Update them before running imports.
            </div>
        }
        else if (UncheckedSources.Count > 0)
        {
            <div class="ds-alert ds-alert-warn">
                <strong>Data sources not yet validated</strong> —
                Click <em>Check All Sources</em> in any data source section to verify URLs are reachable.
            </div>
        }
        else
        {
            <div class="ds-alert ds-alert-ok">
                All @UrlKeys.Count data sources reachable.
            </div>
        }

        <!-- ── USPS ──────────────────────────────────────────────────────────── -->
        <section class="settings-section">
            <h2>USPS Address Validation</h2>
            <p class="section-note">
                Validates that every jurisdiction corresponds to a real USPS-recognized location.
                Get a key at <a href="https://www.usps.com/business/web-tools-apis/" target="_blank">usps.com</a>.
            </p>
            <div class="setting-row">
                <label class="setting-label">API Key</label>
                <input class="setting-input" type="password" placeholder="USPS Web Tools API Key"
                       @bind="settings.Current.UspsApiKey" />
            </div>
        </section>

        <!-- ── Scraping ──────────────────────────────────────────────────────── -->
        <section class="settings-section">
            <h2>Scraping &amp; Updates</h2>
            <div class="setting-row">
                <label class="setting-label">Default update frequency (days)</label>
                <input class="setting-input setting-input-sm" type="number" min="1" max="365"
                       @bind="settings.Current.DefaultUpdateFrequencyDays" />
            </div>
            <div class="setting-row">
                <label class="setting-label">Auto-fetch evidence when scraping</label>
                <input type="checkbox" @bind="settings.Current.EvidenceAutoFetch" />
            </div>
            <div class="setting-row">
                <label class="setting-label">Fall back to Wayback Machine for unavailable pages</label>
                <input type="checkbox" @bind="settings.Current.WaybackMachineFallback" />
            </div>
        </section>

        <!-- ── Census data source URLs ────────────────────────────────────────── -->
        <section class="settings-section">
            <h2>Census Data Source URLs</h2>
            <p class="section-note">
                Update these when the Census Bureau moves files to a new year or path.
                Changes take effect on the next import run (clear cache first to force re-download).
            </p>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem">
                <label class="setting-label">County Gazetteer (ZIP)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.CensusCountyGazUrl" />
                    <span class="ds-url-status @UrlStatusClass("CensusCountyGaz")">@UrlStatusIcon("CensusCountyGaz")</span>
                </div>
            </div>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem;margin-top:.75rem">
                <label class="setting-label">Place Gazetteer (ZIP)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.CensusPlaceGazUrl" />
                    <span class="ds-url-status @UrlStatusClass("CensusPlaceGaz")">@UrlStatusIcon("CensusPlaceGaz")</span>
                </div>
            </div>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem;margin-top:.75rem">
                <label class="setting-label">ZCTA → County crosswalk (TXT)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.CensusZctaCountyUrl" />
                    <span class="ds-url-status @UrlStatusClass("CensusZctaCounty")">@UrlStatusIcon("CensusZctaCounty")</span>
                </div>
            </div>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem;margin-top:.75rem">
                <label class="setting-label">ZCTA → Place crosswalk (TXT)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.CensusZctaPlaceUrl" />
                    <span class="ds-url-status @UrlStatusClass("CensusZctaPlace")">@UrlStatusIcon("CensusZctaPlace")</span>
                </div>
            </div>
            <div class="settings-actions" style="margin-top:.8rem;gap:.6rem">
                <button class="btn-primary" @onclick="Save">Save Settings</button>
                <button class="btn-secondary" @onclick="CheckAllSources" disabled="@checkingUrls">
                    @(checkingUrls ? "Checking…" : "Check All Sources")
                </button>
                @if (saved) { <span class="save-confirm">✓ Saved</span> }
            </div>
        </section>

        <!-- ── Streamlined Sales Tax (SST) source URLs ───────────────────────── -->
        <section class="settings-section">
            <h2>Streamlined Sales Tax (SST) Source URLs</h2>
            <p class="section-note">
                The SST Governing Board publishes the SSUTA agreement and supporting materials.
                Update these URLs when the Board publishes a new amendment. The Agreement PDF
                (Appendix C) is the authoritative source for the product/service taxonomy.
            </p>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem">
                <label class="setting-label">SSUTA Agreement (PDF) — Appendix C: Product/Service Taxonomy</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.SstAgreementUrl" />
                    <span class="ds-url-status @UrlStatusClass("SstAgreement")">@UrlStatusIcon("SstAgreement")</span>
                </div>
            </div>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem;margin-top:.75rem">
                <label class="setting-label">SST Taxability Matrix (web)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.SstTaxabilityMatrixUrl" />
                    <span class="ds-url-status @UrlStatusClass("SstTaxabilityMatrix")">@UrlStatusIcon("SstTaxabilityMatrix")</span>
                </div>
            </div>
            <div class="setting-row ds-url-row" style="flex-direction:column;align-items:flex-start;gap:.4rem;margin-top:.75rem">
                <label class="setting-label">SST Member States &amp; News (web)</label>
                <div class="ds-url-input-wrap">
                    <input class="setting-input" style="font-size:.82rem;font-family:monospace"
                           @bind="settings.Current.SstMemberStatesUrl" />
                    <span class="ds-url-status @UrlStatusClass("SstMemberStates")">@UrlStatusIcon("SstMemberStates")</span>
                </div>
            </div>
            <div class="settings-actions" style="margin-top:.8rem;gap:.6rem">
                <button class="btn-primary" @onclick="Save">Save Settings</button>
                <button class="btn-secondary" @onclick="CheckAllSources" disabled="@checkingUrls">
                    @(checkingUrls ? "Checking…" : "Check All Sources")
                </button>
                @if (saved) { <span class="save-confirm">✓ Saved</span> }
            </div>
        </section>
    }

    <!-- ── Save app settings ─────────────────────────────────────────────── -->
    <div class="settings-actions">
        <button class="btn-primary" @onclick="Save">Save Settings</button>
        @if (saved)
        {
            <span class="save-confirm">✓ Saved</span>
        }
    </div>

</div>

@if (effectiveIsAdmin)
{
<div class="settings-grid">

    <!-- ── Pricing ───────────────────────────────────────────────────────── -->
    <section class="settings-section">
        <h2>Subscription Pricing</h2>
        <p class="section-note">
            These values are stored in the database and applied to all new subscription checkouts.
            Changes take effect immediately — existing subscriptions are not retroactively changed.
        </p>
        @if (pricing is not null)
        {
            <div class="setting-row">
                <label class="setting-label">Price per state / month</label>
                <div style="display:flex;align-items:center;gap:.5rem">
                    <span class="muted">$</span>
                    <input class="setting-input setting-input-sm" type="number" step="0.001" min="0.001"
                           @bind="pricing.PricePerState" />
                    <span class="muted">USD · 50 states = @((pricing.PricePerState * 50).ToString("C"))/mo full access</span>
                </div>
            </div>
            <div class="setting-row">
                <label class="setting-label">Currency</label>
                <input class="setting-input" style="max-width:80px" @bind="pricing.Currency" />
            </div>
            <div class="settings-actions" style="margin-top:.8rem">
                <button class="btn-primary" @onclick="SavePricing" disabled="@adminBusy">Save Pricing</button>
                @if (adminStatus is not null)
                {
                    <span class="save-confirm">@adminStatus</span>
                }
            </div>
        }
        else
        {
            <div class="loading-state">Loading…</div>
        }
    </section>

    <!-- ── PayPal ─────────────────────────────────────────────────────────── -->
    <section class="settings-section">
        <h2>PayPal Integration</h2>
        <p class="section-note">
            Leave blank to run in <strong>mock mode</strong> — payments are simulated, no real charges.
            Get credentials at <a href="https://developer.paypal.com/dashboard/" target="_blank">developer.paypal.com</a> →
            Apps &amp; Credentials.
        </p>
        @if (paypal is not null)
        {
            <div class="setting-row">
                <label class="setting-label">Mode</label>
                <div class="theme-toggle">
                    <button class="theme-btn @(paypal.Mode == "sandbox" ? "theme-active" : "")"
                            @onclick='() => paypal.Mode = "sandbox"'>
                        Sandbox
                    </button>
                    <button class="theme-btn @(paypal.Mode == "live" ? "theme-active" : "")"
                            @onclick='() => paypal.Mode = "live"'>
                        Live
                    </button>
                </div>
            </div>
            <div class="setting-row">
                <label class="setting-label">Client ID</label>
                <input class="setting-input" placeholder="AXxx… (from PayPal dashboard)"
                       @bind="paypal.ClientId" />
            </div>
            <div class="setting-row">
                <label class="setting-label">Client Secret</label>
                <input class="setting-input" type="password" placeholder="EXxx… (keep secret)"
                       @bind="paypal.ClientSecret" />
            </div>
            <div class="setting-row">
                <label class="setting-label">Webhook ID <span class="muted">(optional)</span></label>
                <input class="setting-input" placeholder="For signature verification"
                       @bind="paypal.WebhookId" />
            </div>
            <div class="settings-actions" style="margin-top:.8rem">
                <button class="btn-primary" @onclick="SavePayPal" disabled="@adminBusy">Save PayPal Config</button>
                @if (adminStatus is not null)
                {
                    <span class="save-confirm">@adminStatus</span>
                }
            </div>
        }
        else
        {
            <div class="loading-state">Loading…</div>
        }
    </section>

    <!-- ── Database Backup ──────────────────────────────────────────────── -->
    <section class="settings-section">
        <h2>Database Backup</h2>
        <p class="section-note">
            Exports the database to a <code>.bacpac</code> file using <code>sqlpackage</code>.
            Install it once with: <code>dotnet tool install -g microsoft.sqlpackage</code>
        </p>
        <div class="setting-row" style="flex-direction:column;align-items:flex-start;gap:.4rem">
            <label class="setting-label">Output path</label>
            <input class="setting-input" style="font-size:.85rem;font-family:monospace"
                   placeholder="C:\Users\…\TaxRateCollector.bacpac"
                   @bind="backupPath" />
        </div>
        <div class="settings-actions" style="margin-top:.8rem;gap:.6rem">
            <button class="btn-primary" @onclick="CreateBackup" disabled="@backupBusy">
                @(backupBusy ? "Exporting…" : "Create Backup")
            </button>
            @if (!string.IsNullOrEmpty(backupMsg))
            {
                <span class="@(backupMsg.StartsWith("✗") ? "text-error" : "save-confirm")">@backupMsg</span>
            }
        </div>
    </section>

    <!-- ── Danger Zone ────────────────────────────────────────────────────── -->
    <section class="settings-section settings-section-danger">
        <h2>Danger Zone</h2>
        <p class="section-note">
            Permanently delete all collected data from the database. The schema (tables, indexes, migrations)
            is preserved. Login credentials and payment configuration are NOT cleared.
        </p>
        <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
            <button class="btn-danger" @onclick="TruncateAll" disabled="@truncateBusy">
                @(truncateBusy ? "Truncating…" : "Truncate All Data")
            </button>
            @if (!string.IsNullOrEmpty(truncateMsg))
            {
                <span class="@(truncateMsg.StartsWith("✗") ? "text-error" : "save-confirm")">@truncateMsg</span>
            }
        </div>
        <p class="section-note" style="margin-top:.5rem;color:var(--color-error,#c0392b)">
            Clears: Jurisdictions · TaxRates · ZipCodes · TaxCategories · TaxCategoryRules ·
            ExciseTaxRates · ScrapeRuns · ChangeLog · SourceDocuments · Subscribers · BillingRecords · LogEntries
        </p>
    </section>

</div>
}

@code {
    private bool saved;
    private bool adminBusy;
    private bool isAdmin;
    private bool effectiveIsAdmin;
    private string? adminStatus;
    private PricingConfig? pricing;
    private PayPalConfig? paypal;

    // ── URL validation state ──────────────────────────────────────────────────
    private bool checkingUrls;
    private readonly Dictionary<string, bool?> urlStatus = new();

    private Dictionary<string, Func<string>> UrlMap => new()
    {
        ["CensusCountyGaz"]     = () => settings.Current.CensusCountyGazUrl,
        ["CensusPlaceGaz"]      = () => settings.Current.CensusPlaceGazUrl,
        ["CensusZctaCounty"]    = () => settings.Current.CensusZctaCountyUrl,
        ["CensusZctaPlace"]     = () => settings.Current.CensusZctaPlaceUrl,
        ["SstAgreement"]        = () => settings.Current.SstAgreementUrl,
        ["SstTaxabilityMatrix"] = () => settings.Current.SstTaxabilityMatrixUrl,
        ["SstMemberStates"]     = () => settings.Current.SstMemberStatesUrl,
    };

    private List<string> UrlKeys => UrlMap.Keys.ToList();
    private List<string> FailedSources => UrlKeys.Where(k => urlStatus.TryGetValue(k, out var s) && s == false).ToList();
    private List<string> UncheckedSources => UrlKeys.Where(k => !urlStatus.ContainsKey(k)).ToList();

    private string UrlStatusIcon(string key) =>
        urlStatus.TryGetValue(key, out var s) ? (s == true ? "✓" : (s == false ? "✗" : "?")) : "?";

    private string UrlStatusClass(string key) =>
        urlStatus.TryGetValue(key, out var s)
            ? (s == true ? "ds-url-ok" : (s == false ? "ds-url-fail" : "ds-url-unknown"))
            : "ds-url-unknown";

    // ── Backup state ──────────────────────────────────────────────────────────
    private bool backupBusy;
    private string? backupMsg;
    private string backupPath = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
        $"TaxRateCollector_{DateTime.Now:yyyyMMdd}.bacpac");

    // ── Truncate state ────────────────────────────────────────────────────────
    private bool truncateBusy;
    private string? truncateMsg;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = auth.User.Identity?.IsAuthenticated == true;
        effectiveIsAdmin = ViewAs.EffectiveIsAdmin(isAdmin);

        await using var db = await DbFactory.CreateDbContextAsync();
        pricing = await db.PricingConfigs.FirstOrDefaultAsync();
        paypal = await db.PayPalConfigs.FirstOrDefaultAsync();
    }

    protected override void OnParametersSet()
    {
        effectiveIsAdmin = ViewAs.EffectiveIsAdmin(isAdmin);
    }

    private async Task CheckAllSources()
    {
        checkingUrls = true;
        StateHasChanged();

        var map = UrlMap;
        using var http = HttpClientFactory.CreateClient();
        http.Timeout = TimeSpan.FromSeconds(10);

        var tasks = map.Select(async kv =>
        {
            var url = kv.Value();
            if (string.IsNullOrWhiteSpace(url)) return (kv.Key, false);
            try
            {
                using var req = new HttpRequestMessage(HttpMethod.Head, url);
                using var resp = await http.SendAsync(req, HttpCompletionOption.ResponseHeadersRead);
                return (kv.Key, resp.IsSuccessStatusCode || (int)resp.StatusCode < 400);
            }
            catch
            {
                return (kv.Key, false);
            }
        });

        var results = await Task.WhenAll(tasks);
        foreach (var (key, ok) in results)
            urlStatus[key] = ok;

        checkingUrls = false;
        StateHasChanged();
    }

    private async Task CreateBackup()
    {
        if (string.IsNullOrWhiteSpace(backupPath)) return;
        backupBusy = true;
        backupMsg = null;
        StateHasChanged();

        try
        {
            var connStr = Configuration.GetConnectionString("DefaultConnection") ?? "";
            var server = "";
            var database = "";
            foreach (var part in connStr.Split(';', StringSplitOptions.RemoveEmptyEntries))
            {
                var kv = part.Split('=', 2);
                if (kv.Length < 2) continue;
                var key = kv[0].Trim();
                var val = kv[1].Trim();
                if (key.Equals("Server", StringComparison.OrdinalIgnoreCase) ||
                    key.Equals("Data Source", StringComparison.OrdinalIgnoreCase))
                    server = val;
                else if (key.Equals("Database", StringComparison.OrdinalIgnoreCase) ||
                         key.Equals("Initial Catalog", StringComparison.OrdinalIgnoreCase))
                    database = val;
            }

            var dir = Path.GetDirectoryName(backupPath);
            if (!string.IsNullOrEmpty(dir)) Directory.CreateDirectory(dir);

            var sw = System.Diagnostics.Stopwatch.StartNew();
            using var proc = new System.Diagnostics.Process();
            proc.StartInfo = new System.Diagnostics.ProcessStartInfo
            {
                FileName = "sqlpackage",
                Arguments = $"/Action:Export /SourceServerName:\"{server}\" /SourceDatabaseName:\"{database}\" /TargetFile:\"{backupPath}\"",
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };
            proc.Start();
            await proc.WaitForExitAsync();
            sw.Stop();

            if (proc.ExitCode == 0)
                backupMsg = $"✓ Saved to {backupPath} ({sw.Elapsed.TotalSeconds:F1}s)";
            else
            {
                var err = await proc.StandardError.ReadToEndAsync();
                backupMsg = $"✗ sqlpackage exited {proc.ExitCode}: {err.Split('\n').FirstOrDefault()?.Trim()}";
            }
        }
        catch (Exception ex)
        {
            backupMsg = $"✗ {ex.Message}";
        }
        finally
        {
            backupBusy = false;
            StateHasChanged();
        }
    }

    private async Task TruncateAll()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "TRUNCATE ALL DATA?\n\n" +
            "This permanently deletes:\n" +
            "  • All jurisdictions, tax rates, ZIP codes\n" +
            "  • All tax categories and rules\n" +
            "  • All scrape runs, source documents, change log\n" +
            "  • All subscribers, billing records, log entries\n\n" +
            "Login credentials and payment config are preserved.\n\n" +
            "This cannot be undone. Continue?");
        if (!confirmed) return;

        truncateBusy = true;
        truncateMsg = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.Database.ExecuteSqlRawAsync("DELETE FROM BillingRecords");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM SubscribedStates");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM Subscribers");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM LogEntries");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ChangeLog");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ExciseSourceDocuments");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ExciseTaxRates");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM SourceDocuments");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxRates");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ScrapeRuns");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ZipCodes");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategoryRules");
            await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories NOCHECK CONSTRAINT ALL");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM TaxCategories");
            await db.Database.ExecuteSqlRawAsync("ALTER TABLE TaxCategories WITH CHECK CHECK CONSTRAINT ALL");
            await db.Database.ExecuteSqlRawAsync("DELETE FROM Jurisdictions");

            truncateMsg = "✓ All data cleared.";
        }
        catch (Exception ex)
        {
            truncateMsg = $"✗ {ex.Message}";
        }
        finally
        {
            truncateBusy = false;
            StateHasChanged();
        }
    }

    private async Task SetTheme(string theme)
    {
        settings.SetTheme(theme);
        await JS.InvokeVoidAsync("applyTheme", theme);
        StateHasChanged();
    }

    private async Task SetFont(string font)
    {
        settings.Current.Font = font;
        await JS.InvokeVoidAsync("applyFont", font, settings.Current.FontSize);
        StateHasChanged();
    }

    private async Task Save()
    {
        settings.Save();
        saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        saved = false;
        StateHasChanged();
    }

    private async Task SavePricing()
    {
        if (pricing is null) return;
        adminBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            pricing.UpdatedAt = DateTime.UtcNow.ToString("o");
            db.PricingConfigs.Update(pricing);
            await db.SaveChangesAsync();
            SetAdminStatus("✓ Pricing saved");
        }
        catch (Exception ex) { SetAdminStatus($"✗ {ex.Message}"); }
        finally { adminBusy = false; }
    }

    private async Task SavePayPal()
    {
        if (paypal is null) return;
        adminBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            paypal.UpdatedAt = DateTime.UtcNow.ToString("o");
            db.PayPalConfigs.Update(paypal);
            await db.SaveChangesAsync();
            SetAdminStatus("✓ PayPal config saved");
        }
        catch (Exception ex) { SetAdminStatus($"✗ {ex.Message}"); }
        finally { adminBusy = false; }
    }

    private void SetAdminStatus(string msg)
    {
        adminStatus = msg;
        StateHasChanged();
        _ = Task.Delay(3000).ContinueWith(_ => { adminStatus = null; InvokeAsync(StateHasChanged); });
    }
}
