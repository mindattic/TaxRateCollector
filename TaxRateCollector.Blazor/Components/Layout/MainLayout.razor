@inherits LayoutComponentBase
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Infrastructure.Data
@inject NavigationManager Nav
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="app-shell">
    <header class="app-header" role="banner">
        <div class="brand">
            <span class="brand-icon" aria-hidden="true">◈</span>
            <span class="brand-name">TaxRateCollector</span>
        </div>
        <div class="user-nav" aria-label="User account">
            <AuthorizeView>
                <Authorized>
                    <div class="user-dropdown @(dropdownOpen ? "user-dropdown-open" : "")">
                        <button type="button"
                                class="user-nav-link"
                                aria-haspopup="menu"
                                aria-expanded="@dropdownOpen.ToString().ToLower()"
                                aria-controls="user-menu"
                                @onclick="ToggleDropdown"
                                @onclick:stopPropagation="true">
                            <span aria-hidden="true">👤</span>
                            <span>@context.User.Identity?.Name</span>
                            <span aria-hidden="true">▾</span>
                        </button>
                        @if (dropdownOpen)
                        {
                            <div id="user-menu" class="user-dropdown-menu" role="menu" @onclick:stopPropagation="true">
                                <a href="/settings" class="user-dropdown-item" role="menuitem" @onclick="CloseDropdown">
                                    <span aria-hidden="true">⚙</span> Settings
                                </a>
                                <form method="post" action="/logout" style="margin:0">
                                    <AntiforgeryToken />
                                    <button type="submit" class="user-dropdown-item user-dropdown-item-danger" role="menuitem">
                                        <span aria-hidden="true">⏻</span> Log Out
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="user-nav-link">Log In</a>
                    <a href="/register" class="btn-subscribe-sm">Sign Up</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <nav class="tab-bar" aria-label="Primary">
        <NavLink class="tab" href="" Match="NavLinkMatch.All">
            <span class="tab-icon" aria-hidden="true">◈</span>
            <span class="tab-label">Jurisdictions</span>
        </NavLink>
        <NavLink class="tab" href="glossary">
            <span class="tab-icon" aria-hidden="true">☰</span>
            <span class="tab-label">Glossary</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="tab" href="logs">
                    <span class="tab-icon" aria-hidden="true">◎</span>
                    <span class="tab-label">Logs</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Administrator">
            <Authorized>
                <NavLink class="tab tab-admin" href="review">
                    <span class="tab-icon" aria-hidden="true">✓</span>
                    <span class="tab-label">
                        Review
                        @if (reviewCount > 0)
                        {
                            <span class="tab-badge" aria-label="@reviewCount items pending review">@reviewCount</span>
                        }
                    </span>
                </NavLink>
                <NavLink class="tab tab-admin" href="setup">
                    <span class="tab-icon" aria-hidden="true">⚒</span>
                    <span class="tab-label">Setup</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </nav>

    <main id="main-content" class="tab-content" tabindex="-1">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet role="alert" aria-live="assertive">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <button type="button" class="dismiss" aria-label="Dismiss error">
        <span aria-hidden="true">🗙</span>
    </button>
</div>

@code {
    private bool dropdownOpen;
    private int reviewCount;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        reviewCount = await db.TaxRates.CountAsync(t => !t.AutoApprove);
    }

    private void ToggleDropdown() => dropdownOpen = !dropdownOpen;
    private void CloseDropdown() => dropdownOpen = false;
}
