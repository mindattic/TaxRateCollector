<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal"
        data-nosnippet
        aria-labelledby="components-reconnect-title"
        aria-describedby="components-reconnect-desc">
    <div class="components-reconnect-container">
        <h2 id="components-reconnect-title" class="sr-only">Connection status</h2>
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p id="components-reconnect-desc" class="components-reconnect-first-attempt-visible" role="status" aria-live="polite">
            Rejoining the server...
        </p>
        <p class="components-reconnect-repeated-attempt-visible" role="status" aria-live="polite">
            Rejoin failed... trying again in <span id="components-seconds-to-next-attempt"></span> seconds.
        </p>
        <p class="components-reconnect-failed-visible" role="alert">
            Failed to rejoin.<br />Please retry or reload the page.
        </p>
        <button id="components-reconnect-button"
                type="button"
                class="components-reconnect-failed-visible"
                aria-label="Retry connection to server">
            Retry
        </button>
        <p class="components-pause-visible" role="status" aria-live="polite">
            The session has been paused by the server.
        </p>
        <p class="components-resume-failed-visible" role="alert">
            Failed to resume the session.<br />Please retry or reload the page.
        </p>
        <button id="components-resume-button"
                type="button"
                class="components-pause-visible components-resume-failed-visible"
                aria-label="Resume session">
            Resume
        </button>
    </div>
</dialog>
