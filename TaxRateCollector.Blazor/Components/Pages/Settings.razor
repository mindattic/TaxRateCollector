@page "/settings"
@attribute [Authorize]
@inject TaxRateCollector.Infrastructure.Services.SettingsService settings
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Settings — TaxRateCollector</PageTitle>

<div class="page-header">
    <h1 class="page-title">Settings</h1>
    <p class="page-sub">Appearance preferences. Admin configuration lives in <a href="/setup">Setup</a>.</p>
</div>

<div class="settings-grid">

    <section class="settings-section" aria-labelledby="appearance-heading">
        <h2 id="appearance-heading">Appearance</h2>
        <div class="setting-row">
            <label class="setting-label" for="settings-theme">Theme</label>
            <select id="settings-theme" class="setting-input" style="max-width:220px"
                    value="@settings.Current.Theme"
                    @onchange="e => SetTheme(e.Value?.ToString() ?? settings.Current.Theme)">
                <option value="light">☀ Light</option>
                <option value="dark">☾ Dark</option>
                <option value="spring">🌸 Spring</option>
                <option value="summer">☀ Summer</option>
                <option value="autumn">🍂 Autumn</option>
                <option value="winter">❄ Winter</option>
                <option value="tutor">📘 Tutor</option>
                <option value="llm">🤖 LLM</option>
                <option value="samurai">⚔ Samurai</option>
            </select>
        </div>
        <div class="setting-row">
            <label class="setting-label" for="settings-font">Font</label>
            <select id="settings-font" class="setting-input" style="max-width:220px"
                    value="@settings.Current.Font"
                    @onchange="e => SetFont(e.Value?.ToString() ?? settings.Current.Font)">
                <option value="outfit">Outfit</option>
                <option value="roboto">Roboto</option>
                <option value="lato">Lato</option>
                <option value="calibri">Calibri</option>
                <option value="arial">Arial</option>
                <option value="times">Times New Roman</option>
            </select>
        </div>
    </section>

    <div class="settings-actions">
        <button type="button" class="btn-primary" @onclick="Save">Save Settings</button>
        <span class="save-confirm" role="status" aria-live="polite">@(saved ? "✓ Saved" : "")</span>
    </div>

</div>

@code {
    private bool saved;

    private async Task SetTheme(string theme)
    {
        settings.SetTheme(theme);
        await JS.InvokeVoidAsync("applyTheme", theme);
        StateHasChanged();
    }

    private async Task SetFont(string font)
    {
        settings.Current.Font = font;
        await JS.InvokeVoidAsync("applyFont", font, settings.Current.FontSize);
        StateHasChanged();
    }

    private async Task Save()
    {
        settings.Save();
        saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        saved = false;
        StateHasChanged();
    }
}
