@page "/rates"
@using System.Text
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Rates — TaxRateCollector</PageTitle>

<h1>Rates Browser</h1>

<div class="filter-row">
    <input class="filter-input" placeholder="Search jurisdiction…" @bind="search" @bind:event="oninput" />
    <select class="filter-select" @bind="stateFilter">
        <option value="">All States</option>
        <option value="IL">Illinois</option>
        <option value="CA">California</option>
        <option value="TX">Texas</option>
    </select>
    <button class="btn-secondary" @onclick="ExportCsv">Export CSV</button>
</div>

@if (rates is null)
{
    <p class="muted">Loading…</p>
}
else if (rates.Count == 0)
{
    <p class="muted">No rates found.</p>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th @onclick='() => SetSort("name")' class="sortable">Jurisdiction @SortIcon("name")</th>
                <th @onclick='() => SetSort("state")' class="sortable">State @SortIcon("state")</th>
                <th @onclick='() => SetSort("type")' class="sortable">Type @SortIcon("type")</th>
                <th @onclick='() => SetSort("rate")' class="sortable">Rate @SortIcon("rate")</th>
                <th>Rate Type</th>
                <th>Effective</th>
                <th>Scraped</th>
                <th>Statute / Conditions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Filtered)
            {
                <tr>
                    <td>@r.JurisdictionName</td>
                    <td>@r.StateCode</td>
                    <td>@r.JurisdictionType</td>
                    <td class="rate-cell">@r.Rate.ToString("P4")</td>
                    <td>@r.Name</td>
                    <td>@r.EffectiveDate</td>
                    <td>@r.ScrapedAt[..10]</td>
                    <td class="conditions-cell" title="@r.Conditions">@r.Conditions</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="muted" style="margin-top:8px">Showing @Filtered.Count() of @rates.Count rates</div>
}

@code {
    private List<RateRow>? rates;
    private string search = string.Empty;
    private string stateFilter = string.Empty;
    private string sortCol = "state";
    private bool sortAsc = true;

    private record RateRow(string JurisdictionName, string StateCode, string JurisdictionType,
        decimal Rate, string Name, string EffectiveDate, string ScrapedAt, string Conditions);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        rates = await db.TaxRates
            .Include(t => t.Jurisdiction)
            .Where(t => t.IsCurrent)
            .Select(t => new RateRow(
                t.Jurisdiction.JurisdictionName,
                t.Jurisdiction.StateCode,
                t.Jurisdiction.JurisdictionType.ToString(),
                t.Rate,
                t.Name,
                t.EffectiveDate != null ? t.EffectiveDate.Value.ToString() : "",
                t.ScrapedAt,
                t.Conditions ?? ""))
            .ToListAsync();
    }

    private IEnumerable<RateRow> Filtered
    {
        get
        {
            var q = rates?.AsEnumerable() ?? Enumerable.Empty<RateRow>();
            if (!string.IsNullOrWhiteSpace(search))
                q = q.Where(r => r.JurisdictionName.Contains(search, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(stateFilter))
                q = q.Where(r => r.StateCode == stateFilter);

            q = sortCol switch
            {
                "name" => sortAsc ? q.OrderBy(r => r.JurisdictionName) : q.OrderByDescending(r => r.JurisdictionName),
                "state" => sortAsc ? q.OrderBy(r => r.StateCode) : q.OrderByDescending(r => r.StateCode),
                "type" => sortAsc ? q.OrderBy(r => r.JurisdictionType) : q.OrderByDescending(r => r.JurisdictionType),
                "rate" => sortAsc ? q.OrderBy(r => r.Rate) : q.OrderByDescending(r => r.Rate),
                _ => q
            };
            return q;
        }
    }

    private void SetSort(string col)
    {
        if (sortCol == col) sortAsc = !sortAsc;
        else { sortCol = col; sortAsc = true; }
    }

    private string SortIcon(string col) =>
        sortCol != col ? "" : sortAsc ? " ▲" : " ▼";

    private async Task ExportCsv()
    {
        var rows = Filtered.ToList();
        var sb = new StringBuilder();
        sb.AppendLine("Jurisdiction,State,Type,Rate,RateName,EffectiveDate,Scraped,Conditions");
        foreach (var r in rows)
        {
            sb.Append(Csv(r.JurisdictionName)).Append(',')
              .Append(Csv(r.StateCode)).Append(',')
              .Append(Csv(r.JurisdictionType)).Append(',')
              .Append(r.Rate.ToString("0.######")).Append(',')
              .Append(Csv(r.Name)).Append(',')
              .Append(Csv(r.EffectiveDate)).Append(',')
              .Append(Csv(r.ScrapedAt.Length >= 10 ? r.ScrapedAt[..10] : r.ScrapedAt)).Append(',')
              .AppendLine(Csv(r.Conditions));
        }

        var fileName = $"TaxRates_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
        var bytes    = Encoding.UTF8.GetPreamble().Concat(Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
        var base64   = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadBase64File", fileName, "text/csv", base64);
    }

    private static string Csv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        var needsQuote = value.IndexOfAny(['"', ',', '\n', '\r']) >= 0;
        var escaped    = value.Replace("\"", "\"\"");
        return needsQuote ? $"\"{escaped}\"" : escaped;
    }
}
