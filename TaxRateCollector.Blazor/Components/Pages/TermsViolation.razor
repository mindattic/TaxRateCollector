@page "/terms-violation"
@layout TaxRateCollector.Blazor.Components.Layout.MainLayout

<PageTitle>Terms Violation — TaxRateCollector</PageTitle>

<div class="violation-page">
    <section class="violation-card" role="alert" aria-labelledby="violation-title">
        <div class="violation-icon" aria-hidden="true">⚠</div>
        <h1 id="violation-title" class="violation-title">Terms of Agreement Violated</h1>
        <p class="violation-body">
            An attempt was detected to tamper with the evidence reader's security overlay.
            This session has been flagged. Data exfiltration from licensed evidence documents
            is strictly prohibited under your subscription agreement.
        </p>
        <p class="violation-body">
            If you believe this is an error, please contact
            <a href="mailto:support@mindattic.com">support@mindattic.com</a>.
        </p>
        <a href="/" class="btn-primary">Return to Application</a>
    </section>
</div>
