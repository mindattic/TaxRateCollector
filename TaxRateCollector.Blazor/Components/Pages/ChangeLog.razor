@page "/changes"
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Infrastructure.Data
@using TaxRateCollector.Infrastructure.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AlertService Alerts
@rendermode InteractiveServer

<PageTitle>Change Log — TaxRateCollector</PageTitle>

<h1 id="changelog-title">Change Log</h1>

<div class="filter-row" role="search" aria-label="Filter change log">
    <label for="changelog-type" class="sr-only">Change type</label>
    <select id="changelog-type" class="filter-select" @bind="typeFilter">
        <option value="">All Types</option>
        <option value="RateChanged">Rate Changed</option>
        <option value="NewJurisdiction">New Jurisdiction</option>
        <option value="Removed">Removed</option>
    </select>
    <label class="filter-check">
        <input type="checkbox" @bind="unackOnly" /> Unacknowledged only
    </label>
    <button type="button" class="btn-secondary" @onclick="AcknowledgeAllAsync">Acknowledge All</button>
</div>

@if (entries is null)
{
    <p class="muted" role="status" aria-live="polite">Loading…</p>
}
else if (!Filtered.Any())
{
    <p class="muted" role="status" aria-live="polite">No changes found.</p>
}
else
{
    <ol class="timeline" aria-labelledby="changelog-title">
        @foreach (var e in Filtered)
        {
            <li class="timeline-item change-@e.ChangeType.ToString().ToLower()">
                <div class="timeline-dot" aria-hidden="true"></div>
                <div class="timeline-body">
                    <div class="timeline-header">
                        <span class="badge badge-@e.ChangeType.ToString().ToLower()" aria-label="Change type: @e.ChangeType">@e.ChangeType</span>
                        <strong>@e.Jurisdiction?.JurisdictionName (@e.Jurisdiction?.StateCode)</strong>
                        <time class="muted" datetime="@e.DetectedAt">@e.DetectedAt</time>
                        @if (!e.Acknowledged)
                        {
                            <button type="button"
                                    class="btn-tiny"
                                    aria-label="Dismiss change for @e.Jurisdiction?.JurisdictionName"
                                    @onclick="() => AcknowledgeAsync(e.Id)">Dismiss</button>
                        }
                        else
                        {
                            <span class="badge badge-ack" aria-label="Already acknowledged">Acknowledged</span>
                        }
                    </div>
                    <div class="timeline-detail">
                        @if (e.OldRate.HasValue) { <span>Was: <strong>@e.OldRate.Value.ToString("P4")</strong></span> }
                        @if (e.NewRate.HasValue) { <span>Now: <strong>@e.NewRate.Value.ToString("P4")</strong></span> }
                    </div>
                </div>
            </li>
        }
    </ol>
}

@code {
    private List<TaxRateCollector.Core.Entities.ChangeLogEntry>? entries;
    private string typeFilter = string.Empty;
    private bool unackOnly;

    private IEnumerable<TaxRateCollector.Core.Entities.ChangeLogEntry> Filtered
    {
        get
        {
            var q = entries?.AsEnumerable() ?? Enumerable.Empty<TaxRateCollector.Core.Entities.ChangeLogEntry>();
            if (!string.IsNullOrEmpty(typeFilter) && Enum.TryParse<ChangeType>(typeFilter, out var ct))
                q = q.Where(e => e.ChangeType == ct);
            if (unackOnly) q = q.Where(e => !e.Acknowledged);
            return q;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        entries = await db.ChangeLog
            .Include(c => c.Jurisdiction)
            .OrderByDescending(c => c.DetectedAt)
            .ToListAsync();
    }

    private async Task AcknowledgeAsync(int id)
    {
        await Alerts.AcknowledgeAsync(id);
        await LoadAsync();
    }

    private async Task AcknowledgeAllAsync()
    {
        await Alerts.AcknowledgeAllAsync();
        await LoadAsync();
    }
}
