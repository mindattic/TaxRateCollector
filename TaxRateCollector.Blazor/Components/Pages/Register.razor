@page "/register"
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserMgr
@inject SignInManager<IdentityUser> SignIn
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Create Account — TaxRateCollector</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-logo">◈ TaxRateCollector</div>
        <h2 class="auth-title">Create your account</h2>
        <p class="auth-sub muted">Browse the full jurisdiction hierarchy. Subscribe by state to unlock rates and evidence.</p>

        @if (errors.Count > 0)
        {
            <div class="auth-error">
                @foreach (var e in errors) { <div>@e</div> }
            </div>
        }

        <div class="auth-field">
            <label>Email</label>
            <input type="email" class="setting-input" placeholder="you@example.com"
                   @bind="email" @bind:event="oninput" />
        </div>
        <div class="auth-field">
            <label>Password <span class="muted">(min 8 chars, at least one digit)</span></label>
            <input type="password" class="setting-input" placeholder="••••••••"
                   @bind="password" @bind:event="oninput" />
        </div>
        <div class="auth-field">
            <label>Confirm password</label>
            <input type="password" class="setting-input" placeholder="••••••••"
                   @bind="confirm" @bind:event="oninput" />
        </div>

        <button class="btn-primary auth-btn" @onclick="Submit" disabled="@busy">
            @(busy ? "Creating account…" : "Create Account")
        </button>

        <div class="auth-links">
            <span class="muted">Already have an account?</span>
            <a href="/login">Log in</a>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string confirm = "";
    private List<string> errors = [];
    private bool busy;

    private async Task Submit()
    {
        errors.Clear();
        if (password != confirm) { errors.Add("Passwords do not match."); return; }

        busy = true;
        StateHasChanged();

        var user = new IdentityUser { UserName = email, Email = email };
        var result = await UserMgr.CreateAsync(user, password);

        if (result.Succeeded)
        {
            await SignIn.SignInAsync(user, isPersistent: false);
            Nav.NavigateTo("/subscribe", forceLoad: true);
        }
        else
        {
            errors = result.Errors.Select(e => e.Description).ToList();
            busy = false;
        }
    }
}
