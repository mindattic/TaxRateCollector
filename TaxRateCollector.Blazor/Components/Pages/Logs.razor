@page "/logs"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Logs — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 id="logs-title" class="page-title">Application Logs</h1>
            <p class="page-sub" aria-live="polite">@totalCount records · auto-refreshes every 10 s</p>
        </div>
        <div class="header-actions">
            <label for="logs-clear" class="sr-only">Clear logs</label>
            <select id="logs-clear"
                    class="btn-export-select"
                    value="@clearRange"
                    @onchange="OnClearChange"
                    disabled="@busy"
                    aria-busy="@busy.ToString().ToLower()">
                <option value="">@(busy ? "Clearing…" : "Clear logs ▾")</option>
                <option value="hour">Last hour</option>
                <option value="day">Last 24 hours</option>
                <option value="week">Last 7 days</option>
                <option value="month">Last 4 weeks</option>
                <option value="all">All time</option>
            </select>
        </div>
    </div>
</div>

<!-- Filter bar -->
<div class="log-filter-bar" role="search" aria-label="Filter log entries">
    <div class="log-level-pills" role="group" aria-label="Filter by log level">
        @foreach (var lvl in levels)
        {
            <button type="button"
                    class="log-level-pill log-pill-@lvl.ToLower() @(levelFilter == lvl ? "log-pill-active" : "")"
                    aria-pressed="@((levelFilter == lvl).ToString().ToLower())"
                    @onclick="() => SetLevel(lvl)">@lvl</button>
        }
    </div>
    <label for="logs-search" class="sr-only">Search log messages or source</label>
    <input id="logs-search"
           class="setting-input log-search"
           type="search"
           placeholder="Search message or context…"
           aria-controls="logs-table"
           @bind="search" @bind:event="oninput" @bind:after="OnSearchInput" />
</div>

@if (loading)
{
    <div class="loading-state" role="status" aria-live="polite">Loading…</div>
}
else if (entries.Count == 0)
{
    <div class="muted" style="padding:2rem;text-align:center" role="status" aria-live="polite">No log entries found.</div>
}
else
{
    <div class="log-table-wrap">
        <table id="logs-table" class="data-table log-table" aria-labelledby="logs-title">
            <caption class="sr-only">Application log entries — click a row with an exception to expand its stack trace.</caption>
            <thead>
                <tr>
                    <th scope="col" style="width:160px">Timestamp</th>
                    <th scope="col" style="width:140px">Level</th>
                    <th scope="col">Message</th>
                    <th scope="col" style="width:220px">Source</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    var isExpandable = e.Exception is not null;
                    var isExpanded = expanded.Contains(e.Id);
                    <tr class="log-row @(isExpandable ? "log-row-expandable" : "")"
                        tabindex="@(isExpandable ? 0 : -1)"
                        role="@(isExpandable ? "button" : null)"
                        aria-expanded="@(isExpandable ? isExpanded.ToString().ToLower() : null)"
                        @onclick="() => ToggleExpand(e.Id)"
                        @onkeydown="ev => OnRowKey(ev, e.Id, isExpandable)">
                        <td class="mono" style="font-size:.73rem">@e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><span class="log-badge log-badge-@e.Level.ToLower()" aria-label="Level: @e.Level">@e.Level</span></td>
                        <td class="log-message">
                            @e.Message
                            @if (isExpanded && e.Exception is not null)
                            {
                                <pre class="log-exception" tabindex="0">@e.Exception</pre>
                            }
                        </td>
                        <td class="mono muted" style="font-size:.70rem">@TrimSource(e.SourceContext)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <nav class="log-pagination" aria-label="Log pagination">
        <button type="button" class="btn-tiny" @onclick="PrevPage" disabled="@(page == 0)" aria-label="Previous page">
            <span aria-hidden="true">←</span> Prev
        </button>
        <span class="muted small" role="status" aria-live="polite">Page @(page + 1) of @TotalPages · @totalCount entries</span>
        <button type="button" class="btn-tiny" @onclick="NextPage" disabled="@(page >= TotalPages - 1)" aria-label="Next page">
            Next <span aria-hidden="true">→</span>
        </button>
    </nav>
}

@if (status is not null)
{
    <div class="auth-error" style="max-width:480px;margin-top:.5rem" role="alert">@status</div>
}

@code {
    private static readonly string[] levels = ["All", "Information", "Warning", "Error", "Fatal"];
    private const int PageSize = 50;

    private bool loading = true;
    private bool busy;
    private string? status;
    private string clearRange = "";

    private string levelFilter = "All";
    private string search = "";
    private int page;
    private int totalCount;
    private List<LogEntry> entries = [];
    private HashSet<long> expanded = [];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(totalCount / (double)PageSize));

    private Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
        timer = new Timer(async _ =>
        {
            await Reload();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task Reload()
    {
        loading = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var q = db.LogEntries.AsQueryable();

            if (levelFilter != "All")
                q = q.Where(l => l.Level == levelFilter);

            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(l => (l.Message != null && l.Message.Contains(s)) ||
                                  (l.SourceContext != null && l.SourceContext.Contains(s)));
            }

            totalCount = await q.CountAsync();

            entries = await q
                .OrderByDescending(l => l.Timestamp)
                .Skip(page * PageSize)
                .Take(PageSize)
                .ToListAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SetLevel(string lvl)
    {
        levelFilter = lvl;
        page = 0;
        await Reload();
    }

    private async Task OnSearchInput()
    {
        page = 0;
        await Reload();
        StateHasChanged();
    }

    private async Task PrevPage()
    {
        if (page > 0) { page--; await Reload(); }
    }

    private async Task NextPage()
    {
        if (page < TotalPages - 1) { page++; await Reload(); }
    }

    private void ToggleExpand(long id)
    {
        if (!expanded.Remove(id)) expanded.Add(id);
    }

    private void OnRowKey(KeyboardEventArgs e, long id, bool isExpandable)
    {
        if (!isExpandable) return;
        if (e.Key == "Enter" || e.Key == " " || e.Code == "Space") ToggleExpand(id);
    }

    private async Task OnClearChange(ChangeEventArgs e)
    {
        var range = e.Value?.ToString();
        clearRange = "";
        if (string.IsNullOrEmpty(range)) return;

        busy = true;
        status = null;
        StateHasChanged();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            int deleted;
            if (range == "all")
            {
                deleted = await db.LogEntries.ExecuteDeleteAsync();
            }
            else
            {
                var cutoff = range switch
                {
                    "hour"  => DateTime.UtcNow.AddHours(-1),
                    "day"   => DateTime.UtcNow.AddDays(-1),
                    "week"  => DateTime.UtcNow.AddDays(-7),
                    "month" => DateTime.UtcNow.AddDays(-28),
                    _       => DateTime.UtcNow.AddDays(-7)
                };
                deleted = await db.LogEntries
                    .Where(l => l.Timestamp < cutoff)
                    .ExecuteDeleteAsync();
            }

            var label = range switch
            {
                "hour"  => "the last hour",
                "day"   => "the last 24 hours",
                "week"  => "the last 7 days",
                "month" => "the last 4 weeks",
                "all"   => "all time",
                _       => range
            };
            status = $"Deleted {deleted:N0} entries from {label}.";
            page = 0;
            await Reload();
        }
        catch (Exception ex) { status = $"Error: {ex.Message}"; }
        finally { busy = false; StateHasChanged(); }
    }

    private static string? TrimSource(string? src)
    {
        if (src is null) return null;
        // Show only the last two namespace segments for brevity
        var parts = src.Split('.');
        return parts.Length <= 2 ? src : string.Join(".", parts[^2..]);
    }

    public void Dispose() => timer?.Dispose();
}
