@page "/calc"
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Core.Interfaces
@using TaxRateCollector.Infrastructure.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ITaxCalculator Calculator
@rendermode InteractiveServer

<PageTitle>Tax Calculator — TaxRateCollector</PageTitle>

<h1 id="calc-title">Tax Calculator</h1>

<form class="calc-form" role="form" aria-labelledby="calc-title" @onsubmit="CalculateAsync" @onsubmit:preventDefault="true">
    <div class="form-group">
        <label for="calc-jurisdiction">Jurisdiction</label>
        <input id="calc-jurisdiction"
               class="filter-input"
               type="search"
               role="combobox"
               aria-expanded="@((suggestions.Count > 0 && !jurisdictionSelected).ToString().ToLower())"
               aria-controls="calc-jurisdiction-list"
               aria-autocomplete="list"
               aria-required="true"
               required
               placeholder="Type to search…"
               value="@searchText"
               @oninput="OnSearchInput" />
        @if (suggestions.Count > 0 && !jurisdictionSelected)
        {
            <ul id="calc-jurisdiction-list" class="suggestions" role="listbox" aria-label="Jurisdiction suggestions">
                @foreach (var j in suggestions)
                {
                    <li class="suggestion-item"
                        role="option"
                        tabindex="0"
                        aria-selected="false"
                        @onclick="() => SelectJurisdiction(j)"
                        @onkeydown="ev => OnSuggestKey(ev, j)">
                        @j.Name (@j.StateCode) — @j.Type
                    </li>
                }
            </ul>
        }
        @if (jurisdictionSelected)
        {
            <div class="selected-tag" role="status" aria-live="polite">
                <span>@selectedName</span>
                <button type="button"
                        class="btn-tiny"
                        aria-label="Clear selected jurisdiction"
                        @onclick="ClearJurisdiction">
                    <span aria-hidden="true">✕</span>
                </button>
            </div>
        }
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="calc-price">Price ($)</label>
            <input id="calc-price" class="filter-input" type="number" inputmode="decimal" min="0" step="0.01" required aria-required="true" @bind="price" />
        </div>
        <div class="form-group">
            <label for="calc-qty">Quantity</label>
            <input id="calc-qty" class="filter-input" type="number" inputmode="numeric" min="1" required aria-required="true" @bind="quantity" />
        </div>
    </div>

    <details style="margin-top:8px">
        <summary style="cursor:pointer;color:var(--muted)">Advanced options</summary>
        <fieldset class="form-row" style="margin-top:8px;border:0;padding:0">
            <legend class="sr-only">Advanced calculation options</legend>
            <div class="form-group">
                <label for="calc-abv">ABV % (for excise)</label>
                <input id="calc-abv" class="filter-input" type="number" inputmode="decimal" min="0" max="100" step="0.1" @bind="abvPct" placeholder="e.g. 5" />
            </div>
            <div class="form-group">
                <label for="calc-vol">Volume per unit (gal)</label>
                <input id="calc-vol" class="filter-input" type="number" inputmode="decimal" min="0" step="0.001" @bind="volumeGal" placeholder="e.g. 0.5" />
            </div>
            <div class="form-group">
                <label for="calc-wt">Weight per unit (oz)</label>
                <input id="calc-wt" class="filter-input" type="number" inputmode="decimal" min="0" step="0.001" @bind="weightOz" placeholder="e.g. 12" />
            </div>
            <div class="form-group">
                <label for="calc-wholesale">Wholesale price ($)</label>
                <input id="calc-wholesale" class="filter-input" type="number" inputmode="decimal" min="0" step="0.01" @bind="wholesalePrice" placeholder="for OTP/cigar rates" />
            </div>
        </fieldset>
    </details>

    <button type="submit" class="btn-primary" disabled="@(!CanCalculate)" style="margin-top:12px">Calculate</button>
</form>

@if (result is not null)
{
    <section class="calc-result" aria-labelledby="calc-result-label" role="region" aria-live="polite">
        <div id="calc-result-label" class="result-label">Tax to Collect (retailer-remitted)</div>
        <div class="result-value" aria-live="polite">@result.TotalTaxAmount.ToString("C")</div>
        <div class="result-detail">
            <span>Jurisdiction: <strong>@result.JurisdictionName</strong></span>
            <span>Combined Rate: <strong>@result.TotalPercentageRate.ToString("P4")</strong></span>
            <span>Subtotal: <strong>@((price * quantity).ToString("C"))</strong></span>
            <span>Invoice Total: <strong>@((price * quantity + result.TotalTaxAmount).ToString("C"))</strong></span>
        </div>
        @if (result.TotalIncludedInPriceAmount > 0)
        {
            <div class="setup-status-warn" style="margin-top:8px;padding:8px 12px;border-radius:4px">
                Upstream excise taxes already embedded in product price: <strong>@result.TotalIncludedInPriceAmount.ToString("C")</strong> — do not add to customer invoice.
            </div>
        }
        @if (result.RateLines.Count > 0)
        {
            <table class="data-table" style="margin-top:12px" aria-label="Rate breakdown for @result.JurisdictionName">
                <caption class="sr-only">Per-rate breakdown for the selected jurisdiction</caption>
                <thead>
                    <tr>
                        <th scope="col">Rate Name</th><th scope="col">Rate</th><th scope="col">Basis</th><th scope="col">Compound</th>
                        <th scope="col">Sale Context</th><th scope="col">Remittance</th><th scope="col">Tax Amount</th><th scope="col">Effective</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in result.RateLines)
                    {
                        <tr class="@(line.IsIncludedInPrice ? "row-muted" : "")">
                            <th scope="row">
                                @line.RateName
                                @if (line.IsIncludedInPrice) { <span class="badge badge-muted" title="Already embedded in wholesale price" aria-label="Already embedded in wholesale price">embedded</span> }
                            </th>
                            <td>@(line.Basis == TaxRateCollector.Core.Enums.RateBasis.Percentage || line.Basis == TaxRateCollector.Core.Enums.RateBasis.PercentageOfWholesale ? line.Rate.ToString("P4") : line.Rate.ToString("F4") + " " + line.Unit)</td>
                            <td>@line.Basis</td>
                            <td>@(line.IsCompound ? "✓" : "")</td>
                            <td>@line.SaleContext</td>
                            <td>@line.RemittancePoint</td>
                            <td>@line.TaxAmount.ToString("C")</td>
                            <td>@line.EffectiveDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}
@if (noRate)
{
    <p class="muted" role="status" aria-live="polite">No current rate found for the selected jurisdiction.</p>
}

@code {
    private string searchText = string.Empty;
    private bool jurisdictionSelected;
    private int selectedId;
    private string selectedName = string.Empty;
    private decimal price = 100m;
    private int quantity = 1;
    private decimal? abvPct;
    private decimal? volumeGal;
    private decimal? weightOz;
    private decimal? wholesalePrice;
    private TaxCalcResult? result;
    private bool noRate;

    private record JurisdictionOption(int Id, string Name, string StateCode, string Type);
    private List<JurisdictionOption> allJurisdictions = [];
    private List<JurisdictionOption> suggestions = [];

    private bool CanCalculate => jurisdictionSelected && price > 0 && quantity > 0;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        allJurisdictions = await db.Jurisdictions
            .Where(j => j.IsActive || true) // show all for calc
            .Select(j => new JurisdictionOption(j.Id, j.JurisdictionName, j.StateCode, j.JurisdictionType.ToString()))
            .ToListAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        FilterJurisdictions();
    }

    private void FilterJurisdictions()
    {
        jurisdictionSelected = false;
        result = null;
        noRate = false;

        if (string.IsNullOrWhiteSpace(searchText))
        {
            suggestions = [];
            return;
        }

        suggestions = allJurisdictions
            .Where(j => j.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                     || j.StateCode.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList();
    }

    private void SelectJurisdiction(JurisdictionOption j)
    {
        selectedId = j.Id;
        selectedName = $"{j.Name} ({j.StateCode})";
        searchText = selectedName;
        jurisdictionSelected = true;
        suggestions = [];
    }

    private void OnSuggestKey(KeyboardEventArgs e, JurisdictionOption j)
    {
        if (e.Key == "Enter" || e.Key == " " || e.Code == "Space") SelectJurisdiction(j);
    }

    private void ClearJurisdiction()
    {
        selectedId = 0;
        selectedName = string.Empty;
        searchText = string.Empty;
        jurisdictionSelected = false;
        result = null;
        noRate = false;
        suggestions = [];
    }

    private async Task CalculateAsync()
    {
        result = null;
        noRate = false;
        var opts = new TaxCalcOptions(
            Abv:            abvPct.HasValue ? abvPct.Value / 100m : null,
            Volume:         volumeGal,
            Weight:         weightOz,
            WholesalePrice: wholesalePrice);
        var r = await Calculator.CalculateAsync(selectedId, price, quantity, opts);
        if (r is null) noRate = true;
        else result = r;
    }
}
