@page "/runs"
@using Microsoft.EntityFrameworkCore
@using TaxRateCollector.Core.Entities
@using TaxRateCollector.Core.Enums
@using TaxRateCollector.Infrastructure.Data
@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Scrape Runs — TaxRateCollector</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div>
            <h1 id="runs-title" class="page-title">Scrape Runs</h1>
            <p class="page-sub">Queue a scrape job — the Worker Service picks it up and writes progress back here.</p>
        </div>
        <div class="header-actions">
            <button type="button"
                    class="btn-secondary"
                    @onclick="QueueScrape"
                    disabled="@running"
                    aria-busy="@running.ToString().ToLower()">
                @(running ? "Queued…" : "Queue Scrape")
            </button>
            <span class="muted small" role="status" aria-live="polite">@(lastResult ?? "")</span>
        </div>
    </div>
</div>

@if (runs is null)
{
    <p class="muted" role="status" aria-live="polite">Loading…</p>
}
else if (runs.Count == 0)
{
    <p class="muted" role="status" aria-live="polite">No scrape runs yet.</p>
}
else
{
    <table class="data-table" aria-labelledby="runs-title">
        <caption class="sr-only">History of scrape runs with status, progress, and result counts.</caption>
        <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Started</th>
                <th scope="col">Completed</th>
                <th scope="col">Status</th>
                <th scope="col">Progress</th>
                <th scope="col">Changes</th>
                <th scope="col">Errors</th>
                <th scope="col"><span class="sr-only">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in runs)
            {
                <tr>
                    <td>#@r.Id</td>
                    <td>@r.StartedAt[..19]</td>
                    <td>@(r.CompletedAt is not null ? r.CompletedAt[..19] : "—")</td>
                    <td><span class="badge badge-@r.Status.ToString().ToLower()">@r.Status</span></td>
                    <td>
                        @if (r.Status == ScrapeStatus.Running || r.Status == ScrapeStatus.Pending)
                        {
                            <div class="scrape-progress">
                                @if (r.TotalCount > 0)
                                {
                                    var pct = (int)(100.0 * r.ProcessedCount / r.TotalCount);
                                    <div class="scrape-progress-bar"
                                         role="progressbar"
                                         aria-valuemin="0"
                                         aria-valuemax="@r.TotalCount"
                                         aria-valuenow="@r.ProcessedCount"
                                         aria-valuetext="@r.ProcessedCount of @r.TotalCount jurisdictions processed">
                                        <div class="scrape-progress-fill" style="width:@(pct)%"></div>
                                    </div>
                                    <span class="muted small">@r.ProcessedCount / @r.TotalCount</span>
                                }
                                else
                                {
                                    <span class="muted small">Waiting for worker…</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span>@r.TotalScraped</span>
                        }
                    </td>
                    <td>@r.ChangesDetected</td>
                    <td>@r.ErrorCount</td>
                    <td>
                        <button type="button"
                                class="btn-tiny"
                                aria-expanded="@(expanded == r.Id ? "true" : "false")"
                                aria-controls="run-detail-@r.Id"
                                aria-label="@(expanded == r.Id ? $"Hide details for run {r.Id}" : $"Show details for run {r.Id}")"
                                @onclick="() => ToggleDetail(r.Id)">
                            @(expanded == r.Id ? "Hide" : "Details")
                        </button>
                    </td>
                </tr>
                @if (expanded == r.Id)
                {
                    <tr>
                        <td colspan="8">
                            <div id="run-detail-@r.Id" class="run-detail">
                                <strong>Rates recorded in this run:</strong>
                                @if (runRates.Count == 0)
                                {
                                    <span class="muted"> None</span>
                                }
                                else
                                {
                                    <ul>
                                        @foreach (var tr in runRates)
                                        {
                                            <li>@tr.JurisdictionName — @tr.Rate.ToString("P4") (@tr.Name)</li>
                                        }
                                    </ul>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private List<ScrapeRun>? runs;
    private int? expanded;
    private List<(string JurisdictionName, decimal Rate, string Name)> runRates = [];
    private bool running;
    private string? lastResult;

    private Timer? pollTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadRuns();
        StartPollingIfNeeded();
    }

    private void StartPollingIfNeeded()
    {
        var hasActiveRun = runs?.Any(r =>
            r.Status == ScrapeStatus.Pending || r.Status == ScrapeStatus.Running) ?? false;

        if (hasActiveRun && pollTimer is null)
        {
            pollTimer = new Timer(_ => InvokeAsync(PollProgress), null,
                TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
        }
        else if (!hasActiveRun && pollTimer is not null)
        {
            pollTimer.Dispose();
            pollTimer = null;
        }
    }

    private async Task PollProgress()
    {
        await LoadRuns();
        StateHasChanged();
        StartPollingIfNeeded();
    }

    private async Task LoadRuns()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        runs = await db.ScrapeRuns
            .OrderByDescending(r => r.StartedAt)
            .ToListAsync();
    }

    private async Task QueueScrape()
    {
        running = true;
        lastResult = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ScrapeRuns.Add(new ScrapeRun
            {
                StartedAt = DateTime.UtcNow.ToString("o"),
                Status = ScrapeStatus.Pending,
            });
            await db.SaveChangesAsync();
            lastResult = "✓ Job queued — Worker will pick it up shortly";
        }
        catch (Exception ex)
        {
            lastResult = $"✗ {ex.Message}";
        }
        finally
        {
            running = false;
            await LoadRuns();
            StartPollingIfNeeded();
            StateHasChanged();
        }
    }

    private async Task ToggleDetail(int runId)
    {
        if (expanded == runId)
        {
            expanded = null;
            runRates = [];
            return;
        }

        expanded = runId;
        await using var db = await DbFactory.CreateDbContextAsync();
        runRates = await db.TaxRates
            .Include(t => t.Jurisdiction)
            .Where(t => t.ScrapeRunId == runId)
            .Select(t => ValueTuple.Create(t.Jurisdiction.JurisdictionName, t.Rate, t.Name))
            .ToListAsync();
    }

    public void Dispose() => pollTimer?.Dispose();
}
